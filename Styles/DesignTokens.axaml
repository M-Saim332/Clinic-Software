<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Colors -->
  <Color x:Key="ColorPrimaryBlue">#2563EB</Color>
  <Color x:Key="ColorBlue50">#EFF6FF</Color>
  <Color x:Key="ColorTeal">#0F766E</Color>
  <Color x:Key="ColorTeal50">#F0FDFA</Color>
  <Color x:Key="ColorRose">#E11D48</Color>
  <Color x:Key="ColorRose50">#FFF1F2</Color>
  <Color x:Key="ColorAmber">#B45309</Color>
  <Color x:Key="ColorAmber50">#FFFBEB</Color>
  <Color x:Key="ColorInk900">#0F172A</Color>
  <Color x:Key="ColorInk600">#5B6472</Color>
  <Color x:Key="ColorInk400">#98A2B3</Color>
  <Color x:Key="ColorLine">#EAECF0</Color>
  <Color x:Key="ColorBackground">#F9FAFB</Color>
  <Color x:Key="ColorCardBackground">#FFFFFF</Color>

  <!-- Brushes -->
  <SolidColorBrush x:Key="BrushPrimaryBlue" Color="{StaticResource ColorPrimaryBlue}"/>
  <SolidColorBrush x:Key="BrushBlue50" Color="{StaticResource ColorBlue50}"/>
  <SolidColorBrush x:Key="BrushTeal" Color="{StaticResource ColorTeal}"/>
  <SolidColorBrush x:Key="BrushTeal50" Color="{StaticResource ColorTeal50}"/>
  <SolidColorBrush x:Key="BrushRose" Color="{StaticResource ColorRose}"/>
  <SolidColorBrush x:Key="BrushRose50" Color="{StaticResource ColorRose50}"/>
  <SolidColorBrush x:Key="BrushAmber" Color="{StaticResource ColorAmber}"/>
  <SolidColorBrush x:Key="BrushAmber50" Color="{StaticResource ColorAmber50}"/>
  <SolidColorBrush x:Key="BrushInk900" Color="{StaticResource ColorInk900}"/>
  <SolidColorBrush x:Key="BrushInk600" Color="{StaticResource ColorInk600}"/>
  <SolidColorBrush x:Key="BrushInk400" Color="{StaticResource ColorInk400}"/>
  <SolidColorBrush x:Key="BrushLine" Color="{StaticResource ColorLine}"/>
  <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackground}"/>
  <SolidColorBrush x:Key="BrushCardBackground" Color="{StaticResource ColorCardBackground}"/>

  <!-- Corner Radii -->
  <CornerRadius x:Key="CornerRadiusCard">14</CornerRadius>
  <CornerRadius x:Key="CornerRadiusButton">9</CornerRadius>
  <CornerRadius x:Key="CornerRadiusInput">9</CornerRadius>
  <CornerRadius x:Key="CornerRadiusPill">9</CornerRadius>

  <!-- Font Families -->
  <FontFamily x:Key="FontLexend">Lexend,Segoe UI,Arial,sans-serif</FontFamily>
  <FontFamily x:Key="FontInter">Inter,Segoe UI,Arial,sans-serif</FontFamily>
  <FontFamily x:Key="FontMono">IBM Plex Mono,Courier New,Consolas,monospace</FontFamily>
</ResourceDictionary>
