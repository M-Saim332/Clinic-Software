<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ClinicSystem.UI.App"
             xmlns:local="using:ClinicSystem.UI"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ClinicSystem.UI/Styles/DesignTokens.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        <!-- Modern Healthcare Vector Icon Geometries -->
