<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ClinicSystem.UI.App"
             xmlns:local="using:ClinicSystem.UI"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ClinicSystem.UI/Styles/DesignTokens.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        <!-- Modern Healthcare Vector Icon Geometries -->
        <!-- Dashboard: grid/layout icon -->
        <StreamGeometry x:Key="IconDashboard">M4,4H10V10H4V4ZM4,14H10V20H4V14ZM14,4H20V10H14V4ZM14,14H20V20H14V14Z</StreamGeometry>
        <!-- Patients: user with outline -->
        <StreamGeometry x:Key="IconPatients">M12 4C9.79 4 8 5.79 8 8C8 10.21 9.79 12 12 12C14.21 12 16 10.21 16 8C16 5.79 14.21 4 12 4ZM12 14C9.33 14 4 15.34 4 18V20H20V18C20 15.34 14.67 14 12 14Z</StreamGeometry>
