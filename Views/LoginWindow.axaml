<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ClinicSystem.UI.ViewModels"
        x:Class="ClinicSystem.UI.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="Clinic System — Sign In"
        Width="420" Height="620"
        MinWidth="340" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Background="#F8FAFC"
        Icon="avares://ClinicSystem.UI/Assets/hospital_logo.png">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid MinHeight="520" RowDefinitions="*,Auto,*">
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="32"
                    Margin="24"
                    MaxWidth="400"
                    HorizontalAlignment="Center"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    BoxShadow="0 4 6 -1 rgba(0, 0, 0, 0.05), 0 2 4 -1 rgba(0, 0, 0, 0.03)">
                <StackPanel Spacing="24">

                    <!-- Logo / Title -->
                    <StackPanel HorizontalAlignment="Center" Spacing="12">
                        <Border Width="56" Height="56" CornerRadius="28"
                                Background="#EFF6FF" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconClinic}" Width="24" Height="24" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding FormTitle}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="#1F2937"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding FormSubtitle}"
                                       FontSize="13" Foreground="#6B7280"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Username -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="Username" Classes="label"/>
                        <TextBox x:Name="UsernameBox"
                                 Text="{Binding Username}"
                                 PlaceholderText="Enter username"/>
                    </StackPanel>

                    <!-- Password -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="Password" Classes="label"/>
                        <Grid>
                            <TextBox Text="{Binding Password}"
                                     PasswordChar="•"
                                     IsVisible="{Binding !IsPasswordVisible}"
                                     PlaceholderText="Enter password"
                                     Padding="14,0,46,0"/>
                            <TextBox Text="{Binding Password}"
                                     IsVisible="{Binding IsPasswordVisible}"
                                     PlaceholderText="Enter password"
                                     Padding="14,0,46,0"/>
                            <Button Command="{Binding TogglePasswordVisibilityCommand}"
                                    Width="36" Height="36"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,4,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ToolTip.Tip="Show or hide password">
                                <Grid Width="18" Height="18">
                                    <Viewbox IsVisible="{Binding !IsPasswordVisible}">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"
                                                  Stroke="#9CA3AF" StrokeThickness="2"
                                                  StrokeLineCap="Round" StrokeJoin="Round"/>
                                            <Ellipse Width="6" Height="6" Canvas.Left="9" Canvas.Top="9"
                                                     Stroke="#9CA3AF" StrokeThickness="2"/>
                                        </Canvas>
                                    </Viewbox>
                                    <Viewbox IsVisible="{Binding IsPasswordVisible}">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49"
                                                  Stroke="#9CA3AF" StrokeThickness="2"
                                                  StrokeLineCap="Round" StrokeJoin="Round"/>
                                            <Path Data="M14.084 14.158a3 3 0 0 1-4.242-4.242"
                                                  Stroke="#9CA3AF" StrokeThickness="2"
                                                  StrokeLineCap="Round" StrokeJoin="Round"/>
                                            <Path Data="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143"
                                                  Stroke="#9CA3AF" StrokeThickness="2"
                                                  StrokeLineCap="Round" StrokeJoin="Round"/>
                                            <Path Data="M2 2L22 22"
                                                  Stroke="#9CA3AF" StrokeThickness="2"
                                                  StrokeLineCap="Round" StrokeJoin="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Error -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#DC2626" FontSize="13"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasErrorMessage}"/>

                    <!-- Login Button -->
                    <Button Content="{Binding LoginButtonText}"
                            Command="{Binding LoginCommand}"
                            Classes="primary"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding !IsBusy}"/>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
