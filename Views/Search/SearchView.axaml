<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Search"
             xmlns:comp="using:ClinicSystem.UI.Views.Components"
             x:Class="ClinicSystem.UI.Views.Search.SearchView"
             x:DataType="vm:SearchViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushPrimaryBlue50}">
                        <materialIcons:MaterialIcon Kind="Magnify" Width="20" Height="20"
                                  Foreground="{DynamicResource BrushPrimaryBlue}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="Global Search" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk900}"
                                   FontFamily="{DynamicResource FontLexend}"/>
                        <TextBlock Text="Search instantly across patients, appointments, and products"
                                   FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                    </StackPanel>
                </StackPanel>
                <Border DockPanel.Dock="Right" Background="{DynamicResource BrushBackground}"
                        BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                        CornerRadius="{DynamicResource CornerRadiusInput}" Width="350" Height="38" Padding="12,0"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Grid ColumnDefinitions="Auto,*">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="Magnify" Width="14" Height="14"
                                  Foreground="{DynamicResource BrushInk400}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchText}" PlaceholderText="Type to search..."
                                 BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Height="36" Padding="0"/>
                    </Grid>
                </Border>
            </DockPanel>
        </Border>

        <!-- Main Results Panels -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel Spacing="24">
                
                <!-- Patients Results -->
                <comp:DataTableShellControl Title="Matching Patients" RecordCount="{Binding PatientCount, StringFormat='{}{0}'}">
                    <comp:DataTableShellControl.TableContent>
                        <DataGrid ItemsSource="{Binding Patients}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal" Height="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding PatientID}" Width="70"/>
                                <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="AGE" Binding="{Binding Age}" Width="90"/>
                                <DataGridTextColumn Header="GENDER" Binding="{Binding Gender}" Width="110"/>
                                <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="160"/>
                                <DataGridTextColumn Header="ADDRESS" Binding="{Binding Address}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </comp:DataTableShellControl.TableContent>
                </comp:DataTableShellControl>

                <!-- Appointments Results -->
                <comp:DataTableShellControl Title="Matching Appointments" RecordCount="{Binding AppointmentCount, StringFormat='{}{0}'}">
                    <comp:DataTableShellControl.TableContent>
                        <DataGrid ItemsSource="{Binding Appointments}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal" Height="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding AppointmentID}" Width="70"/>
                                <DataGridTextColumn Header="DATE" Binding="{Binding AppointmentDate, StringFormat=\{0:dd MMM yyyy\}}" Width="130"/>
                                <DataGridTextColumn Header="TIME" Binding="{Binding AppointmentTime, StringFormat=\{0:hh\:mm tt\}}" Width="100"/>
                                <DataGridTextColumn Header="PATIENT" Binding="{Binding PatientName}" Width="*"/>
                                <DataGridTextColumn Header="DOCTOR" Binding="{Binding DoctorName}" Width="*"/>
                                <DataGridTemplateColumn Header="STATUS" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <comp:StatusBadgeControl Status="{Binding Status}" VerticalAlignment="Center" Margin="4,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </comp:DataTableShellControl.TableContent>
                </comp:DataTableShellControl>

                <!-- Products Results -->
                <comp:DataTableShellControl Title="Matching Products" RecordCount="{Binding ProductCount, StringFormat='{}{0}'}">
                    <comp:DataTableShellControl.TableContent>
                        <DataGrid ItemsSource="{Binding Products}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal" Height="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding ProductID}" Width="70"/>
                                <DataGridTextColumn Header="PRODUCT NAME" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="GENERIC NAME" Binding="{Binding GenericName}" Width="*"/>
                                <DataGridTextColumn Header="BATCH NO." Binding="{Binding BatchNumber}" Width="120"/>
                                <DataGridTextColumn Header="EXPIRY DATE" Binding="{Binding ExpiryDate, StringFormat=\{0:dd MMM yyyy\}}" Width="145"/>
                                <DataGridTextColumn Header="STOCK LEVEL" Binding="{Binding Stock}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </comp:DataTableShellControl.TableContent>
                </comp:DataTableShellControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
