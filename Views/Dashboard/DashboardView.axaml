<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Dashboard"
             xmlns:models="using:ClinicSystem.Core.Models"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="ClinicSystem.UI.Views.Dashboard.DashboardView"
             x:Name="Root"
             x:DataType="vm:DashboardViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,16,20,20" Spacing="16">


            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- ROW 1: Stat Cards (3 cards in one row)                     -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="*,*,*" Height="100">

                <!-- Appointments -->
                <Border Grid.Column="0" Classes="kpiCard" Margin="0,0,10,0">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Classes="kpiIcon" Background="#FFF1F2">
                            <PathIcon Data="{StaticResource IconAppointments}" Width="22" Height="22" Foreground="#E11D48"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Appointments" Classes="kpiLabel"/>
                            <TextBlock Text="{Binding TotalAppointmentsToday}" Classes="kpiValue"/>
                            <Button Command="{Binding NavigateToAppointmentsCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" Cursor="Hand"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="View all →" Classes="kpiLink" Foreground="#E11D48"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Products -->
                <Border Grid.Column="1" Classes="kpiCard" Margin="5,0,5,0">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Classes="kpiIcon" Background="#F0FDFA">
                            <PathIcon Data="{StaticResource IconProducts}" Width="22" Height="22" Foreground="#0D9488"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Products" Classes="kpiLabel"/>
                            <TextBlock Text="{Binding TotalProducts}" Classes="kpiValue"/>
                            <Button Command="{Binding NavigateToProductsCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" Cursor="Hand"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="View all →" Classes="kpiLink" Foreground="#0D9488"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Stock Value -->
                <Border Grid.Column="2" Classes="kpiCard" Margin="10,0,0,0">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Classes="kpiIcon" Background="#FDF4FF">
                            <PathIcon Data="{StaticResource IconSales}" Width="22" Height="22" Foreground="#9333EA"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Stock Value" Classes="kpiLabel"/>
                            <TextBlock Text="{Binding TotalStockValue}" Classes="kpiValue"/>
                            <Button Command="{Binding NavigateToInventoryCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" Cursor="Hand"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="View inventory →" Classes="kpiLink" Foreground="#9333EA"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- KPI Row 2: Today's financials -->
            <Grid ColumnDefinitions="*,*,*" Height="100" Margin="0,-6,0,0">
                <!-- Today's Revenue -->
                <Border Grid.Column="0" Classes="kpiCard" Margin="0,0,10,0">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Classes="kpiIcon" Background="#F0FDF4">
                            <PathIcon Data="{StaticResource IconSales}" Width="22" Height="22" Foreground="#16A34A"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Today's Revenue" Classes="kpiLabel"/>
                            <TextBlock Text="{Binding TodayRevenue}" Classes="kpiValue" FontSize="18"/>
                            <Button Command="{Binding NavigateToSalesCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" Cursor="Hand" HorizontalAlignment="Left">
                                <TextBlock Text="View sales →" Classes="kpiLink" Foreground="#16A34A"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- Today's Profit -->
                <Border Grid.Column="1" Classes="kpiCard" Margin="5,0,5,0">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Classes="kpiIcon" Background="#EFF6FF">
                            <PathIcon Data="{StaticResource IconReports}" Width="22" Height="22" Foreground="#3B82F6"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Today's Profit" Classes="kpiLabel"/>
                            <TextBlock Text="{Binding TodayProfit}" Classes="kpiValue" FontSize="18"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- Today's Patients -->
                <Border Grid.Column="2" Classes="kpiCard" Margin="10,0,0,0">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Classes="kpiIcon" Background="#FFF7ED">
                            <PathIcon Data="{StaticResource IconPatients}" Width="22" Height="22" Foreground="#F97316"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Today's Patients" Classes="kpiLabel"/>
                            <TextBlock Text="{Binding TodayPatients}" Classes="kpiValue"/>
                            <Button Command="{Binding NavigateToPatientsCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" Cursor="Hand" HorizontalAlignment="Left">
                                <TextBlock Text="View patients →" Classes="kpiLink" Foreground="#F97316"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>


            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- ADMIN QUICK ACTIONS (Admin only)                            -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Border IsVisible="{Binding IsAdmin}"
                    Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                    CornerRadius="{DynamicResource CornerRadiusCard}"
                    Padding="18,14">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="8" Background="#EFF6FF">
                            <PathIcon Data="{StaticResource IconSettings}" Width="15" Height="15"
                                      Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="Admin Quick Actions" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Administrative options visible to Admin role only"
                                       FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Command="{Binding OpenChangePasswordCommand}"
                                Background="{DynamicResource BrushPrimaryBlue}"
                                Foreground="White" BorderThickness="0"
                                CornerRadius="{DynamicResource CornerRadiusPill}"
                                Padding="16,0" Height="36"
                                ToolTip.Tip="Change your Admin account password">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconUsers}" Width="13" Height="13"
                                          Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="Change Password" VerticalAlignment="Center"
                                           FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- ROW 2: Charts                                               -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="3*,2*" Height="380">

                <!-- Left: Profit & Loss Line Chart -->
                <Border Grid.Column="0" Classes="dashCard" Margin="0,0,10,0">
                    <DockPanel>
                        <!-- Chart Header -->
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <TextBlock Text="Profit &amp; Loss Analysis" Classes="cardTitle" VerticalAlignment="Center"/>
                            <!-- Legend -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="12" Height="3" Background="#10B981" VerticalAlignment="Center" CornerRadius="2"/>
                                    <TextBlock Text="Revenue" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="12" Height="3" Background="#3799F8" VerticalAlignment="Center" CornerRadius="2"/>
                                    <TextBlock Text="Profit" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>

                        <!-- Summary Totals Strip -->
                        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,*" Margin="0,10,0,0">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Total Revenue" FontSize="11" Foreground="#6B7280"/>
                                <TextBlock Text="{Binding SummaryTotalRevenue}" FontSize="15" FontWeight="Bold" Foreground="#10B981"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="Total Profit" FontSize="11" Foreground="#6B7280"/>
                                <TextBlock Text="{Binding SummaryTotalProfit}" FontSize="15" FontWeight="Bold" Foreground="#3799F8"/>
                            </StackPanel>
                        </Grid>

                        <!-- The chart itself -->
                        <lvc:CartesianChart Series="{Binding ProfitSeries}"
                                            XAxes="{Binding XAxes}"
                                            TooltipPosition="Top"
                                            Background="Transparent"/>
                    </DockPanel>
                </Border>

                <!-- Right: Revenue Overview Donut -->
                <Border Grid.Column="1" Classes="dashCard" Margin="10,0,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Revenue Overview" Classes="cardTitle" Margin="0,0,0,12"/>

                        <!-- Legend (must be declared BEFORE the fill child) -->
                        <StackPanel DockPanel.Dock="Bottom" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="10" Height="10" CornerRadius="5" Background="#10B981" VerticalAlignment="Center"/>
                                <TextBlock Text="Product Sales" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="10" Height="10" CornerRadius="5" Background="#3799F8" VerticalAlignment="Center"/>
                                <TextBlock Text="Consultation Fees" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="10" Height="10" CornerRadius="5" Background="#A78BFA" VerticalAlignment="Center"/>
                                <TextBlock Text="Other Services" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="10" Height="10" CornerRadius="5" Background="#FBBF24" VerticalAlignment="Center"/>
                                <TextBlock Text="Other Income" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Donut chart area (fill child — declared last) -->
                        <Grid>
                            <lvc:PieChart Series="{Binding RevenueSeries}"
                                          LegendPosition="Hidden"
                                          TooltipPosition="Top"
                                          InitialRotation="-90"
                                          Background="Transparent"/>

                            <!-- Center label overlay -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="Total Revenue" FontSize="10" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SummaryTotalRevenue}" FontSize="13" FontWeight="Bold"
                                           Foreground="#1F2937" HorizontalAlignment="Center" TextWrapping="Wrap"
                                           MaxWidth="110" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                    </DockPanel>
                </Border>

            </Grid>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- ROW 3: Bottom Info Panels                                   -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="*,*,*" Height="230">

                <!-- Low Stock Alert -->
                <Border Grid.Column="0" Classes="dashCard" Margin="0,0,8,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconAlert}" Width="16" Height="16" Foreground="#F59E0B"/>
                                <TextBlock Text="Low Stock Alert" Classes="cardTitle" Foreground="#F59E0B"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding NavigateToProductsCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" Cursor="Hand"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="View all" Foreground="#3B82F6" FontSize="12"/>
                            </Button>
                        </DockPanel>
                        <Border DockPanel.Dock="Top" Height="1" Background="#F3F4F6" Margin="0,0,0,8"/>
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding LowStockProducts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,4">
                                            <TextBlock Text="{Binding Name}" Foreground="#374151" FontSize="13"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <Border DockPanel.Dock="Right" Background="#FEF3C7" CornerRadius="4"
                                                    Padding="6,2" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Stock, StringFormat='Stock: {0}'}"
                                                           Foreground="#D97706" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Expiring Soon -->
                <Border Grid.Column="1" Classes="dashCard" Margin="8,0,8,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconAppointments}" Width="16" Height="16" Foreground="#F59E0B"/>
                                <TextBlock Text="Expiring Soon" Classes="cardTitle"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding NavigateToInventoryCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" Cursor="Hand"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="View all" Foreground="#3B82F6" FontSize="12"/>
                            </Button>
                        </DockPanel>
                        <Border DockPanel.Dock="Top" Height="1" Background="#F3F4F6" Margin="0,0,0,8"/>
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding ExpiringSoonProducts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,4">
                                            <TextBlock Text="{Binding Name}" Foreground="#374151" FontSize="13"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding ExpiryDate, StringFormat={}{0:dd MMM yyyy}}"
                                                       Foreground="#EF4444" FontSize="12" HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Recent Activities -->
                <Border Grid.Column="2" Classes="dashCard" Margin="8,0,0,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconClock}" Width="16" Height="16" Foreground="#3B82F6"/>
                                <TextBlock Text="Recent Activities" Classes="cardTitle"/>
                            </StackPanel>
                            <TextBlock DockPanel.Dock="Right" Text="View all" Foreground="#3B82F6" FontSize="12"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Border DockPanel.Dock="Top" Height="1" Background="#F3F4F6" Margin="0,0,0,8"/>
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding RecentActivities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ActivityLog">
                                        <Border Margin="0,2" Padding="8,6" CornerRadius="6"
                                                Background="Transparent">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0" Width="7" Height="7" CornerRadius="4"
                                                        Background="#3B82F6" VerticalAlignment="Top" Margin="0,5,10,0"/>
                                                <StackPanel Grid.Column="1" Spacing="1">
                                                    <DockPanel>
                                                        <Border DockPanel.Dock="Right" Background="#F3F4F6" CornerRadius="4" Padding="4,2" Margin="6,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Module}" FontSize="9" Foreground="#6B7280" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Title}" Foreground="#1F2937"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding Description}" Foreground="#4B5563"
                                                               FontSize="11" TextTrimming="CharacterEllipsis" TextWrapping="Wrap"
                                                               IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                                        <PathIcon Data="{StaticResource IconProfile}" Width="10" Height="10" Foreground="#9CA3AF"/>
                                                        <TextBlock Text="{Binding UserName}" FontSize="10" Foreground="#9CA3AF"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding TimeAgo}"
                                                           Foreground="#9CA3AF" FontSize="10"
                                                           VerticalAlignment="Top" Margin="8,2,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

            </Grid>

        </StackPanel>
    </ScrollViewer>

    <UserControl.Styles>

        <!-- KPI (top stat) card -->
        <Style Selector="Border.kpiCard">
            <Setter Property="Background" Value="{DynamicResource BrushCardBackground}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusCard}"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #0A000000"/>
        </Style>

        <!-- KPI icon box -->
        <Style Selector="Border.kpiIcon">
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- KPI text styles -->
        <Style Selector="TextBlock.kpiLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk600}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontInter}"/>
        </Style>
        <Style Selector="TextBlock.kpiValue">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontMono}"/>
        </Style>
        <Style Selector="TextBlock.kpiLink">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontInter}"/>
        </Style>

        <!-- General dashboard card -->
        <Style Selector="Border.dashCard">
            <Setter Property="Background" Value="{DynamicResource BrushCardBackground}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusCard}"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #0A000000"/>
        </Style>

        <!-- Card title -->
        <Style Selector="TextBlock.cardTitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontLexend}"/>
        </Style>

    </UserControl.Styles>

</UserControl>

