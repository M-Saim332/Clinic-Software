<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Dashboard"
             x:Class="ClinicSystem.UI.Views.Dashboard.DashboardView"
             x:DataType="vm:DashboardViewModel"
             Background="#F8FAFC">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="24">
            <!-- Summary Cards Row -->
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,*">
                <!-- Patients -->
                <Border Grid.Row="0" Grid.Column="0" Classes="statCard">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Classes="iconBox" Background="#EFF6FF">
                            <PathIcon Data="{StaticResource IconPatients}" Width="20" Height="20" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Patients" Classes="statLabel" />
                            <TextBlock Text="{Binding TotalPatients}" Classes="statValue" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <!-- Companies -->
                <Border Grid.Row="0" Grid.Column="1" Classes="statCard">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Classes="iconBox" Background="#F0FDF4">
                            <PathIcon Data="{StaticResource IconCompanies}" Width="20" Height="20" Foreground="#16A34A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Companies" Classes="statLabel" />
                            <TextBlock Text="{Binding TotalCompanies}" Classes="statValue" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <!-- Products -->
                <Border Grid.Row="0" Grid.Column="2" Classes="statCard">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Classes="iconBox" Background="#FFFBEB">
                            <PathIcon Data="{StaticResource IconProducts}" Width="20" Height="20" Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Products" Classes="statLabel" />
                            <TextBlock Text="{Binding TotalProducts}" Classes="statValue" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <!-- Suppliers -->
                <Border Grid.Row="1" Grid.Column="0" Classes="statCard">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Classes="iconBox" Background="#EFF6FF">
                            <PathIcon Data="{StaticResource IconSuppliers}" Width="20" Height="20" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Suppliers" Classes="statLabel" />
                            <TextBlock Text="{Binding TotalSuppliers}" Classes="statValue" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <!-- Medicines -->
                <Border Grid.Row="1" Grid.Column="1" Classes="statCard">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Classes="iconBox" Background="#EFF6FF">
                            <PathIcon Data="{StaticResource IconMedicines}" Width="20" Height="20" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Medicines" Classes="statLabel" />
                            <TextBlock Text="{Binding TotalMedicines}" Classes="statValue" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <!-- Appointments -->
                <Border Grid.Row="1" Grid.Column="2" Classes="statCard">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Classes="iconBox" Background="#FEF2F2">
                            <PathIcon Data="{StaticResource IconAppointments}" Width="20" Height="20" Foreground="#DC2626" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Appointments" Classes="statLabel" />
                            <TextBlock Text="{Binding TotalAppointmentsToday}" Classes="statValue" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Middle Row: Charts Placeholder -->
            <Grid ColumnDefinitions="2*,1*" Height="320">
                <Border Grid.Column="0" Classes="panelCard" Margin="0,0,12,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Profit &amp; Loss Analysis" Classes="panelTitle" Margin="0,0,0,16"/>
                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8">
                            <TextBlock Text="Line Chart Placeholder (LiveCharts2)" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#9CA3AF" FontSize="13"/>
                        </Border>
                    </DockPanel>
                </Border>
                <Border Grid.Column="1" Classes="panelCard" Margin="12,0,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Revenue Overview" Classes="panelTitle" Margin="0,0,0,16"/>
                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8">
                            <TextBlock Text="Donut Chart Placeholder" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#9CA3AF" FontSize="13"/>
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Bottom Row: Information Panels -->
            <Grid ColumnDefinitions="*,*,*,*" Height="280">
                <!-- Today's Summary -->
                <Border Grid.Column="0" Classes="panelCard" Margin="0,0,8,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconClock}" Width="16" Height="16" Foreground="#2563EB"/>
                                <TextBlock Text="Today's Summary" Classes="panelTitle" />
                            </StackPanel>
                            <TextBlock Text="{Binding TodayDate}" FontSize="12" Foreground="#6B7280" />
                        </StackPanel>
                        <StackPanel Spacing="12">
                            <Border Height="1" Background="#E5E7EB"/>
                            <DockPanel>
                                <TextBlock Text="Today's Appointments:" Foreground="#4B5563" FontSize="14"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding TotalAppointmentsToday}" FontWeight="Bold" Foreground="#1F2937" FontSize="14" HorizontalAlignment="Right" />
                            </DockPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Low Stock Alert -->
                <Border Grid.Column="1" Classes="panelCard" Margin="8,0,8,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                            <PathIcon Data="{StaticResource IconAlert}" Width="16" Height="16" Foreground="#F59E0B"/>
                            <TextBlock Text="Low Stock Alert" Classes="panelTitle" Foreground="#F59E0B" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding LowStockMedicines}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="None" Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Binding="{Binding Stock, StringFormat='Stock: \{0\}'}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Expiring Soon -->
                <Border Grid.Column="2" Classes="panelCard" Margin="8,0,8,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                            <PathIcon Data="{StaticResource IconAppointments}" Width="16" Height="16" Foreground="#DC2626"/>
                            <TextBlock Text="Expiring Soon" Classes="panelTitle" Foreground="#DC2626" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding ExpiringSoonMedicines}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="None" Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Binding="{Binding ExpiryDate, StringFormat=\{0:MM/dd/yyyy\}}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Recent Activities -->
                <Border Grid.Column="3" Classes="panelCard" Margin="8,0,0,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                            <PathIcon Data="{StaticResource IconClock}" Width="16" Height="16" Foreground="#2563EB"/>
                            <TextBlock Text="Recent Activities" Classes="panelTitle" Foreground="#2563EB" />
                        </StackPanel>
                        <ListBox ItemsSource="{Binding RecentActivities}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="13" Foreground="#4B5563" Margin="0,0,0,6"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>

    <UserControl.Styles>
        <Style Selector="Border.statCard">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BoxShadow" Value="0 1 3 0 #06000000" />
        </Style>
        <Style Selector="Border.iconBox">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.statLabel">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
        <Style Selector="TextBlock.statValue">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>
        <Style Selector="TextBlock.panelTitle">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <!-- DataGrid overrides for light theme panels -->
        <Style Selector="DataGrid">
            <Setter Property="Foreground" Value="#4B5563" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </UserControl.Styles>
</UserControl>
