<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Dashboard"
             x:Class="ClinicSystem.UI.Views.Dashboard.DashboardView"
             x:DataType="vm:DashboardViewModel"
             Background="#F5F7FA">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="20">
            <!-- Summary Cards Row -->
            <Grid ColumnDefinitions="*,*,*,*,*,*" Margin="0,0,0,10">
                <!-- Patients -->
                <Border Grid.Column="0" Classes="statCard" Background="#E0F2FE">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Classes="iconBox" Background="#3B82F6">
                            <TextBlock Text="👥" Classes="iconText" />
                        </Border>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Patients" Classes="statLabel" />
                            <TextBlock Text="{Binding TotalPatients}" Classes="statValue" Foreground="#1E3A8A" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <!-- Companies -->
                <Border Grid.Column="1" Classes="statCard" Background="#DCFCE7">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Classes="iconBox" Background="#22C55E">
                            <TextBlock Text="🏢" Classes="iconText" />
                        </Border>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Companies" Classes="statLabel" />
                            <TextBlock Text="{Binding TotalCompanies}" Classes="statValue" Foreground="#14532D" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <!-- Products -->
                <Border Grid.Column="2" Classes="statCard" Background="#FEF3C7">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Classes="iconBox" Background="#F59E0B">
                            <TextBlock Text="📦" Classes="iconText" />
                        </Border>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Products" Classes="statLabel" />
                            <TextBlock Text="{Binding TotalProducts}" Classes="statValue" Foreground="#78350F" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <!-- Suppliers -->
                <Border Grid.Column="3" Classes="statCard" Background="#F3E8FF">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Classes="iconBox" Background="#A855F7">
                            <TextBlock Text="🚚" Classes="iconText" />
                        </Border>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Suppliers" Classes="statLabel" />
                            <TextBlock Text="{Binding TotalSuppliers}" Classes="statValue" Foreground="#4C1D95" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <!-- Medicines -->
                <Border Grid.Column="4" Classes="statCard" Background="#CCFBF1">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Classes="iconBox" Background="#14B8A6">
                            <TextBlock Text="💊" Classes="iconText" />
                        </Border>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Medicines" Classes="statLabel" />
                            <TextBlock Text="{Binding TotalMedicines}" Classes="statValue" Foreground="#134E4A" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <!-- Appointments -->
                <Border Grid.Column="5" Classes="statCard" Background="#FFE4E6">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Classes="iconBox" Background="#F43F5E">
                            <TextBlock Text="📅" Classes="iconText" />
                        </Border>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Appointments" Classes="statLabel" />
                            <TextBlock Text="{Binding TotalAppointmentsToday}" Classes="statValue" Foreground="#881337" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Middle Row: Charts Placeholder -->
            <Grid ColumnDefinitions="2*,1*" Height="300" Margin="0,0,0,10">
                <Border Grid.Column="0" Classes="panelCard" Margin="0,0,10,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Profit &amp; Loss Analysis" Classes="panelTitle" />
                        <Border Background="#F3F4F6" CornerRadius="8" Margin="0,10,0,0">
                            <TextBlock Text="Line Chart Placeholder (LiveCharts2)" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#9CA3AF" />
                        </Border>
                    </DockPanel>
                </Border>
                <Border Grid.Column="1" Classes="panelCard" Margin="10,0,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Revenue Overview" Classes="panelTitle" />
                        <Border Background="#F3F4F6" CornerRadius="8" Margin="0,10,0,0">
                            <TextBlock Text="Donut Chart Placeholder" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#9CA3AF" />
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Bottom Row: Information Panels -->
            <Grid ColumnDefinitions="*,*,*,*" Height="250">
                <!-- Today's Summary -->
                <Border Grid.Column="0" Classes="panelCard" Margin="0,0,5,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Today's Summary" Classes="panelTitle" />
                        <TextBlock DockPanel.Dock="Top" Text="{Binding TodayDate}" FontSize="12" Foreground="#6B7280" Margin="0,0,0,10" />
                        <StackPanel Spacing="10">
                            <DockPanel>
                                <TextBlock Text="Today's Appointments:" Foreground="#4B5563" />
                                <TextBlock DockPanel.Dock="Right" Text="{Binding TotalAppointmentsToday}" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Right" />
                            </DockPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Low Stock Alert -->
                <Border Grid.Column="1" Classes="panelCard" Margin="5,0,5,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="⚠️ Low Stock Alert" Classes="panelTitle" Foreground="#D97706" />
                        <DataGrid ItemsSource="{Binding LowStockMedicines}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="None" Background="Transparent" BorderThickness="0" Margin="0,10,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Binding="{Binding Stock, StringFormat='Stock: \{0\}'}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Expiring Soon -->
                <Border Grid.Column="2" Classes="panelCard" Margin="5,0,5,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="⌛ Expiring Soon" Classes="panelTitle" Foreground="#EA580C" />
                        <DataGrid ItemsSource="{Binding ExpiringSoonMedicines}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="None" Background="Transparent" BorderThickness="0" Margin="0,10,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Binding="{Binding ExpiryDate, StringFormat=\{0:MM/dd/yyyy\}}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Recent Activities -->
                <Border Grid.Column="3" Classes="panelCard" Margin="5,0,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="🕒 Recent Activities" Classes="panelTitle" Foreground="#2563EB" />
                        <ListBox ItemsSource="{Binding RecentActivities}" Background="Transparent" BorderThickness="0" Margin="0,10,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12" Foreground="#4B5563" Margin="0,0,0,5"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>

    <UserControl.Styles>
        <Style Selector="Border.statCard">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="BoxShadow" Value="0 1 3 0 #1A000000" />
        </Style>
        <Style Selector="Border.iconBox">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.iconText">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.statLabel">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#4B5563" />
        </Style>
        <Style Selector="TextBlock.statValue">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="Border.panelCard">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BoxShadow" Value="0 1 3 0 #1A000000" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBlock.panelTitle">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>
        
        <!-- DataGrid overrides for light theme panels -->
        <Style Selector="DataGrid">
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="RowBackground" Value="Transparent" />
        </Style>
    </UserControl.Styles>
</UserControl>
