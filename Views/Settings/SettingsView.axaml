<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Settings"
             xmlns:userviews="using:ClinicSystem.UI.Views.Users"
             x:Class="ClinicSystem.UI.Views.Settings.SettingsView"
             x:DataType="vm:SettingsViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <Panel>
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushPrimaryBlue50}">
                        <materialIcons:MaterialIcon Kind="Cog" Width="20" Height="20"
                                  Foreground="{DynamicResource BrushPrimaryBlue}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk900}"
                                   FontFamily="{DynamicResource FontLexend}"/>
                        <TextBlock Text="Manage clinic configuration, defaults, database backups, and security settings"
                                   FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                    </StackPanel>
                </StackPanel>
                <Button  Command="{Binding SaveSettingsCommand}"
                        Classes="btn-primary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="ContentSave" Width="18" Height="18"/>
        <TextBlock Text="Save Settings" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
            </DockPanel>
        </Border>

        <!-- Main Content Panels -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel Spacing="20" MaxWidth="900" HorizontalAlignment="Left">
                
                <!-- GENERAL SETTINGS -->
                <Border Background="{DynamicResource BrushCardBackground}" BorderBrush="{DynamicResource BrushLine}" BorderThickness="1" CornerRadius="{DynamicResource CornerRadiusCard}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="GENERAL SETTINGS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushInk600}" LetterSpacing="1.2" FontFamily="{DynamicResource FontLexend}"/>
                        <Separator Height="1" Background="{DynamicResource BrushLine}"/>
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" HorizontalAlignment="Stretch">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,12,12">
                                <TextBlock Text="Clinic Name" Classes="label"/>
                                <TextBox Text="{Binding ClinicName}" PlaceholderText="Enter clinic name"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="12,0,0,12">
                                <TextBlock Text="Contact Number" Classes="label"/>
                                <TextBox Text="{Binding ClinicPhone}" PlaceholderText="Enter clinic contact number"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,12,12,0">
                                <TextBlock Text="Email Address" Classes="label"/>
                                <TextBox Text="{Binding ClinicEmail}" PlaceholderText="Enter clinic email"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="12,12,0,0">
                                <TextBlock Text="Physical Address" Classes="label"/>
                                <TextBox Text="{Binding ClinicAddress}" PlaceholderText="Enter clinic physical address"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- BILLING SETTINGS -->
                <Border Background="{DynamicResource BrushCardBackground}" BorderBrush="{DynamicResource BrushLine}" BorderThickness="1" CornerRadius="{DynamicResource CornerRadiusCard}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="BILLING SETTINGS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushInk600}" LetterSpacing="1.2" FontFamily="{DynamicResource FontLexend}"/>
                        <Separator Height="1" Background="{DynamicResource BrushLine}"/>
                        <Grid ColumnDefinitions="*,*,*" HorizontalAlignment="Stretch">
                            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,12,0">
                                <TextBlock Text="Invoice Prefix" Classes="label"/>
                                <TextBox Text="{Binding InvoicePrefix}" PlaceholderText="e.g. INV-"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,12,0">
                                <TextBlock Text="Default Tax Rate (%)" Classes="label"/>
                                <NumericUpDown Value="{Binding DefaultTaxRate}" FormatString="N2" Increment="0.1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4" Margin="12,0,0,0">
                                <TextBlock Text="Currency" Classes="label"/>
                                <TextBox Text="{Binding Currency}" PlaceholderText="e.g. USD, PKR"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- INVENTORY SETTINGS -->
                <Border Background="{DynamicResource BrushCardBackground}" BorderBrush="{DynamicResource BrushLine}" BorderThickness="1" CornerRadius="{DynamicResource CornerRadiusCard}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="INVENTORY SETTINGS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushInk600}" LetterSpacing="1.2" FontFamily="{DynamicResource FontLexend}"/>
                        <Separator Height="1" Background="{DynamicResource BrushLine}"/>
                        <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch">
                            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,12,0">
                                <TextBlock Text="Low Stock Threshold" Classes="label"/>
                                <NumericUpDown Value="{Binding LowStockThreshold}" Minimum="1" Maximum="1000"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,0,0">
                                <TextBlock Text="Expiry Alert Days" Classes="label"/>
                                <NumericUpDown Value="{Binding ExpiryAlertDays}" Minimum="1" Maximum="365"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- SYSTEM SETTINGS -->
                <Border Background="{DynamicResource BrushCardBackground}" BorderBrush="{DynamicResource BrushLine}" BorderThickness="1" CornerRadius="{DynamicResource CornerRadiusCard}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="SYSTEM SETTINGS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushInk600}" LetterSpacing="1.2" FontFamily="{DynamicResource FontLexend}"/>
                        <Separator Height="1" Background="{DynamicResource BrushLine}"/>
                        <Grid ColumnDefinitions="*,*,*" HorizontalAlignment="Stretch">
                            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,12,0">
                                <TextBlock Text="Date Format" Classes="label"/>
                                <ComboBox ItemsSource="{Binding DateFormatOptions}" SelectedItem="{Binding DateFormat}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,12,0">
                                <TextBlock Text="Time Format" Classes="label"/>
                                <ComboBox ItemsSource="{Binding TimeFormatOptions}" SelectedItem="{Binding TimeFormat}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4" Margin="12,0,0,0">
                                <TextBlock Text="Language" Classes="label"/>
                                <ComboBox ItemsSource="{Binding LanguageOptions}" SelectedItem="{Binding Language}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- DATABASE & MAINTENANCE -->
                <Border Background="{DynamicResource BrushCardBackground}" BorderBrush="{DynamicResource BrushLine}" BorderThickness="1" CornerRadius="{DynamicResource CornerRadiusCard}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="DATABASE &amp; MAINTENANCE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushInk600}" LetterSpacing="1.2" FontFamily="{DynamicResource FontLexend}"/>
                        <Separator Height="1" Background="{DynamicResource BrushLine}"/>

                        <!-- Backup / Restore row -->
                        <DockPanel>
                            <StackPanel Spacing="4" DockPanel.Dock="Left">
                                <TextBlock Text="Backup &amp; Restore" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrushInk900}"/>
                                <TextBlock Text="Save a full database backup or restore from an existing .bak file."
                                           FontSize="12" Foreground="{DynamicResource BrushInk600}" TextWrapping="Wrap" MaxWidth="440"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button   Command="{Binding BackupCommand}"  Classes="btn-secondary" IsEnabled="{Binding !IsBusy}">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="DatabaseExport" Width="18" Height="18"/>
        <TextBlock Text="Backup Database" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                                <Button  Command="{Binding RestoreCommand}" Classes="btn-secondary" IsEnabled="{Binding !IsBusy}">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="DatabaseImport" Width="18" Height="18"/>
        <TextBlock Text="Restore Database" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                            </StackPanel>
                        </DockPanel>

                        <Separator Height="1" Background="{DynamicResource BrushLine}" Margin="0,4"/>

                        <!-- Reset to Zero row -->
                        <DockPanel>
                            <StackPanel Spacing="4" DockPanel.Dock="Left">
                                <TextBlock Text="Delete All Data" FontSize="14" FontWeight="SemiBold" Foreground="#DC2626"/>
                                <TextBlock Text="Wipes ALL products, patients, companies, transactions etc. Users are preserved. A rollback backup is created automatically before deletion."
                                           FontSize="12" Foreground="{DynamicResource BrushInk600}" TextWrapping="Wrap" MaxWidth="440"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button 
                                        Command="{Binding RollbackResetCommand}"
                                        IsVisible="{Binding IsRollbackAvailable}"
                                        IsEnabled="{Binding !IsBusy}"
                                        Background="#F59E0B" Foreground="White"
                                        BorderThickness="0" CornerRadius="{DynamicResource CornerRadiusPill}"
                                        Padding="14,0" Height="36" FontSize="13" FontWeight="SemiBold">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Undo" Width="18" Height="18"/>
        <TextBlock Text="Rollback Reset" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                                <Button 
                                        Command="{Binding ShowResetConfirmCommand}"
                                        IsEnabled="{Binding !IsBusy}"
                                        Background="#DC2626" Foreground="White"
                                        BorderThickness="0" CornerRadius="{DynamicResource CornerRadiusPill}"
                                        Padding="14,0" Height="36" FontSize="13" FontWeight="SemiBold">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Delete" Width="18" Height="18"/>
        <TextBlock Text="Delete All Data" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                            </StackPanel>
                        </DockPanel>

                        <!-- Confirmation Banner (appears after clicking Reset to Zero) -->
                        <Border IsVisible="{Binding IsResetConfirmVisible}"
                                Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                                CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="⚠️" FontSize="20" VerticalAlignment="Center"/>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Are you absolutely sure?" FontSize="14" FontWeight="Bold" Foreground="#991B1B"/>
                                        <TextBlock Text="This will permanently delete all clinical data. A rollback backup will be saved first so you can undo this action."
                                                   FontSize="12" Foreground="#7F1D1D" TextWrapping="Wrap" MaxWidth="500"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button 
                                            Command="{Binding ConfirmResetCommand}"
                                            Background="#DC2626" Foreground="White"
                                            BorderThickness="0" CornerRadius="{DynamicResource CornerRadiusPill}"
                                            Padding="16,0" Height="36" FontSize="13" FontWeight="SemiBold">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Delete" Width="18" Height="18"/>
        <TextBlock Text="Yes, Delete Everything" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                                    <Button 
                                            Command="{Binding CancelResetCommand}"
                                            Classes="btn-secondary">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Close" Width="18" Height="18"/>
        <TextBlock Text="Cancel" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Admin Security (Admin only) -->
                <Border IsVisible="{Binding IsAdmin}"
                        Background="{DynamicResource BrushCardBackground}"
                        BorderBrush="#FCA5A5" BorderThickness="1"
                        CornerRadius="{DynamicResource CornerRadiusCard}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="ADMIN SECURITY" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushRose}" LetterSpacing="1.2"
                                   FontFamily="{DynamicResource FontLexend}"/>
                        <Separator Height="1" Background="#FCA5A5"/>
                        <DockPanel>
                            <StackPanel Spacing="4" DockPanel.Dock="Left">
                                <TextBlock Text="Change Admin Password" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushInk900}"/>
                                <TextBlock Text="Update your admin account password. You will need to verify your current password first."
                                           FontSize="12" Foreground="{DynamicResource BrushInk600}"
                                           TextWrapping="Wrap" MaxWidth="480"/>
                            </StackPanel>
                            <Button Command="{Binding OpenChangePasswordCommand}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="{DynamicResource BrushRose}"
                                    Foreground="White" BorderThickness="0"
                                    CornerRadius="{DynamicResource CornerRadiusPill}"
                                    Padding="16,0" Height="36">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <materialIcons:MaterialIcon Kind="AccountCog" Width="13" Height="13"
                                              Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="Change Password" FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- USER MANAGEMENT (Admin Only) -->
                <Border IsVisible="{Binding IsAdmin}"
                        Background="{DynamicResource BrushCardBackground}"
                        BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                        CornerRadius="{DynamicResource CornerRadiusCard}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="USER MANAGEMENT" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk600}" LetterSpacing="1.2"
                                   FontFamily="{DynamicResource FontLexend}"/>
                        <Separator Height="1" Background="{DynamicResource BrushLine}"/>
                        <Border Height="800" Background="{DynamicResource BrushBackground}" CornerRadius="8" ClipToBounds="True">
                            <userviews:UserRegistryView DataContext="{Binding UserRegistryVM}" />
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource BrushCardBackground}" Padding="28,16" BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushInk600}" FontSize="13" VerticalAlignment="Center" FontWeight="Medium"/>
        </Border>
    </Grid>

    <!-- Change Password Modal Overlay (Settings-triggered) -->
    <Panel IsVisible="{Binding IsChangePasswordVisible}" ZIndex="200">
        <userviews:ChangePasswordView DataContext="{Binding ChangePasswordVM}"/>
    </Panel>

    </Panel>

    <UserControl.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk500}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource BrushPrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </UserControl.Styles>
</UserControl>
