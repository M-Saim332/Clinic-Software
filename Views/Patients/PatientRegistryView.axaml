<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Patients"
             xmlns:models="using:ClinicSystem.Core.Models"
             x:Class="ClinicSystem.UI.Views.Patients.PatientRegistryView"
             x:DataType="vm:PatientRegistryViewModel"
             Background="#0F1117">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A1D27" Padding="20,14" BorderBrush="#2A2D3A" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="👥 Patients Registry" FontSize="20" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}"
                           Foreground="#0097A7" VerticalAlignment="Center" FontSize="13"/>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="340,*">

            <!-- Left Panel: Form -->
            <Border Grid.Column="0" Background="#141720" Padding="20" BorderBrush="#2A2D3A" BorderThickness="0,0,1,0">
                <ScrollViewer>
                    <StackPanel Spacing="14">

                        <!-- Action Buttons Row 1 -->
                        <TextBlock Text="Actions" Foreground="#666" FontSize="11" FontWeight="SemiBold"/>
                        <WrapPanel Margin="0,0,0,16">
                            <Button Content="New"    Command="{Binding NewCommand}"    IsEnabled="{Binding MutationEnabled}" Classes="action"/>
                            <Button Content="Edit"   Command="{Binding EditCommand}"   IsEnabled="{Binding MutationEnabled}" Classes="action"/>
                            <Button Content="Delete" Command="{Binding DeleteCommand}" IsEnabled="{Binding MutationEnabled}" Classes="action danger"/>
                            <Button Content="Save"   Command="{Binding SaveCommand}"   IsEnabled="{Binding SaveCancelEnabled}" Classes="action primary"/>
                            <Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding SaveCancelEnabled}" Classes="action"/>
                        </WrapPanel>

                        <!-- Action Buttons Row 2 -->
                        <WrapPanel>
                            <Button Content="Find"  Command="{Binding FindCommand}"      IsEnabled="{Binding MutationEnabled}" Classes="action"/>
                            <Button Content="List"  Command="{Binding ListCommand}"      IsEnabled="{Binding MutationEnabled}" Classes="action"/>
                        </WrapPanel>

                        <Separator Background="#2A2D3A" Height="1" Margin="0,4"/>

                        <!-- Form Fields -->
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Full Name *" Classes="label"/>
                                <TextBox Text="{Binding Name}" IsEnabled="{Binding SaveCancelEnabled}" Classes="field" PlaceholderText="Patient full name"/>
                            </StackPanel>
                            <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch">
                                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                                    <TextBlock Text="Age" Classes="label"/>
                                    <TextBox Text="{Binding Age}" IsEnabled="{Binding SaveCancelEnabled}" Classes="field" PlaceholderText="Years"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Gender" Classes="label"/>
                                    <ComboBox ItemsSource="{Binding GenderOptions}"
                                              SelectedItem="{Binding Gender}"
                                              IsEnabled="{Binding SaveCancelEnabled}"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Phone" Classes="label"/>
                                <TextBox Text="{Binding Phone}" IsEnabled="{Binding SaveCancelEnabled}" Classes="field" PlaceholderText="Phone number"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Address" Classes="label"/>
                                <TextBox Text="{Binding Address}" IsEnabled="{Binding SaveCancelEnabled}" Classes="field" PlaceholderText="Full address"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Diagnosis" Classes="label"/>
                                <TextBox Text="{Binding Diagnosis}"
                                         IsEnabled="{Binding SaveCancelEnabled}"
                                         Classes="field"
                                         PlaceholderText="Diagnosis notes..."
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         Height="60"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Prescription" Classes="label"/>
                                <TextBox Text="{Binding Prescription}"
                                         IsEnabled="{Binding SaveCancelEnabled}"
                                         Classes="field"
                                         PlaceholderText="Prescribed medicines..."
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         Height="60"/>
                            </StackPanel>
                            <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch">
                                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                                    <TextBlock Text="Consultation Fee" Classes="label"/>
                                    <TextBox Text="{Binding ConsultationFee}" IsEnabled="{Binding SaveCancelEnabled}" Classes="field" PlaceholderText="0.00"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Discount" Classes="label"/>
                                    <TextBox Text="{Binding Discount}" IsEnabled="{Binding SaveCancelEnabled}" Classes="field" PlaceholderText="0.00"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Panel: List Overlay or Patient Preview -->
            <Border Grid.Column="1" Padding="20">
                <Grid>
                    <!-- Patient List (shown when ShowList is true) -->
                    <Border IsVisible="{Binding ShowList}" Background="#141720" CornerRadius="10" Padding="16">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <TextBlock Text="Find Patient" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                <Button DockPanel.Dock="Right" Content="✕ Close" Command="{Binding CloseListCommand}" Classes="action" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <TextBox DockPanel.Dock="Top" Text="{Binding SearchTerm}"
                                     PlaceholderText="Search by name or phone..." Margin="0,0,0,10"
                                     Classes="field"/>
                            <DataGrid ItemsSource="{Binding FilteredPatients}"
                                      SelectedItem="{Binding SelectedPatient}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Background="#141720" RowBackground="#141720"
                                      Foreground="White"
                                      GridLinesVisibility="Horizontal"
                                      BorderBrush="#2A2D3A"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="*"/>
                                    <DataGridTextColumn Header="Age"     Binding="{Binding Age}"     Width="50"/>
                                    <DataGridTextColumn Header="Gender"  Binding="{Binding Gender}"  Width="70"/>
                                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                                </DataGrid.Columns>
                                <DataGrid.Styles>
                                    <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
                                        <Setter Property="Fill" Value="#0097A7"/>
                                    </Style>
                                </DataGrid.Styles>
                            </DataGrid>
                            <Button DockPanel.Dock="Bottom" Content="Select" Margin="0,10,0,0"
                                    Command="{Binding SelectFromListCommand}"
                                    CommandParameter="{Binding SelectedPatient}"
                                    Classes="action primary" HorizontalAlignment="Left"/>
                        </DockPanel>
                    </Border>

                    <!-- Info panel when nothing selected -->
                    <StackPanel IsVisible="{Binding !ShowList}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="👥" FontSize="64" HorizontalAlignment="Center"/>
                        <TextBlock Text="Patients Registry" FontSize="22" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Use New to add a patient, or List to search existing records."
                                   Foreground="#666" HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#141720" Padding="16,8" BorderBrush="#2A2D3A" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#888" FontSize="12"/>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="TextBox.field">
            <Setter Property="Background" Value="#252837"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Background" Value="#252837"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.action.primary">
            <Setter Property="Background" Value="#0097A7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.action.danger">
            <Setter Property="Background" Value="#B71C1C"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.35"/>
        </Style>
    </UserControl.Styles>
</UserControl>
