<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Patients"
             xmlns:comp="using:ClinicSystem.UI.Views.Components"
             x:Class="ClinicSystem.UI.Views.Patients.PatientRegistryView"
             x:Name="Root"
             x:DataType="vm:PatientRegistryViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <Grid>
        <!-- LIST VIEW -->
        <Grid IsVisible="{Binding !SaveCancelEnabled}" RowDefinitions="Auto,Auto,*">
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushBlue50}">
                            <PathIcon Data="{StaticResource IconPatients}" Width="20" Height="20"
                                      Foreground="{DynamicResource BrushPrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="Patient Registry" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Manage patient records and consultation details"
                                       FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="+ Add Patient" Command="{Binding NewCommand}"
                            Classes="btn-primary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Summary Cards -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Margin="28,16,28,4">
                <comp:SummaryCardControl Grid.Column="0" Margin="0,0,12,0"
                    Title="Total Patients"
                    Value="{Binding TotalPatientsCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushPrimaryBlue}"/>
                <comp:SummaryCardControl Grid.Column="1" Margin="0,0,12,0"
                    Title="Active This Month"
                    Value="{Binding ActiveThisMonthCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushAmber}"/>
                <comp:SummaryCardControl Grid.Column="2" Margin="0,0,12,0"
                    Title="Waiting Today"
                    Value="{Binding WaitingTodayCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushTeal}"/>
                <comp:SummaryCardControl Grid.Column="3"
                    Title="Avg Consultation Fee"
                    Value="{Binding AvgConsultationFee}"
                    BorderColor="{DynamicResource BrushRose}"/>
            </Grid>

            <!-- Data Panel -->
            <Grid Grid.Row="2" Margin="28,12,28,24">
                <comp:DataTableShellControl Title="Patients" RecordCount="{Binding FilteredPatients.Count}">
                    <comp:DataTableShellControl.FilterToolbar>
                        <Border Background="{DynamicResource BrushCardBackground}"
                                BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                                CornerRadius="{DynamicResource CornerRadiusInput}" Padding="12,0"
                                Height="40" Width="380" Margin="0,0,16,8">
                            <Grid ColumnDefinitions="Auto,*">
                                <PathIcon Grid.Column="0" Data="{StaticResource IconSearch}" Width="14" Height="14"
                                          Foreground="{DynamicResource BrushInk400}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchTerm}"
                                         PlaceholderText="Search patient by name, phone, diagnosis..."
                                         Classes="search-input"
                                         VerticalAlignment="Center" Height="38" Padding="0"/>
                            </Grid>
                        </Border>
                    </comp:DataTableShellControl.FilterToolbar>
                    <comp:DataTableShellControl.TableContent>
                        <DataGrid ItemsSource="{Binding FilteredPatients}" SelectedItem="{Binding SelectedPatient}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" Background="Transparent" BorderThickness="0"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="AGE" Binding="{Binding Age}" Width="90"/>
                                <DataGridTextColumn Header="GENDER" Binding="{Binding Gender}" Width="120"/>
                                <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="160"/>
                                <DataGridTextColumn Header="DIAGNOSIS" Binding="{Binding Diagnosis}" Width="*"/>
                                <DataGridTemplateColumn Header="ACTIONS" Width="300">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Content="View" Command="{Binding #Root.((vm:PatientRegistryViewModel)DataContext).ViewSpecificCommand}" CommandParameter="{Binding}" Classes="btn-secondary" Padding="8,4" Height="28" FontSize="11"/>
                                                <Button Content="Edit" Command="{Binding #Root.((vm:PatientRegistryViewModel)DataContext).EditSpecificCommand}" CommandParameter="{Binding}" Classes="btn-secondary" Padding="8,4" Height="28" FontSize="11"/>
                                                <Button Content="Delete" Command="{Binding #Root.((vm:PatientRegistryViewModel)DataContext).DeleteSpecificCommand}" CommandParameter="{Binding}" Classes="btn-danger" Padding="8,4" Height="28" FontSize="11"/>
                                                <Button Content="Book" Command="{Binding #Root.((vm:PatientRegistryViewModel)DataContext).BookAppointmentSpecificCommand}" CommandParameter="{Binding}" Classes="btn-primary" Padding="8,4" Height="28" FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </comp:DataTableShellControl.TableContent>
                </comp:DataTableShellControl>
            </Grid>
        </Grid>

        <!-- FORM VIEW -->
        <Grid IsVisible="{Binding SaveCancelEnabled}" RowDefinitions="Auto,*,Auto">
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushBlue50}">
                            <PathIcon Data="{StaticResource IconPatients}" Width="20" Height="20"
                                      Foreground="{DynamicResource BrushPrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="{Binding Mode, StringFormat='{}{0} Patient'}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}" FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Fill out patient details below" FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="Back" Command="{Binding CancelCommand}"
                            Classes="btn-secondary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Form Body -->
            <ScrollViewer Grid.Row="1" Padding="28,24">
                <StackPanel Spacing="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="PATIENT DETAILS" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk400}" LetterSpacing="1.5"
                                   FontFamily="{DynamicResource FontLexend}"/>
                        <Separator/>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" HorizontalAlignment="Stretch">
                            
                            <!-- Row 0 -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="Full Name *" Classes="label"/>
                                <TextBox Text="{Binding Name}" IsReadOnly="{Binding IsReadOnly}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="0" Spacing="6" Margin="12,0,0,12">
                                <TextBlock Text="Phone Number" Classes="label"/>
                                <TextBox Text="{Binding Phone}" IsReadOnly="{Binding IsReadOnly}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            
                            <!-- Row 1 -->
                            <StackPanel Grid.Column="0" Grid.Row="1" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="Age" Classes="label"/>
                                <TextBox Text="{Binding Age}" PlaceholderText="e.g. 35" IsReadOnly="{Binding IsReadOnly}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Spacing="6" Margin="12,0,0,12">
                                <TextBlock Text="Gender" Classes="label"/>
                                <ComboBox ItemsSource="{Binding GenderOptions}" SelectedItem="{Binding Gender}" HorizontalAlignment="Stretch" IsEnabled="{Binding !IsReadOnly}"/>
                            </StackPanel>
                            
                            <!-- Row 2 -->
                            <StackPanel Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Spacing="6" Margin="0,0,0,12">
                                <TextBlock Text="Address" Classes="label"/>
                                <TextBox Text="{Binding Address}" AcceptsReturn="True" Height="60" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="12,10" IsReadOnly="{Binding IsReadOnly}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            
                            <!-- Row 3 -->
                            <StackPanel Grid.Column="0" Grid.Row="3" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="Diagnosis" Classes="label"/>
                                <TextBox Text="{Binding Diagnosis}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="12,10" IsReadOnly="{Binding IsReadOnly}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="3" Spacing="6" Margin="12,0,0,12">
                                <TextBlock Text="Prescription" Classes="label"/>
                                <TextBox Text="{Binding Prescription}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="12,10" IsReadOnly="{Binding IsReadOnly}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            
                            <!-- Row 4 -->
                            <StackPanel Grid.Column="0" Grid.Row="4" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="Consultation Fee" Classes="label"/>
                                <TextBox Text="{Binding ConsultationFee}" PlaceholderText="0.00" IsReadOnly="{Binding IsReadOnly}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="4" Spacing="6" Margin="12,0,0,12">
                                <TextBlock Text="Discount" Classes="label"/>
                                <TextBox Text="{Binding Discount}" PlaceholderText="0.00" IsReadOnly="{Binding IsReadOnly}" HorizontalAlignment="Stretch"/>
                            </StackPanel>

                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,1,0,0" Padding="28,16">
                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushRose}"
                               VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Edit Patient" Command="{Binding EditSpecificCommand}" CommandParameter="{Binding SelectedPatient}" Classes="btn-secondary" IsVisible="{Binding ShowEditButton}"/>
                        <Button Content="Save Patient" Command="{Binding SaveCommand}" Classes="btn-primary" IsVisible="{Binding ShowSaveButton}"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource BrushPrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk600}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="{DynamicResource BrushRose}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#BE123C"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-success">
            <Setter Property="Background" Value="#16A34A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.40"/>
        </Style>
    </UserControl.Styles>
</UserControl>
