<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Patients"
             xmlns:comp="using:ClinicSystem.UI.Views.Components"
             x:Class="ClinicSystem.UI.Views.Patients.PatientRegistryView"
             x:Name="Root"
             x:DataType="vm:PatientRegistryViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <Grid>
        <Grid IsVisible="{Binding IsListViewVisible}" RowDefinitions="Auto,*">
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushBlue50}">
                            <PathIcon Data="{StaticResource IconPatients}" Width="20" Height="20"
                                      Foreground="{DynamicResource BrushPrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="Patient Registry" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Manage patient records and consultation details"
                                       FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="+ Add Patient" Command="{Binding NewCommand}"
                            Classes="btn-primary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="28,16,28,24" RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushRose}" Margin="0,0,0,10"/>

                <comp:DataTableShellControl Grid.Row="1" Title="Patients" RecordCount="{Binding FilteredPatients.Count}">
                    <comp:DataTableShellControl.FilterToolbar>
                        <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                            <TextBox Grid.Column="0" Text="{Binding SearchTerm}" PlaceholderText="Search patient by name, phone, diagnosis..." MaxWidth="460"/>
                        </Grid>
                    </comp:DataTableShellControl.FilterToolbar>
                    <comp:DataTableShellControl.TableContent>
                        <DataGrid ItemsSource="{Binding FilteredPatients}"
                                  SelectedItem="{Binding SelectedPatient}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="AGE" Binding="{Binding Age}" Width="90"/>
                                <DataGridTextColumn Header="GENDER" Binding="{Binding Gender}" Width="120"/>
                                <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="160"/>
                                <DataGridTextColumn Header="DIAGNOSIS" Binding="{Binding Diagnosis}" Width="*"/>
                                <DataGridTemplateColumn Header="ACTIONS" Width="240">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Content="View" Command="{Binding #Root.((vm:PatientRegistryViewModel)DataContext).ViewSpecificCommand}" CommandParameter="{Binding}" Classes="btn-secondary" Padding="12,4" Height="28" FontSize="11"/>
                                                <Button Content="Edit" Command="{Binding #Root.((vm:PatientRegistryViewModel)DataContext).EditSpecificCommand}" CommandParameter="{Binding}" Classes="btn-secondary" Padding="12,4" Height="28" FontSize="11"/>
                                                <Button Content="Delete" Command="{Binding #Root.((vm:PatientRegistryViewModel)DataContext).DeleteSpecificCommand}" CommandParameter="{Binding}" Classes="btn-danger" Padding="12,4" Height="28" FontSize="11"/>
                                                <Button Content="Book" Command="{Binding #Root.((vm:PatientRegistryViewModel)DataContext).BookAppointmentSpecificCommand}" CommandParameter="{Binding}" Classes="btn-primary" Padding="12,4" Height="28" FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </comp:DataTableShellControl.TableContent>
                </comp:DataTableShellControl>
            </Grid>
        </Grid>

        <Grid IsVisible="{Binding SaveCancelEnabled}" RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <TextBlock Text="{Binding Mode, StringFormat='{}{0} Patient'}" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource BrushInk900}" FontFamily="{DynamicResource FontLexend}"/>
                    <Button Content="← Back to Patients" Command="{Binding CancelCommand}"
                            Classes="btn-secondary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Row="1" Padding="28,24">
                <StackPanel Spacing="14" MaxWidth="760">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushRose}"/>
                    <TextBlock Text="Full Name *" Classes="label"/>
                    <TextBox Text="{Binding Name}" IsReadOnly="{Binding IsReadOnly}"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Age" Classes="label"/>
                            <TextBox Text="{Binding Age}" PlaceholderText="e.g. 35" IsReadOnly="{Binding IsReadOnly}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Gender" Classes="label"/>
                            <ComboBox ItemsSource="{Binding GenderOptions}" SelectedItem="{Binding Gender}" HorizontalAlignment="Stretch" IsEnabled="{Binding !IsReadOnly}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Phone" Classes="label"/>
                    <TextBox Text="{Binding Phone}" IsReadOnly="{Binding IsReadOnly}"/>
                    <TextBlock Text="Address" Classes="label"/>
                    <TextBox Text="{Binding Address}" AcceptsReturn="True" Height="70" IsReadOnly="{Binding IsReadOnly}"/>
                    <TextBlock Text="Diagnosis" Classes="label"/>
                    <TextBox Text="{Binding Diagnosis}" AcceptsReturn="True" Height="70" IsReadOnly="{Binding IsReadOnly}"/>
                    <TextBlock Text="Prescription" Classes="label"/>
                    <TextBox Text="{Binding Prescription}" AcceptsReturn="True" Height="70" IsReadOnly="{Binding IsReadOnly}"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Consultation Fee" Classes="label"/>
                            <TextBox Text="{Binding ConsultationFee}" PlaceholderText="0.00" IsReadOnly="{Binding IsReadOnly}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Discount" Classes="label"/>
                            <TextBox Text="{Binding Discount}" PlaceholderText="0.00" IsReadOnly="{Binding IsReadOnly}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,1,0,0" Padding="28,16">
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button Content="Back" Command="{Binding CancelCommand}" Classes="btn-ghost"/>
                    <Button Content="Edit Patient" Command="{Binding EditSpecificCommand}" CommandParameter="{Binding SelectedPatient}" Classes="btn-secondary" IsVisible="{Binding ShowEditButton}"/>
                    <Button Content="Save Patient" Command="{Binding SaveCommand}" Classes="btn-primary" IsVisible="{Binding ShowSaveButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource BrushPrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk600}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="{DynamicResource BrushRose}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Styles>
</UserControl>
