<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Patients"
             xmlns:models="using:ClinicSystem.Core.Models"
             x:Class="ClinicSystem.UI.Views.Patients.PatientRegistryView"
             x:DataType="vm:PatientRegistryViewModel"
             Background="#F8FAFC">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="24,16" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource IconPatients}" Width="20" Height="20" Foreground="#2563EB"/>
                    <TextBlock Text="Patients Registry" FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}"
                           Foreground="#2563EB" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="360,*">

            <!-- Left Panel: Form -->
            <Border Grid.Column="0" Background="#FFFFFF" Padding="24" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
                <ScrollViewer>
                    <StackPanel Spacing="16">

                        <!-- Action Buttons Row 1 -->
                        <TextBlock Text="Actions" Classes="label" Foreground="#6B7280" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="New"    Command="{Binding NewCommand}"    IsEnabled="{Binding MutationEnabled}" Classes="action" Margin="0,0,6,6"/>
                            <Button Content="Edit"   Command="{Binding EditCommand}"   IsEnabled="{Binding MutationEnabled}" Classes="action" Margin="0,0,6,6"/>
                            <Button Content="Delete" Command="{Binding DeleteCommand}" IsEnabled="{Binding MutationEnabled}" Classes="action danger" Margin="0,0,6,6"/>
                            <Button Content="Save"   Command="{Binding SaveCommand}"   IsEnabled="{Binding SaveCancelEnabled}" Classes="action primary" Margin="0,0,6,6"/>
                            <Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding SaveCancelEnabled}" Classes="action" Margin="0,0,6,6"/>
                        </WrapPanel>

                        <!-- Action Buttons Row 2 -->
                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="Find"  Command="{Binding FindCommand}"      IsEnabled="{Binding MutationEnabled}" Classes="action" Margin="0,0,6,6"/>
                            <Button Content="List"  Command="{Binding ListCommand}"      IsEnabled="{Binding MutationEnabled}" Classes="action" Margin="0,0,6,6"/>
                        </WrapPanel>

                        <Separator Background="#E5E7EB" Height="1" Margin="0,8"/>

                        <!-- Form Fields -->
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Full Name *" Classes="label"/>
                                <TextBox Text="{Binding Name}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="Patient full name"/>
                            </StackPanel>
                            <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch">
                                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                                    <TextBlock Text="Age" Classes="label"/>
                                    <TextBox Text="{Binding Age}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="Years"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Gender" Classes="label"/>
                                    <ComboBox ItemsSource="{Binding GenderOptions}"
                                              SelectedItem="{Binding Gender}"
                                              IsEnabled="{Binding SaveCancelEnabled}"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Phone" Classes="label"/>
                                <TextBox Text="{Binding Phone}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="Phone number"/>
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Address" Classes="label"/>
                                <TextBox Text="{Binding Address}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="Full address"/>
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Diagnosis" Classes="label"/>
                                <TextBox Text="{Binding Diagnosis}"
                                         IsEnabled="{Binding SaveCancelEnabled}"
                                         PlaceholderText="Diagnosis notes..."
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         Height="80" VerticalContentAlignment="Top" Padding="12,10"/>
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Prescription" Classes="label"/>
                                <TextBox Text="{Binding Prescription}"
                                         IsEnabled="{Binding SaveCancelEnabled}"
                                         PlaceholderText="Prescribed medicines..."
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         Height="80" VerticalContentAlignment="Top" Padding="12,10"/>
                            </StackPanel>
                            <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch">
                                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                                    <TextBlock Text="Consultation Fee" Classes="label"/>
                                    <TextBox Text="{Binding ConsultationFee}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="0.00"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Discount" Classes="label"/>
                                    <TextBox Text="{Binding Discount}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="0.00"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Panel: List Overlay or Patient Preview -->
            <Border Grid.Column="1" Padding="24">
                <Grid>
                    <!-- Patient List (shown when ShowList is true) -->
                    <Border IsVisible="{Binding ShowList}" Background="#FFFFFF" Classes="card">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                                <TextBlock Text="Find Patient" FontSize="16" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Command="{Binding CloseListCommand}" Classes="action"
                                        HorizontalAlignment="Right" Width="32" Height="32" Padding="0"
                                        Background="Transparent" BorderThickness="0">
                                    <PathIcon Data="{StaticResource IconClose}" Width="12" Height="12" Foreground="#6B7280"/>
                                </Button>
                            </DockPanel>
                            <TextBox DockPanel.Dock="Top" Text="{Binding SearchTerm}"
                                     PlaceholderText="Search by name or phone..." Margin="0,0,0,16"/>
                            <DataGrid ItemsSource="{Binding FilteredPatients}"
                                      SelectedItem="{Binding SelectedPatient}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="*"/>
                                    <DataGridTextColumn Header="Age"     Binding="{Binding Age}"     Width="60"/>
                                    <DataGridTextColumn Header="Gender"  Binding="{Binding Gender}"  Width="80"/>
                                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button DockPanel.Dock="Bottom" Content="Select Patient" Margin="0,16,0,0"
                                    Command="{Binding SelectFromListCommand}"
                                    CommandParameter="{Binding SelectedPatient}"
                                    Classes="action primary" HorizontalAlignment="Left"/>
                        </DockPanel>
                    </Border>

                    <!-- Info panel when nothing selected -->
                    <StackPanel IsVisible="{Binding !ShowList}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                        <Border Width="64" Height="64" CornerRadius="32" Background="#EFF6FF">
                            <PathIcon Data="{StaticResource IconPatients}" Width="24" Height="24" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Patients Registry" FontSize="20" FontWeight="Bold"
                                   Foreground="#1F2937" HorizontalAlignment="Center"/>
                        <TextBlock Text="Use 'New' to add a patient, or 'List' to search existing records."
                                   Foreground="#6B7280" HorizontalAlignment="Center" TextAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#FFFFFF" Padding="24,8" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#6B7280" FontSize="12"/>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.action">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.action.primary">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.action.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.action.danger">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.action.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#B91C1C"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
    </UserControl.Styles>
</UserControl>
