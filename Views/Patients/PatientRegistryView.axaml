<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Patients"
             xmlns:models="using:ClinicSystem.Core.Models"
             xmlns:comp="using:ClinicSystem.UI.Views.Components"
             x:Class="ClinicSystem.UI.Views.Patients.PatientRegistryView"
             x:DataType="vm:PatientRegistryViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ── Page Header ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1"
                Padding="28,18">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushBlue50}">
                        <PathIcon Data="{StaticResource IconPatients}" Width="20" Height="20"
                                  Foreground="{DynamicResource BrushPrimaryBlue}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="Patients Registry" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk900}"
                                   FontFamily="{DynamicResource FontLexend}"/>
                        <TextBlock Text="Manage patient records, diagnoses and consultation history"
                                   FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action Toolbar (right side of header) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="New"    Command="{Binding NewCommand}"    IsEnabled="{Binding MutationEnabled}"  Classes="btn-secondary"/>
                    <Button Content="Edit"   Command="{Binding EditCommand}"   IsEnabled="{Binding MutationEnabled}"  Classes="btn-secondary"/>
                    <Button Content="Find"   Command="{Binding FindCommand}"   IsEnabled="{Binding MutationEnabled}"  Classes="btn-secondary"/>
                    <Button Content="List"   Command="{Binding ListCommand}"   IsEnabled="{Binding MutationEnabled}"  Classes="btn-secondary"/>
                    <Border Width="1" Background="{DynamicResource BrushLine}" Height="22" VerticalAlignment="Center"/>
                    <Button Content="Save"   Command="{Binding SaveCommand}"   IsEnabled="{Binding SaveCancelEnabled}" Classes="btn-primary"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding SaveCancelEnabled}" Classes="btn-ghost"/>
                    <Border Width="1" Background="{DynamicResource BrushLine}" Height="22" VerticalAlignment="Center"/>
                    <Button Content="Delete" Command="{Binding DeleteCommand}" IsEnabled="{Binding MutationEnabled}"  Classes="btn-danger"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── KPI Summary Cards ─────────────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Margin="28,16,28,4">
            <comp:SummaryCardControl Grid.Column="0" Margin="0,0,12,0"
                Title="Total Patients"
                Value="{Binding TotalPatientsCount, StringFormat={}{0}}"
                BorderColor="{DynamicResource BrushPrimaryBlue}"/>
            <comp:SummaryCardControl Grid.Column="1" Margin="0,0,12,0"
                Title="Active This Month"
                Value="{Binding ActiveThisMonthCount, StringFormat={}{0}}"
                BorderColor="{DynamicResource BrushTeal}"/>
            <comp:SummaryCardControl Grid.Column="2" Margin="0,0,12,0"
                Title="Waiting Today"
                Value="{Binding WaitingTodayCount, StringFormat={}{0}}"
                BorderColor="{DynamicResource BrushAmber}"/>
            <comp:SummaryCardControl Grid.Column="3"
                Title="Avg Consultation"
                Value="{Binding AvgConsultationFee}"
                BorderColor="{DynamicResource BrushRose}"/>
        </Grid>

        <!-- ── Main Content ──────────────────────────────────────────────── -->
        <Grid Grid.Row="2" ColumnDefinitions="380,*" Margin="28,12,28,0">

            <!-- LEFT: Form Card ──────────────────────────────── -->
            <Border Grid.Column="0" Margin="0,0,12,0"
                    Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                    CornerRadius="{DynamicResource CornerRadiusCard}"
                    BoxShadow="0 1 3 0 #0A000000">
                <ScrollViewer Padding="24">
                    <StackPanel Spacing="16">

                        <!-- Form Section Label -->
                        <TextBlock Text="PATIENT DETAILS" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk400}"
                                   LetterSpacing="1.5" FontFamily="{DynamicResource FontLexend}"/>

                        <!-- Full Name -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Full Name *" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushInk600}"/>
                            <TextBox Text="{Binding Name}" IsEnabled="{Binding SaveCancelEnabled}"
                                     PlaceholderText="Patient full name"
                                     CornerRadius="{DynamicResource CornerRadiusInput}"/>
                        </StackPanel>

                        <!-- Age + Gender -->
                        <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch">
                            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                <TextBlock Text="Age" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushInk600}"/>
                                <TextBox Text="{Binding Age}" IsEnabled="{Binding SaveCancelEnabled}"
                                         PlaceholderText="Years"
                                         CornerRadius="{DynamicResource CornerRadiusInput}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Gender" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushInk600}"/>
                                <ComboBox ItemsSource="{Binding GenderOptions}"
                                          SelectedItem="{Binding Gender}"
                                          IsEnabled="{Binding SaveCancelEnabled}"
                                          HorizontalAlignment="Stretch"
                                          CornerRadius="{DynamicResource CornerRadiusInput}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Phone -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Phone" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushInk600}"/>
                            <TextBox Text="{Binding Phone}" IsEnabled="{Binding SaveCancelEnabled}"
                                     PlaceholderText="e.g. 0300-1234567"
                                     CornerRadius="{DynamicResource CornerRadiusInput}"/>
                        </StackPanel>

                        <!-- Address -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Address" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushInk600}"/>
                            <TextBox Text="{Binding Address}" IsEnabled="{Binding SaveCancelEnabled}"
                                     PlaceholderText="Full address"
                                     CornerRadius="{DynamicResource CornerRadiusInput}"/>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource BrushLine}" Margin="0,4"/>

                        <TextBlock Text="CLINICAL NOTES" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk400}"
                                   LetterSpacing="1.5" FontFamily="{DynamicResource FontLexend}"/>

                        <!-- Diagnosis -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Diagnosis" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushInk600}"/>
                            <TextBox Text="{Binding Diagnosis}" IsEnabled="{Binding SaveCancelEnabled}"
                                     PlaceholderText="Diagnosis notes..."
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="80" VerticalContentAlignment="Top" Padding="12,10"
                                     CornerRadius="{DynamicResource CornerRadiusInput}"/>
                        </StackPanel>

                        <!-- Prescription -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Prescription" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushInk600}"/>
                            <TextBox Text="{Binding Prescription}" IsEnabled="{Binding SaveCancelEnabled}"
                                     PlaceholderText="Prescribed medicines..."
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="80" VerticalContentAlignment="Top" Padding="12,10"
                                     CornerRadius="{DynamicResource CornerRadiusInput}"/>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource BrushLine}" Margin="0,4"/>

                        <TextBlock Text="BILLING" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk400}"
                                   LetterSpacing="1.5" FontFamily="{DynamicResource FontLexend}"/>

                        <!-- Fee + Discount -->
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                <TextBlock Text="Consultation Fee" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushInk600}"/>
                                <TextBox Text="{Binding ConsultationFee}" IsEnabled="{Binding SaveCancelEnabled}"
                                         PlaceholderText="0.00"
                                         CornerRadius="{DynamicResource CornerRadiusInput}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Discount" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushInk600}"/>
                                <TextBox Text="{Binding Discount}" IsEnabled="{Binding SaveCancelEnabled}"
                                         PlaceholderText="0.00"
                                         CornerRadius="{DynamicResource CornerRadiusInput}"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- RIGHT: List / Placeholder ────────────────────── -->
            <Grid Grid.Column="1">

                <!-- Patient List overlay -->
                <Border IsVisible="{Binding ShowList}"
                        Background="{DynamicResource BrushCardBackground}"
                        BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                        CornerRadius="{DynamicResource CornerRadiusCard}"
                        BoxShadow="0 1 3 0 #0A000000" Padding="24">
                    <DockPanel>

                        <!-- List header -->
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource IconSearch}" Width="16" Height="16"
                                          Foreground="{DynamicResource BrushPrimaryBlue}"/>
                                <TextBlock Text="Find Patient" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource BrushInk900}"
                                           FontFamily="{DynamicResource FontLexend}"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Command="{Binding CloseListCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Width="32" Height="32" Padding="0" HorizontalAlignment="Right">
                                <PathIcon Data="{StaticResource IconClose}" Width="12" Height="12"
                                          Foreground="{DynamicResource BrushInk600}"/>
                            </Button>
                        </DockPanel>

                        <!-- Search box -->
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource BrushBackground}"
                                BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                                CornerRadius="{DynamicResource CornerRadiusInput}" Padding="12,0"
                                Margin="0,0,0,16" Height="44">
                            <Grid ColumnDefinitions="Auto,*">
                                <PathIcon Grid.Column="0" Data="{StaticResource IconSearch}" Width="14" Height="14"
                                          Foreground="{DynamicResource BrushInk400}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchTerm}"
                                         PlaceholderText="Search by name or phone..."
                                         BorderThickness="0" Background="Transparent"
                                         VerticalAlignment="Center" Height="42" Padding="0"/>
                            </Grid>
                        </Border>

                        <!-- Select button at bottom -->
                        <Button DockPanel.Dock="Bottom"
                                Content="Select Patient" Margin="0,16,0,0"
                                Command="{Binding SelectFromListCommand}"
                                CommandParameter="{Binding SelectedPatient}"
                                Classes="btn-primary" HorizontalAlignment="Left"/>

                        <!-- DataGrid -->
                        <DataGrid ItemsSource="{Binding FilteredPatients}"
                                  SelectedItem="{Binding SelectedPatient}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single"
                                  Background="{DynamicResource BrushBackground}"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="{DynamicResource BrushCardBackground}">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"   Binding="{Binding Name}"   Width="*"/>
                                <DataGridTextColumn Header="Age"    Binding="{Binding Age}"    Width="60"/>
                                <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="80"/>
                                <DataGridTextColumn Header="Phone"  Binding="{Binding Phone}"  Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>

                    </DockPanel>
                </Border>

                <!-- Empty state placeholder -->
                <Border IsVisible="{Binding !ShowList}"
                        Background="{DynamicResource BrushCardBackground}"
                        BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                        CornerRadius="{DynamicResource CornerRadiusCard}"
                        BoxShadow="0 1 3 0 #0A000000">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                        <Border Width="72" Height="72" CornerRadius="36" Background="{DynamicResource BrushBlue50}"
                                HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconPatients}" Width="28" Height="28"
                                      Foreground="{DynamicResource BrushPrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="Patients Registry" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       HorizontalAlignment="Center"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Use 'New' to add a patient, or 'List' to browse existing records."
                                       Foreground="{DynamicResource BrushInk600}"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       FontSize="13" MaxWidth="320" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Quick action hints -->
                        <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <Border Margin="4" Background="{DynamicResource BrushBlue50}"
                                    CornerRadius="{DynamicResource CornerRadiusPill}" Padding="12,6">
                                <TextBlock Text="New → Add patient" FontSize="12"
                                           Foreground="{DynamicResource BrushPrimaryBlue}" FontWeight="Medium"/>
                            </Border>
                            <Border Margin="4" Background="{DynamicResource BrushTeal50}"
                                    CornerRadius="{DynamicResource CornerRadiusPill}" Padding="12,6">
                                <TextBlock Text="List → Search records" FontSize="12"
                                           Foreground="{DynamicResource BrushTeal}" FontWeight="Medium"/>
                            </Border>
                            <Border Margin="4" Background="{DynamicResource BrushAmber50}"
                                    CornerRadius="{DynamicResource CornerRadiusPill}" Padding="12,6">
                                <TextBlock Text="Edit → Modify selected" FontSize="12"
                                           Foreground="{DynamicResource BrushAmber}" FontWeight="Medium"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>

        <!-- ── Status Bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Margin="0,12,0,0"
                Background="{DynamicResource BrushCardBackground}"
                BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,1,0,0"
                Padding="28,8">
            <DockPanel>
                <PathIcon Data="{StaticResource IconClinic}" Width="12" Height="12"
                          Foreground="{DynamicResource BrushInk400}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource BrushInk600}" FontSize="12"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

    </Grid>

    <UserControl.Styles>
        <!-- Primary btn -->
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource BrushPrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>

        <!-- Secondary btn -->
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Ghost btn -->
        <Style Selector="Button.btn-ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk600}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Danger btn -->
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="{DynamicResource BrushRose}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#BE123C"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>

        <!-- Disabled state -->
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.40"/>
        </Style>
    </UserControl.Styles>
</UserControl>
