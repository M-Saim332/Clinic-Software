<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Inventory"
             xmlns:comp="using:ClinicSystem.UI.Views.Components"
             x:Class="ClinicSystem.UI.Views.Inventory.InventoryView"
             x:Name="Root"
             x:DataType="vm:InventoryViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushPrimaryBlue50}">
                        <materialIcons:MaterialIcon Kind="Store" Width="20" Height="20"
                                  Foreground="{DynamicResource BrushPrimaryBlue}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="Inventory Management" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk900}"
                                   FontFamily="{DynamicResource FontLexend}"/>
                        <TextBlock Text="Monitor product stocks, expiry dates, and perform manual adjustments"
                                   FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- KPI Summary Cards -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Margin="28,16,28,4">
            <comp:SummaryCardControl Grid.Column="0" Margin="0,0,12,0"
                Title="Total Stock Items"
                Value="{Binding TotalStockItems, StringFormat={}{0}}"
                BorderColor="{DynamicResource BrushPrimaryBlue}"/>
            <comp:SummaryCardControl Grid.Column="1" Margin="0,0,12,0"
                Title="Low Stock Items"
                Value="{Binding LowStockCount, StringFormat={}{0}}"
                BorderColor="{DynamicResource BrushAmber}"/>
            <comp:SummaryCardControl Grid.Column="2" Margin="0,0,12,0"
                Title="Out of Stock"
                Value="{Binding OutOfStockCount, StringFormat={}{0}}"
                BorderColor="{DynamicResource BrushRose}"/>
            <comp:SummaryCardControl Grid.Column="3"
                Title="Expired Batches"
                Value="{Binding ExpiredCount, StringFormat={}{0}}"
                BorderColor="{DynamicResource BrushRose}"/>
        </Grid>

        <!-- Main Body split -->
        <Grid Grid.Row="2" ColumnDefinitions="360,*" Margin="28,12,28,24">
            <!-- Left: Manual Stock Adjustment -->
            <Border Grid.Column="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                    CornerRadius="{DynamicResource CornerRadiusCard}"
                    Padding="24" Margin="0,0,24,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="MANUAL ADJUSTMENT" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource BrushInk400}" LetterSpacing="1.5"
                               FontFamily="{DynamicResource FontLexend}" Margin="0,0,0,16"/>

                    <StackPanel DockPanel.Dock="Bottom" Spacing="12" Margin="0,16,0,0">
                        <Button  Command="{Binding AdjustStockCommand}"
                                Classes="btn-primary" HorizontalAlignment="Stretch" Height="40" VerticalContentAlignment="Center">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Sync" Width="18" Height="18"/>
        <TextBlock Text="Update Stock Level" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushRose}" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer>
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Select Product *" Classes="label"/>
                                <ComboBox ItemsSource="{Binding AllStock}" SelectedItem="{Binding SelectedProduct}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name, StringFormat='{}{0}'}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Quantity Change (+ to Add, - to Remove) *" Classes="label"/>
                                <NumericUpDown Value="{Binding AdjustmentQuantity}" FormatString="N0"/>
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Reason for Adjustment" Classes="label"/>
                                <TextBox Text="{Binding AdjustmentReason}" PlaceholderText="Explain why the stock is being updated..."
                                         AcceptsReturn="True" Height="100" TextWrapping="Wrap"
                                         VerticalContentAlignment="Top" Padding="12,10"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Right: Stock Tabs -->
            <Border Grid.Column="1" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                    CornerRadius="{DynamicResource CornerRadiusCard}" Padding="16">
                <TabControl>
                    <!-- All Stock -->
                    <TabItem Header="All Stock">
                        <comp:DataTableShellControl Title="Full Stock Listing" RecordCount="{Binding AllStock.Count}">
                            <comp:DataTableShellControl.TableContent>
                                <DataGrid ItemsSource="{Binding AllStock}" AutoGenerateColumns="False" IsReadOnly="True"
                                          Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="PRODUCT" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="BATCH" Binding="{Binding BatchNumber}" Width="120"/>
                                        <DataGridTextColumn Header="STOCK LEVEL" Binding="{Binding Stock}" Width="120"/>
                                        <DataGridTextColumn Header="EXPIRY DATE" Binding="{Binding ExpiryDate, StringFormat=\{0:dd MMM yyyy\}}" Width="150"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </comp:DataTableShellControl.TableContent>
                        </comp:DataTableShellControl>
                    </TabItem>

                    <!-- Low Stock -->
                    <TabItem Header="Low Stock">
                        <comp:DataTableShellControl Title="Low Stock Alert" RecordCount="{Binding LowStock.Count}">
                            <comp:DataTableShellControl.TableContent>
                                <DataGrid ItemsSource="{Binding LowStock}" AutoGenerateColumns="False" IsReadOnly="True"
                                          Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="PRODUCT" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="CURRENT STOCK" Binding="{Binding Stock}" Width="140"/>
                                        <DataGridTextColumn Header="MINIMUM REQUIRED" Binding="{Binding MinimumStockLevel}" Width="160"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </comp:DataTableShellControl.TableContent>
                        </comp:DataTableShellControl>
                    </TabItem>

                    <!-- Out of Stock -->
                    <TabItem Header="Out of Stock">
                        <comp:DataTableShellControl Title="Out of Stock Alert" RecordCount="{Binding OutOfStock.Count}">
                            <comp:DataTableShellControl.TableContent>
                                <DataGrid ItemsSource="{Binding OutOfStock}" AutoGenerateColumns="False" IsReadOnly="True"
                                          Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="PRODUCT" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="CURRENT STOCK" Binding="{Binding Stock}" Width="140"/>
                                        <DataGridTextColumn Header="MINIMUM REQUIRED" Binding="{Binding MinimumStockLevel}" Width="160"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </comp:DataTableShellControl.TableContent>
                        </comp:DataTableShellControl>
                    </TabItem>

                    <!-- Near Expiry -->
                    <TabItem Header="Near Expiry">
                        <comp:DataTableShellControl Title="Expiring Within 30 Days" RecordCount="{Binding NearExpiry.Count}">
                            <comp:DataTableShellControl.TableContent>
                                <DataGrid ItemsSource="{Binding NearExpiry}" AutoGenerateColumns="False" IsReadOnly="True"
                                          Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="PRODUCT" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="BATCH" Binding="{Binding BatchNumber}" Width="120"/>
                                        <DataGridTextColumn Header="STOCK LEVEL" Binding="{Binding Stock}" Width="120"/>
                                        <DataGridTextColumn Header="EXPIRY DATE" Binding="{Binding ExpiryDate, StringFormat=\{0:dd MMM yyyy\}}" Width="150"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </comp:DataTableShellControl.TableContent>
                        </comp:DataTableShellControl>
                    </TabItem>

                    <!-- Expired -->
                    <TabItem Header="Expired">
                        <comp:DataTableShellControl Title="Expired Batches (Do Not Sell)" RecordCount="{Binding Expired.Count}">
                            <comp:DataTableShellControl.TableContent>
                                <DataGrid ItemsSource="{Binding Expired}" AutoGenerateColumns="False" IsReadOnly="True"
                                          Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="PRODUCT" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="BATCH" Binding="{Binding BatchNumber}" Width="120"/>
                                        <DataGridTextColumn Header="STOCK LEVEL" Binding="{Binding Stock}" Width="120"/>
                                        <DataGridTextColumn Header="EXPIRY DATE" Binding="{Binding ExpiryDate, StringFormat=\{0:dd MMM yyyy\}}" Width="150"/>
                                        <DataGridTemplateColumn Header="ACTIONS" Width="160">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button  Command="{Binding #Root.((vm:InventoryViewModel)DataContext).OpenSupplierReturnModalCommand}" CommandParameter="{Binding}" Classes="btn-danger" Padding="8,4" Height="28" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="KeyboardReturn" Width="18" Height="18"/>
        <TextBlock Text="Return to Supplier" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </comp:DataTableShellControl.TableContent>
                        </comp:DataTableShellControl>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- SUPPLIER RETURN MODAL -->
        <Border IsVisible="{Binding IsSupplierReturnModalOpen}" Background="#80000000" ZIndex="100" Grid.RowSpan="3">
            <Border Background="{DynamicResource BrushBackground}" Width="450" CornerRadius="12"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="Return to Supplier" FontSize="18" FontWeight="Bold" FontFamily="{DynamicResource FontLexend}"/>
                    
                    <TextBlock Text="{Binding ReturnTargetProduct.Name, StringFormat='Returning Expired Product: {0}'}" FontWeight="SemiBold" Foreground="{DynamicResource BrushInk600}"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Quantity to Return" FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        <NumericUpDown Minimum="1" Value="{Binding SupplierReturnQuantity}" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Notes / Reason" FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        <TextBox Text="{Binding SupplierReturnNotes}" AcceptsReturn="True" Height="60" TextWrapping="Wrap" VerticalContentAlignment="Top"/>
                    </StackPanel>
                    
                    <Border Background="{DynamicResource BrushBlue50}" CornerRadius="8" Padding="12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="Estimated Credit" Foreground="{DynamicResource BrushPrimaryBlue}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right" Text="{Binding SupplierCreditAmount, StringFormat='Rs. {0:N2}'}" Foreground="{DynamicResource BrushPrimaryBlue}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushRose}" TextWrapping="Wrap" MinHeight="20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
                        <Button  Command="{Binding CloseSupplierReturnModalCommand}" Classes="btn-secondary">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Close" Width="18" Height="18"/>
        <TextBlock Text="Cancel" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                        <Button  Command="{Binding SubmitSupplierReturnCommand}" Classes="btn-danger">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="KeyboardReturn" Width="18" Height="18"/>
        <TextBlock Text="Process Return" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource BrushPrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="{DynamicResource BrushRose}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#BE123C"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>
</UserControl>
