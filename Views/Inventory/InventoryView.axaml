<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Inventory"
             x:Class="ClinicSystem.UI.Views.Inventory.InventoryView"
             x:DataType="vm:InventoryViewModel" x:CompileBindings="True"
             Background="#F8FAFC">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="24,16"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource IconInventory}" Width="20" Height="20" Foreground="#2563EB"/>
                    <TextBlock Text="Inventory" FontSize="20" FontWeight="Bold"
                               Foreground="#1F2937" VerticalAlignment="Center"/>
                </StackPanel>
                
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" ColumnDefinitions="300,*" Margin="24">

            <!-- Stock Adjustment Side -->
            <Border Grid.Column="0" Classes="card">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Manual Adjustment" Classes="sectionTitle" Margin="0,0,0,20"/>

                    <StackPanel DockPanel.Dock="Bottom" Spacing="12" Margin="0,20,0,0">
                        <Button Content="Update Stock" Command="{Binding AdjustStockCommand}"
                                Classes="primary" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center" Padding="10"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#DC2626" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Spacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Medicine" Classes="label"/>
                            <ComboBox ItemsSource="{Binding AllStock}" SelectedItem="{Binding SelectedMedicine}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock Text="Quantity (+ to Add, − to Remove)" Classes="label"/>
                            <NumericUpDown Value="{Binding AdjustmentQuantity}" FormatString="N0"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock Text="Reason" Classes="label"/>
                            <TextBox Text="{Binding AdjustmentReason}" AcceptsReturn="True"
                                     Height="80" VerticalContentAlignment="Top" Padding="12,10"
                                     PlaceholderText="Reason for adjustment..."/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Grid Side (Tabs) -->
            <Border Grid.Column="1" Classes="card" Margin="24,0,0,0" Padding="16">
                <TabControl>
                    <TabItem Header="All Stock">
                        <DataGrid ItemsSource="{Binding AllStock}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Medicine" Binding="{Binding Name}"                                        Width="*"/>
                                <DataGridTextColumn Header="Batch"    Binding="{Binding BatchNumber}"                                 Width="100"/>
                                <DataGridTextColumn Header="Stock"    Binding="{Binding Stock}"                                       Width="80"/>
                                <DataGridTextColumn Header="Expiry"   Binding="{Binding ExpiryDate, StringFormat=\{0:MM/dd/yyyy\}}"   Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Low Stock">
                        <DataGrid ItemsSource="{Binding LowStock}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Medicine"  Binding="{Binding Name}"                Width="*"/>
                                <DataGridTextColumn Header="Stock"     Binding="{Binding Stock}"               Width="80"/>
                                <DataGridTextColumn Header="Min Level" Binding="{Binding MinimumStockLevel}"   Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Out of Stock">
                        <DataGrid ItemsSource="{Binding OutOfStock}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Medicine"  Binding="{Binding Name}"                Width="*"/>
                                <DataGridTextColumn Header="Stock"     Binding="{Binding Stock}"               Width="80"/>
                                <DataGridTextColumn Header="Min Level" Binding="{Binding MinimumStockLevel}"   Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Expiring Soon (30d)">
                        <DataGrid ItemsSource="{Binding NearExpiry}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Medicine"    Binding="{Binding Name}"                                       Width="*"/>
                                <DataGridTextColumn Header="Batch"       Binding="{Binding BatchNumber}"                                Width="100"/>
                                <DataGridTextColumn Header="Stock"       Binding="{Binding Stock}"                                      Width="80"/>
                                <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate, StringFormat=\{0:MM/dd/yyyy\}}"  Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Expired">
                        <DataGrid ItemsSource="{Binding Expired}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Medicine"    Binding="{Binding Name}"                                       Width="*"/>
                                <DataGridTextColumn Header="Batch"       Binding="{Binding BatchNumber}"                                Width="100"/>
                                <DataGridTextColumn Header="Stock"       Binding="{Binding Stock}"                                      Width="80"/>
                                <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate, StringFormat=\{0:MM/dd/yyyy\}}"  Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#FFFFFF" Padding="24,8"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#6B7280" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>

