<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Prescriptions"
             xmlns:models="using:ClinicSystem.Core.Models"
             x:Class="ClinicSystem.UI.Views.Prescriptions.PrescriptionView"
             x:DataType="vm:PrescriptionViewModel" x:CompileBindings="True"
             Background="#F8FAFC">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="24,16" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource IconVisit}" Width="20" Height="20" Foreground="#2563EB"/>
                    <TextBlock Text="New Visit / Prescription" FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
                </StackPanel>
                
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="340,*">

            <!-- Left: Prescription Details -->
            <Border Grid.Column="0" Background="#FFFFFF" Padding="24" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
                <ScrollViewer>
                    <StackPanel Spacing="16">

                        <!-- Patient Selection -->
                        <TextBlock Text="Patient" Classes="label" Foreground="#6B7280" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding SelectedPatient.Name, FallbackValue='No patient selected'}"
                                           Foreground="{Binding PatientNameColor}"
                                           FontSize="15" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedPatient.Contact}" Foreground="#6B7280" FontSize="13"
                                           IsVisible="{Binding HasSelectedPatient}"/>
                                <Button Command="{Binding PickPatientCommand}" Classes="primary" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="{StaticResource IconPatients}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock Text="Select Patient" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <StackPanel Spacing="2">
                            <TextBlock Text="Visit Date" Classes="label"/>
                            <DatePicker SelectedDate="{Binding VisitDate}" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock Text="Diagnosis" Classes="label"/>
                            <TextBox Text="{Binding Diagnosis}" PlaceholderText="Primary diagnosis..."
                                     AcceptsReturn="True" Height="80" VerticalContentAlignment="Top" Padding="12,10"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock Text="Notes" Classes="label"/>
                            <TextBox Text="{Binding Notes}" PlaceholderText="Additional notes..."
                                     AcceptsReturn="True" Height="80" VerticalContentAlignment="Top" Padding="12,10"/>
                        </StackPanel>

                        <Separator Background="#E5E7EB" Height="1" Margin="0,8"/>

                        <Button Command="{Binding SaveCommand}" IsEnabled="{Binding !IsBusy}" Classes="primary" HorizontalAlignment="Stretch" Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconPlus}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="Save Prescription" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Content="Reset" Command="{Binding ResetCommand}" Classes="secondary" HorizontalAlignment="Stretch" Padding="12"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right: Medicine Items -->
            <Border Grid.Column="1" Padding="24">
                <DockPanel>

                    <!-- Add Medicine Row -->
                    <Border DockPanel.Dock="Top" Background="#FFFFFF" Classes="card" Margin="0,0,0,24">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Add Medicine" Classes="panelTitle" FontSize="15"/>
                            <Grid ColumnDefinitions="*,100,*,Auto" HorizontalAlignment="Stretch">
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding AvailableMedicines}"
                                          SelectedItem="{Binding SelectedMedicineToAdd}"
                                          DisplayMemberBinding="{Binding Name}"
                                          Margin="0,0,8,0"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="Select medicine..."/>
                                <TextBox Grid.Column="1" Text="{Binding QuantityToAdd}"
                                         PlaceholderText="Qty" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="2" Text="{Binding DosageToAdd}"
                                         PlaceholderText="Dosage (e.g. 1 tab twice daily)" Margin="0,0,8,0"/>
                                <Button Grid.Column="3" Command="{Binding AddItemCommand}" Classes="primary">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <PathIcon Data="{StaticResource IconPlus}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock Text="Add" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Items Grid -->
                    <Border DockPanel.Dock="Top" Background="#FFFFFF" Classes="card">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Prescribed Medicines" Classes="panelTitle" FontSize="15" Margin="0,0,0,16"/>
                            <DataGrid ItemsSource="{Binding Items}"
                                      AutoGenerateColumns="False" IsReadOnly="False"
                                      CanUserSortColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Medicine"  Binding="{Binding MedicineName}" Width="*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Quantity"  Binding="{Binding Quantity}"     Width="100"/>
                                    <DataGridTextColumn Header="Dosage"    Binding="{Binding Dosage}"       Width="*"/>
                                    <DataGridTemplateColumn Header="Remove" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:PrescriptionItemRow" x:CompileBindings="True">
                                                <Button Command="{Binding $parent[UserControl].((vm:PrescriptionViewModel)DataContext).RemoveItemCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand"
                                                        Height="32" Width="32" HorizontalAlignment="Center">
                                                    <PathIcon Data="{StaticResource IconClose}" Width="12" Height="12" Foreground="#DC2626"/>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Patient Picker Overlay -->
        <Border Grid.Row="1" IsVisible="{Binding ShowPatientList}"
                Background="rgba(31, 41, 55, 0.5)" ZIndex="100">
            <Border Background="#FFFFFF" Classes="card"
                    Width="500" Height="420" VerticalAlignment="Center" HorizontalAlignment="Center">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                        <TextBlock Text="Select Patient" FontSize="18" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Command="{Binding ClosePatientListCommand}"
                                Background="Transparent" BorderThickness="0" Height="36" Width="36">
                            <PathIcon Data="{StaticResource IconClose}" Width="14" Height="14" Foreground="#6B7280"/>
                        </Button>
                    </DockPanel>
                    <TextBox DockPanel.Dock="Top" Text="{Binding PatientSearch}"
                             PlaceholderText="Search patient..." Margin="0,0,0,16"/>
                    <DataGrid ItemsSource="{Binding FilteredPatients}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="*"/>
                            <DataGridTextColumn Header="Age"     Binding="{Binding Age}"     Width="70"/>
                            <DataGridTextColumn Header="Contact" Binding="{Binding Contact}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button DockPanel.Dock="Bottom" Content="Select" Margin="0,16,0,0"
                            Command="{Binding SelectPatientCommand}"
                            Classes="primary" HorizontalAlignment="Left"/>
                </DockPanel>
            </Border>
        </Border>

        <Border Grid.Row="2" Background="#FFFFFF" Padding="24,8" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#6B7280" FontSize="12"/>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.action">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.action.primary">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.action.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
    </UserControl.Styles>
</UserControl>

