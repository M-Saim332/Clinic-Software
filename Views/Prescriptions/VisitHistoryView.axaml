<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Prescriptions"
             x:Class="ClinicSystem.UI.Views.Prescriptions.VisitHistoryView"
             x:DataType="vm:VisitHistoryViewModel"
             Background="#F8FAFC">
    <Panel>
        <Grid RowDefinitions="Auto,*">

            <!-- Header -->
            <Border Grid.Row="0" Background="#FFFFFF" Padding="24,16"
                    BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <PathIcon Data="{StaticResource IconAppointments}" Width="20" Height="20" Foreground="#2563EB"/>
                        <TextBlock Text="Visit History" FontSize="20" FontWeight="Bold"
                                   Foreground="#1F2937" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Command="{Binding ShowPatientsCommand}" Classes="action">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconFilter}" Width="14" Height="14" Foreground="#1F2937" VerticalAlignment="Center"/>
                                <TextBlock Text="Filter by Patient" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding LoadAllVisitsCommand}" Classes="action primary">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="Show All" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*,320">

                <!-- Prescriptions List -->
                <Border Grid.Column="0" Padding="24">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" FontSize="14" Foreground="#1F2937"
                                   FontWeight="SemiBold" Margin="0,0,0,12">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} visits{1}">
                                    <Binding Path="Prescriptions.Count"/>
                                    <Binding Path="SelectedPatient.Name" StringFormat=" — {0}" FallbackValue=""/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <DataGrid DockPanel.Dock="Top"
                                  ItemsSource="{Binding Prescriptions}"
                                  SelectedItem="{Binding SelectedPrescription}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date"      Binding="{Binding VisitDate, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="155"/>
                                <DataGridTextColumn Header="Patient"   Binding="{Binding PatientName}"                                   Width="*"/>
                                <DataGridTextColumn Header="Doctor"    Binding="{Binding DoctorName}"                                    Width="160"/>
                                <DataGridTextColumn Header="Diagnosis" Binding="{Binding Diagnosis}"                                     Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Prescription Items Detail -->
                <Border Grid.Column="1" Background="#FFFFFF" Padding="24"
                        BorderBrush="#E5E7EB" BorderThickness="1,0,0,0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Prescribed Medicines" Foreground="#1F2937"
                                   FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedPrescription.Diagnosis, FallbackValue='Select a visit to see details'}"
                                   Foreground="#6B7280" FontSize="13" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedPrescription.Notes}"
                                   Foreground="#6B7280" FontSize="12" TextWrapping="Wrap"/>
                        <Border Height="1" Background="#E5E7EB"/>
                        <DataGrid ItemsSource="{Binding PrescriptionItems}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Medicine" Binding="{Binding MedicineName}" Width="*"/>
                                <DataGridTextColumn Header="Qty"      Binding="{Binding Quantity}"     Width="50"/>
                                <DataGridTextColumn Header="Dosage"   Binding="{Binding Dosage}"       Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Patient Picker Overlay -->
        <Panel IsVisible="{Binding ShowPatientList}">
            <Border Background="rgba(31, 41, 55, 0.55)" ZIndex="100">
                <Border Background="#FFFFFF" Classes="card"
                        Width="480" Height="400"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                            <TextBlock Text="Filter by Patient" FontSize="18" FontWeight="Bold"
                                       Foreground="#1F2937" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Command="{Binding ClosePatientListCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Height="36" Width="36" Padding="0">
                                <PathIcon Data="{StaticResource IconClose}" Width="14" Height="14" Foreground="#6B7280"/>
                            </Button>
                        </DockPanel>
                        <TextBox DockPanel.Dock="Top" Text="{Binding PatientSearch}"
                                 PlaceholderText="Search patient..." Margin="0,0,0,16"/>
                        <DataGrid ItemsSource="{Binding FilteredPatients}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="*"/>
                                <DataGridTextColumn Header="Contact" Binding="{Binding Contact}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button DockPanel.Dock="Bottom" Margin="0,16,0,0"
                                Command="{Binding SelectPatientCommand}"
                                Classes="primary" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="View History" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>
            </Border>
        </Panel>
    </Panel>

    <UserControl.Styles>
        <Style Selector="Button.action">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.action.primary">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.action.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
    </UserControl.Styles>
</UserControl>
