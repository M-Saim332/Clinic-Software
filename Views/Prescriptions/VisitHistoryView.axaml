<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Prescriptions"
             x:Class="ClinicSystem.UI.Views.Prescriptions.VisitHistoryView"
             x:DataType="vm:VisitHistoryViewModel"
             Background="#0F1117">
    <Panel>
        <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Background="#1A1D27" Padding="20,14" BorderBrush="#2A2D3A" BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock Text="📅 Visit History" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10">
                        <Button Content="Filter by Patient" Command="{Binding ShowPatientsCommand}" Classes="action"/>
                        <Button Content="Show All" Command="{Binding LoadAllVisitsCommand}" Classes="action primary"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*,320">

                <!-- Prescriptions List -->
                <Border Grid.Column="0" Padding="20">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" FontSize="14" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,10">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} visits{1}">
                                    <Binding Path="Prescriptions.Count"/>
                                    <Binding Path="SelectedPatient.Name" StringFormat=" — {0}" FallbackValue=""/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <DataGrid DockPanel.Dock="Top"
                                  ItemsSource="{Binding Prescriptions}"
                                  SelectedItem="{Binding SelectedPrescription}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="#141720" RowBackground="#141720"
                                  Foreground="White" GridLinesVisibility="Horizontal"
                                  BorderBrush="#2A2D3A" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date"        Binding="{Binding VisitDate, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="140"/>
                                <DataGridTextColumn Header="Patient"     Binding="{Binding PatientName}" Width="*"/>
                                <DataGridTextColumn Header="Doctor"      Binding="{Binding DoctorName}"  Width="150"/>
                                <DataGridTextColumn Header="Diagnosis"   Binding="{Binding Diagnosis}"   Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Prescription Items Detail -->
                <Border Grid.Column="1" Background="#141720" Padding="20" BorderBrush="#2A2D3A" BorderThickness="1,0,0,0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Prescribed Medicines" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedPrescription.Diagnosis, FallbackValue='Select a visit to see details'}"
                                   Foreground="#888" FontSize="12" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedPrescription.Notes}" Foreground="#666" FontSize="12" TextWrapping="Wrap"/>
                        <Separator Background="#2A2D3A" Height="1"/>
                        <DataGrid ItemsSource="{Binding PrescriptionItems}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="#1A1D27" RowBackground="#1A1D27"
                                  Foreground="White" GridLinesVisibility="Horizontal"
                                  BorderBrush="#2A2D3A">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Medicine"  Binding="{Binding MedicineName}" Width="*"/>
                                <DataGridTextColumn Header="Qty"       Binding="{Binding Quantity}"     Width="50"/>
                                <DataGridTextColumn Header="Dosage"    Binding="{Binding Dosage}"       Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Patient Picker Overlay -->
        <Panel IsVisible="{Binding ShowPatientList}">
            <Border Background="#CC000000" ZIndex="100">
                <Border Background="#1A1D27" CornerRadius="12" Padding="24"
                        Width="450" Height="380" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="Filter by Patient" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <Button DockPanel.Dock="Right" Content="✕" Command="{Binding ClosePatientListCommand}" Background="Transparent" Foreground="#888" FontSize="16"/>
                        </DockPanel>
                        <TextBox DockPanel.Dock="Top" Text="{Binding PatientSearch}" Watermark="Search..." Margin="0,0,0,10"
                                 Background="#252837" BorderBrush="#333" Foreground="White" CornerRadius="6" Padding="10,8"/>
                        <DataGrid ItemsSource="{Binding FilteredPatients}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="#141720" RowBackground="#141720"
                                  Foreground="White" GridLinesVisibility="Horizontal"
                                  BorderBrush="#2A2D3A">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="*"/>
                                <DataGridTextColumn Header="Contact" Binding="{Binding Contact}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button DockPanel.Dock="Bottom" Content="View History" Margin="0,10,0,0"
                                Command="{Binding SelectPatientCommand}"
                                Background="#0097A7" Foreground="White" CornerRadius="6" Padding="14,8"/>
                    </DockPanel>
                </Border>
            </Border>
        </Panel>
    </Panel>

    <UserControl.Styles>
        <Style Selector="Button.action">
            <Setter Property="Background" Value="#252837"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,7"/>
        </Style>
        <Style Selector="Button.action.primary">
            <Setter Property="Background" Value="#0097A7"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>
</UserControl>
