<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ClinicSystem.UI.ViewModels"
        xmlns:userviews="using:ClinicSystem.UI.Views.Users"
        xmlns:comp="using:ClinicSystem.UI.Views.Components"
        x:Class="ClinicSystem.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel" x:CompileBindings="True"
        Title="Clinic Management System"
        Width="1280" Height="780"
        MinWidth="1000" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        Icon="avares://ClinicSystem.UI/Assets/hospital_logo.png">

  <Grid ColumnDefinitions="Auto,*">
    <comp:SidebarControl Grid.Column="0"/>


    <!-- ═══════════════════════════════════════════════════════
         RIGHT: TOP BAR + CONTENT
         ═══════════════════════════════════════════════════════ -->
    <Grid Grid.Column="1" RowDefinitions="60,Auto,*,Auto">

      <!-- Top bar -->
      <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
              BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="24,0">
        <DockPanel VerticalAlignment="Center">
          <!-- Left: Clinic name chip and Page Title -->
          <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
              <Border Background="{DynamicResource BrushBlue50}" CornerRadius="{DynamicResource CornerRadiusPill}" Padding="12,6">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                      <PathIcon Data="{StaticResource IconClinic}" Width="12" Height="12" Foreground="{DynamicResource BrushPrimaryBlue}"/>
                      <TextBlock Text="Care &amp; Cure Clinic" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimaryBlue}"/>
                  </StackPanel>
              </Border>
              <TextBlock Text="{Binding PageTitle}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushInk900}" FontFamily="{DynamicResource FontLexend}" VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Right: User Avatar, Name, Role and Options -->
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center" HorizontalAlignment="Right">
            <TextBlock Text="{Binding TodayDate}" Foreground="{DynamicResource BrushInk600}" FontSize="13" VerticalAlignment="Center"/>
            
            <Border Width="1" Background="{DynamicResource BrushLine}" Height="20" VerticalAlignment="Center"/>
            
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource BrushPrimaryBlue}">
                    <TextBlock Text="Dr" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center" Spacing="0">
                    <TextBlock Text="{Binding CurrentUserName}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrushInk900}"/>
                    <TextBlock Text="{Binding CurrentUserRole}" FontSize="11" Foreground="{DynamicResource BrushInk600}"/>
                </StackPanel>
            </StackPanel>

            <!-- Change Password button -->
            <Button Command="{Binding OpenChangePasswordDialogCommand}"
                    IsVisible="{Binding IsAdmin}"
                    Background="#F3F4F6" BorderThickness="0"
                    CornerRadius="8" Padding="10,6"
                    ToolTip.Tip="Change Password">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource IconUsers}" Width="13" Height="13" Foreground="#4B5563" VerticalAlignment="Center"/>
                    <TextBlock Text="Password" FontSize="12" Foreground="#4B5563" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource BrushTeal}" VerticalAlignment="Center"
                    ToolTip.Tip="Database connected"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- Alert Banner -->
      <Border Grid.Row="1" Background="{DynamicResource BrushAmber50}" BorderBrush="{DynamicResource BrushAmber}" BorderThickness="0,0,0,1" Padding="24,10" IsVisible="{Binding ShowAlert}">
        <DockPanel>
          <PathIcon Data="{StaticResource IconAlert}" Width="16" Height="16" Foreground="{DynamicResource BrushAmber}" VerticalAlignment="Center" Margin="0,0,10,0"/>
          <Button DockPanel.Dock="Right" Command="{Binding CloseAlertCommand}" Background="Transparent" BorderThickness="0" Padding="4" Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center">
            <PathIcon Data="{StaticResource IconClose}" Width="10" Height="10" Foreground="{DynamicResource BrushAmber}"/>
          </Button>
          <TextBlock Text="{Binding AlertMessage}" Foreground="{DynamicResource BrushAmber}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
        </DockPanel>
      </Border>


      <!-- Content area -->
      <Panel Grid.Row="2" Background="#F8FAFC">
        <ContentControl Content="{Binding CurrentPageViewModel}" Background="#F8FAFC"/>

        <!-- Loading overlay -->
        <Border IsVisible="{Binding IsLoading}"
                Background="rgba(248, 250, 252, 0.85)">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="18">
            <Border Width="64" Height="64" CornerRadius="32"
                    Background="White" BorderBrush="#2563EB" BorderThickness="1"
                    BoxShadow="0 4 6 -1 rgba(0,0,0,0.05)">
              <PathIcon Data="{StaticResource IconClinic}" Width="24" Height="24"
                        Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                         Foreground="#2563EB" Background="#E5E7EB"/>
            <TextBlock Text="Loading data…" Foreground="#4B5563" FontSize="13"
                       HorizontalAlignment="Center" FontWeight="Medium"/>
          </StackPanel>
        </Border>

        <!-- Change Password overlay wrapper -->
        <Panel IsVisible="{Binding ShowChangePassword}" ZIndex="200">
            <userviews:ChangePasswordView DataContext="{Binding ChangePasswordVM}"/>
        </Panel>
      </Panel>

      <!-- Status bar -->
      <Border Grid.Row="3" Background="#F8FAFC" Padding="24,6"
              BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
        <TextBlock Text="{Binding StatusText}" Foreground="#6B7280" FontSize="12"/>
      </Border>


    </Grid>
  </Grid>
</Window>

