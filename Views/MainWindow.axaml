<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ClinicSystem.UI.ViewModels"
        x:Class="ClinicSystem.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Clinic Management System"
        Width="1280" Height="780"
        MinWidth="1000" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        Icon="avares://ClinicSystem.UI/Assets/hospital_logo.png">

  <Grid ColumnDefinitions="240,*">

    <!-- ═══════════════════════════════════════════════════════
         LEFT SIDEBAR
         ═══════════════════════════════════════════════════════ -->
    <Border Grid.Column="0" Background="#FFFFFF"
            BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
      <DockPanel>

        <!-- Logo / Brand -->
        <Border DockPanel.Dock="Top" Padding="20,24"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF">
              <PathIcon Data="{StaticResource IconClinic}" Width="18" Height="18"
                        Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center" Spacing="1">
              <TextBlock Text="Clinic" FontSize="15" FontWeight="Bold" Foreground="#1F2937"/>
              <TextBlock Text="Management" FontSize="11" Foreground="#6B7280"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Logout at bottom -->
        <Border DockPanel.Dock="Bottom" Padding="16">
          <Button Command="{Binding LogoutCommand}" HorizontalAlignment="Stretch"
                  Classes="navbtn">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <PathIcon Data="{StaticResource IconLogout}" Width="16" Height="16" Foreground="#DC2626" VerticalAlignment="Center"/>
              <TextBlock Text="Logout" Foreground="#DC2626" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </Border>

        <!-- Logged-in user chip -->
        <Border DockPanel.Dock="Bottom" Padding="20,16"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
          <StackPanel Spacing="3">
            <TextBlock Text="{Binding CurrentUserName}" FontSize="13"
                       FontWeight="SemiBold" Foreground="#1F2937" TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{Binding CurrentUserRole}" FontSize="11" Foreground="#6B7280"/>
          </StackPanel>
        </Border>

        <!-- Navigation -->
        <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="4" Margin="12,16">

            <!-- Primary -->
            <TextBlock Text="MAIN" FontSize="10" FontWeight="Bold"
                       Foreground="#9CA3AF" Margin="8,4,0,8" LetterSpacing="1.5"/>

            <Button Command="{Binding ShowDashboardCommand}"
                    Classes="navbtn" Classes.active="{Binding IsDashboardActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding ShowPatientsCommand}"
                    Classes="navbtn" Classes.active="{Binding IsPatientsActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconPatients}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Patients" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding ShowCompaniesCommand}"
                    Classes="navbtn" Classes.active="{Binding IsCompaniesActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconCompanies}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Companies" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding ShowSuppliersCommand}"
                    Classes="navbtn" Classes.active="{Binding IsSuppliersActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconSuppliers}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Suppliers" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding ShowProductsCommand}"
                    Classes="navbtn" Classes.active="{Binding IsProductsActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconProducts}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Products" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding ShowMedicinesCommand}"
                    Classes="navbtn" Classes.active="{Binding IsMedicinesActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconMedicines}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Medicines" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <!-- Management Section -->
            <Border Height="1" Background="#E5E7EB" Margin="8,12"/>
            <TextBlock Text="MANAGEMENT" FontSize="10" FontWeight="Bold"
                       Foreground="#9CA3AF" Margin="8,0,0,8" LetterSpacing="1.5"/>

            <Button Command="{Binding ShowPurchasesCommand}"
                    Classes="navbtn" Classes.active="{Binding IsPurchasesActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconPurchases}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Purchase" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding ShowSalesCommand}"
                    Classes="navbtn" Classes.active="{Binding IsSalesActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconSales}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Sales" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding ShowInventoryCommand}"
                    Classes="navbtn" Classes.active="{Binding IsInventoryActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconInventory}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Inventory" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding ShowAppointmentsCommand}"
                    Classes="navbtn" Classes.active="{Binding IsAppointmentsActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconAppointments}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Appointments" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding ShowPrescriptionsCommand}"
                    Classes="navbtn" Classes.active="{Binding IsPrescriptionsActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconVisit}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="New Visit" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <!-- System Section -->
            <Border Height="1" Background="#E5E7EB" Margin="8,12"/>
            <TextBlock Text="SYSTEM" FontSize="10" FontWeight="Bold"
                       Foreground="#9CA3AF" Margin="8,0,0,8" LetterSpacing="1.5"/>

            <Button Command="{Binding ShowUsersCommand}"
                    Classes="navbtn" Classes.active="{Binding IsUsersActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconUsers}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Users" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding ShowReportsCommand}"
                    Classes="navbtn" Classes.active="{Binding IsReportsActive}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconReports}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Reports" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding BackupCommand}"
                    Classes="navbtn">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconBackup}" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Backup" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- ═══════════════════════════════════════════════════════
         RIGHT: TOP BAR + CONTENT
         ═══════════════════════════════════════════════════════ -->
    <Grid Grid.Column="1" RowDefinitions="60,*,Auto">

      <!-- Top bar -->
      <Border Grid.Row="0" Background="#FFFFFF"
              BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="24,0">
        <DockPanel VerticalAlignment="Center">
          <TextBlock Text="{Binding PageTitle}" FontSize="18" FontWeight="Bold"
                     Foreground="#1F2937" VerticalAlignment="Center"/>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                      Spacing="16" VerticalAlignment="Center">
            <TextBlock Text="{Binding TodayDate}" Foreground="#9CA3AF" FontSize="13" VerticalAlignment="Center"/>
            <Border Width="8" Height="8" CornerRadius="4" Background="#16A34A" VerticalAlignment="Center"
                    ToolTip.Tip="Database connected"/>
            <TextBlock Text="{Binding StatusText}" Foreground="#6B7280" FontSize="12"
                       VerticalAlignment="Center" MaxWidth="300" TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- Content area -->
      <Panel Grid.Row="1" Background="#F8FAFC">
        <ContentControl Content="{Binding CurrentPageViewModel}" Background="#F8FAFC"/>

        <!-- Loading overlay -->
        <Border IsVisible="{Binding IsLoading}"
                Background="rgba(248, 250, 252, 0.85)">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="18">
            <Border Width="64" Height="64" CornerRadius="32"
                    Background="White" BorderBrush="#2563EB" BorderThickness="1"
                    BoxShadow="0 4 6 -1 rgba(0,0,0,0.05)">
              <PathIcon Data="{StaticResource IconClinic}" Width="24" Height="24"
                        Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                         Foreground="#2563EB" Background="#E5E7EB"/>
            <TextBlock Text="Loading data…" Foreground="#4B5563" FontSize="13"
                       HorizontalAlignment="Center" FontWeight="Medium"/>
          </StackPanel>
        </Border>
      </Panel>

      <!-- Status bar -->
      <Border Grid.Row="2" Background="#F8FAFC" Padding="24,6"
              BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
        <TextBlock Text="{Binding StatusText}" Foreground="#6B7280" FontSize="12"/>
      </Border>

    </Grid>
  </Grid>
</Window>
