<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Suppliers"
             x:Class="ClinicSystem.UI.Views.Suppliers.SupplierRegistryView"
             x:DataType="vm:SupplierRegistryViewModel"
             Background="#F5F7FA">

    <Grid ColumnDefinitions="300,*" Margin="20">
        <!-- Form Side -->
        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20"
                BorderBrush="#E5E7EB" BorderThickness="1"
                BoxShadow="0 1 3 0 #1A000000">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Supplier Details" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,20"/>
                
                <StackPanel DockPanel.Dock="Bottom" Spacing="10" Margin="0,20,0,0">
                    <Grid ColumnDefinitions="*,*">
                        <Button Grid.Column="0" Content="Save" Command="{Binding SaveCommand}"
                                IsEnabled="{Binding SaveCancelEnabled}"
                                Background="#0EA5E9" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,5,0" CornerRadius="6"/>
                        <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}"
                                IsEnabled="{Binding SaveCancelEnabled}"
                                Background="#F3F4F6" Foreground="#4B5563" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5,0,0,0" CornerRadius="6"/>
                    </Grid>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Spacing="15" IsEnabled="{Binding SaveCancelEnabled}">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Name" Foreground="#374151" FontSize="12" FontWeight="Medium"/>
                        <TextBox Text="{Binding Name}" CornerRadius="6" BorderBrush="#D1D5DB"/>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="Phone" Foreground="#374151" FontSize="12" FontWeight="Medium"/>
                        <TextBox Text="{Binding Phone}" CornerRadius="6" BorderBrush="#D1D5DB"/>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="Email" Foreground="#374151" FontSize="12" FontWeight="Medium"/>
                        <TextBox Text="{Binding Email}" CornerRadius="6" BorderBrush="#D1D5DB"/>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="Address" Foreground="#374151" FontSize="12" FontWeight="Medium"/>
                        <TextBox Text="{Binding Address}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" CornerRadius="6" BorderBrush="#D1D5DB"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Grid Side -->
        <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="20,0,0,0"
                BorderBrush="#E5E7EB" BorderThickness="1"
                BoxShadow="0 1 3 0 #1A000000">
            <DockPanel>
                <!-- Toolbar -->
                <Border DockPanel.Dock="Top" Padding="15" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="➕ New" Command="{Binding NewCommand}"
                                IsEnabled="{Binding MutationEnabled}"
                                Background="#10B981" Foreground="White" CornerRadius="6" Padding="15,6"/>
                        <Button Content="✏️ Edit" Command="{Binding EditCommand}"
                                IsEnabled="{Binding MutationEnabled}"
                                Background="#F59E0B" Foreground="White" CornerRadius="6" Padding="15,6"/>
                        <Button Content="🗑️ Delete" Command="{Binding DeleteCommand}"
                                IsEnabled="{Binding MutationEnabled}"
                                Background="#EF4444" Foreground="White" CornerRadius="6" Padding="15,6"/>
                    </StackPanel>
                </Border>
                
                <DataGrid ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0"
                          RowBackground="Transparent"
                          Foreground="#374151">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding SupplierID}" Width="60"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="150"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                        <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
