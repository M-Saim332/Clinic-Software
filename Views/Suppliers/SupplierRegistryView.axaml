<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Suppliers"
             x:Class="ClinicSystem.UI.Views.Suppliers.SupplierRegistryView"
             x:DataType="vm:SupplierRegistryViewModel"
             Background="#F8FAFC">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="24,16"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource IconSuppliers}" Width="20" Height="20" Foreground="#2563EB"/>
                    <TextBlock Text="Supplier Registry" FontSize="20" FontWeight="Bold"
                               Foreground="#1F2937" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}"
                           Foreground="#2563EB" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" ColumnDefinitions="340,*">

            <!-- Left: Form -->
            <Border Grid.Column="0" Background="#FFFFFF" Padding="24"
                    BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
                <DockPanel>

                    <!-- Bottom: Action buttons + status -->
                    <StackPanel DockPanel.Dock="Bottom" Spacing="12" Margin="0,20,0,0">
                        <Grid ColumnDefinitions="*,*">
                            <Button Grid.Column="0" Content="Save" Command="{Binding SaveCommand}"
                                    IsEnabled="{Binding SaveCancelEnabled}"
                                    Classes="primary" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" Margin="0,0,6,0"/>
                            <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}"
                                    IsEnabled="{Binding SaveCancelEnabled}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#DC2626" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Form fields -->
                    <StackPanel Spacing="16" IsEnabled="{Binding SaveCancelEnabled}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Name *" Classes="label"/>
                            <TextBox Text="{Binding Name}" PlaceholderText="Supplier name"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Phone" Classes="label"/>
                            <TextBox Text="{Binding Phone}" PlaceholderText="Contact number"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Email" Classes="label"/>
                            <TextBox Text="{Binding Email}" PlaceholderText="Email address"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Address" Classes="label"/>
                            <TextBox Text="{Binding Address}" Height="80" AcceptsReturn="True"
                                     TextWrapping="Wrap" PlaceholderText="Full address"
                                     VerticalContentAlignment="Top" Padding="12,10"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Right: Grid with toolbar -->
            <Border Grid.Column="1" Padding="24">
                <DockPanel>
                    <!-- Toolbar -->
                    <Border DockPanel.Dock="Top" Padding="0,0,0,16"
                            BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding NewCommand}"
                                    IsEnabled="{Binding MutationEnabled}" Classes="primary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconPlus}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="New" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding EditCommand}"
                                    IsEnabled="{Binding MutationEnabled}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconEdit}" Width="14" Height="14" Foreground="#1F2937" VerticalAlignment="Center"/>
                                    <TextBlock Text="Edit" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DeleteCommand}"
                                    IsEnabled="{Binding MutationEnabled}" Classes="danger" Focusable="False">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconClose}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="Delete" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <DataGrid ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"      Binding="{Binding SupplierID}" Width="60"/>
                            <DataGridTextColumn Header="Name"    Binding="{Binding Name}"       Width="*"/>
                            <DataGridTextColumn Header="Phone"   Binding="{Binding Phone}"      Width="150"/>
                            <DataGridTextColumn Header="Email"   Binding="{Binding Email}"      Width="200"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}"    Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#FFFFFF" Padding="24,8"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#6B7280" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
