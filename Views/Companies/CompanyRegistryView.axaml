<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Companies"
             x:Class="ClinicSystem.UI.Views.Companies.CompanyRegistryView"
             x:DataType="vm:CompanyRegistryViewModel"
             Background="#F8FAFC">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Header -->
    <Border Grid.Row="0" Background="#FFFFFF" Padding="24,16"
            BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
      <DockPanel>
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <PathIcon Data="{StaticResource IconCompanies}" Width="20" Height="20" Foreground="#2563EB"/>
          <TextBlock Text="Company Registry" FontSize="20" FontWeight="Bold"
                     Foreground="#1F2937" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}"
                   Foreground="#2563EB" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
      </DockPanel>
    </Border>

    <!-- Main content -->
    <Grid Grid.Row="1" ColumnDefinitions="340,*">

      <!-- Left: Form -->
      <Border Grid.Column="0" Background="#FFFFFF" Padding="24"
              BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
        <ScrollViewer>
          <StackPanel Spacing="16">

            <!-- Actions -->
            <TextBlock Text="ACTIONS" Classes="label" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold" LetterSpacing="1.5" Margin="0,0,0,4"/>
            <WrapPanel Margin="0,0,0,8">
              <Button Content="New"    Command="{Binding NewCommand}"    IsEnabled="{Binding MutationEnabled}" Classes="action" Margin="0,0,6,6"/>
              <Button Content="Edit"   Command="{Binding EditCommand}"   IsEnabled="{Binding MutationEnabled}" Classes="action" Margin="0,0,6,6"/>
              <Button Content="Delete" Command="{Binding DeleteCommand}" IsEnabled="{Binding MutationEnabled}" Classes="action danger" Margin="0,0,6,6"/>
              <Button Content="Save"   Command="{Binding SaveCommand}"   IsEnabled="{Binding SaveCancelEnabled}" Classes="action primary" Margin="0,0,6,6"/>
              <Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding SaveCancelEnabled}" Classes="action" Margin="0,0,6,6"/>
            </WrapPanel>

            <Separator Margin="0,4"/>

            <!-- Form Fields -->
            <StackPanel Spacing="14">
              <StackPanel Spacing="2">
                <TextBlock Text="Company Name *" Classes="label"/>
                <TextBox Text="{Binding Name}" IsEnabled="{Binding SaveCancelEnabled}"
                         PlaceholderText="Company name"/>
              </StackPanel>
              <StackPanel Spacing="2">
                <TextBlock Text="Phone" Classes="label"/>
                <TextBox Text="{Binding Phone}" IsEnabled="{Binding SaveCancelEnabled}"
                         PlaceholderText="Contact number"/>
              </StackPanel>
              <StackPanel Spacing="2">
                <TextBlock Text="Email" Classes="label"/>
                <TextBox Text="{Binding Email}" IsEnabled="{Binding SaveCancelEnabled}"
                         PlaceholderText="Email address"/>
              </StackPanel>
              <StackPanel Spacing="2">
                <TextBlock Text="Address" Classes="label"/>
                <TextBox Text="{Binding Address}" IsEnabled="{Binding SaveCancelEnabled}"
                         PlaceholderText="Full address" Height="80"
                         AcceptsReturn="True" VerticalContentAlignment="Top" Padding="12,10"/>
              </StackPanel>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Right: Company list -->
      <Border Grid.Column="1" Padding="24">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="All Companies" Foreground="#1F2937"
                     FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>
          <DataGrid ItemsSource="{Binding Companies}"
                    SelectedItem="{Binding SelectedCompany}"
                    AutoGenerateColumns="False" IsReadOnly="True"
                    SelectionMode="Single">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="*"/>
              <DataGridTextColumn Header="Phone"   Binding="{Binding Phone}"   Width="140"/>
              <DataGridTextColumn Header="Email"   Binding="{Binding Email}"   Width="200"/>
              <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="2" Background="#FFFFFF" Padding="24,8"
            BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#6B7280" FontSize="12"/>
    </Border>
  </Grid>

  <UserControl.Styles>
    <Style Selector="Button.action">
      <Setter Property="Height" Value="36"/>
      <Setter Property="Padding" Value="14,0"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style Selector="Button.action.primary">
      <Setter Property="Background" Value="#2563EB"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.action.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1D4ED8"/>
      <Setter Property="TextElement.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.action.danger">
      <Setter Property="Background" Value="#DC2626"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.action.danger:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#B91C1C"/>
      <Setter Property="TextElement.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
  </UserControl.Styles>
</UserControl>
