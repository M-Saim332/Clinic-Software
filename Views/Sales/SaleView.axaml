<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Sales"
             xmlns:models="using:ClinicSystem.Core.Models"
             xmlns:comp="using:ClinicSystem.UI.Views.Components"
             x:Class="ClinicSystem.UI.Views.Sales.SaleView"
             x:DataType="vm:SaleViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <Grid>
        <!-- ============================================================ -->
        <!-- 1. LIST/GRID VIEW (ShowList is true)                         -->
        <!-- ============================================================ -->
        <Grid IsVisible="{Binding ShowList}" RowDefinitions="Auto,Auto,*">
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushBlue50}">
                            <materialIcons:MaterialIcon Kind="Receipt" Width="20" Height="20"
                                      Foreground="{DynamicResource BrushPrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="Sales &amp; Billing" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Post invoices and manage patient bills"
                                       FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button  Command="{Binding NewCommand}"
                            Classes="btn-primary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Plus" Width="18" Height="18"/>
        <TextBlock Text="New Sale" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                </DockPanel>
            </Border>

            <!-- Summary Cards Row -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Margin="28,16,28,4">
                <comp:SummaryCardControl Grid.Column="0" Margin="0,0,12,0"
                    Title="Total Bills Posted"
                    Value="{Binding TotalInvoicesCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushTeal}"/>
                <comp:SummaryCardControl Grid.Column="1" Margin="0,0,12,0"
                    Title="Total Revenue"
                    Value="{Binding TotalRevenue, StringFormat='Rs. {0:N2}'}"
                    BorderColor="{DynamicResource BrushPrimaryBlue}"/>
                <comp:SummaryCardControl Grid.Column="2" Margin="0,0,12,0"
                    Title="Revenue Today"
                    Value="{Binding RevenueToday, StringFormat='Rs. {0:N2}'}"
                    BorderColor="{DynamicResource BrushAmber}"/>
                <comp:SummaryCardControl Grid.Column="3"
                    Title="Avg Invoice Value"
                    Value="{Binding AvgSaleValue, StringFormat='Rs. {0:N2}'}"
                    BorderColor="{DynamicResource BrushRose}"/>
            </Grid>

            <!-- Data Panel -->
            <Grid Grid.Row="2" Margin="28,12,28,24">
                <comp:DataTableShellControl Title="Billing History" RecordCount="{Binding Sales.Count}">
                    <comp:DataTableShellControl.FilterToolbar>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button  Command="{Binding ViewDetailsCommand}"
                                    IsEnabled="{Binding SelectedSale, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Classes="btn-secondary">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Eye" Width="18" Height="18"/>
        <TextBlock Text="View Details" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                            <Button  Command="{Binding PrintInvoiceCommand}"
                                    IsEnabled="{Binding SelectedSale, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Classes="btn-secondary">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Printer" Width="18" Height="18"/>
        <TextBlock Text="Print Invoice" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                        </StackPanel>
                    </comp:DataTableShellControl.FilterToolbar>
                    <comp:DataTableShellControl.TableContent>
                        <DataGrid ItemsSource="{Binding Sales}" SelectedItem="{Binding SelectedSale}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" Background="Transparent" BorderThickness="0"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="INVOICE NO." Binding="{Binding InvoiceNumber}" Width="150"/>
                                <DataGridTextColumn Header="DATE" Binding="{Binding SaleDate, StringFormat=\{0:dd MMM yyyy\}}" Width="130"/>
                                <DataGridTextColumn Header="PATIENT" Binding="{Binding PatientName}" Width="*"/>
                                <DataGridTextColumn Header="METHOD" Binding="{Binding PaymentMethod}" Width="110"/>
                                <DataGridTextColumn Header="GRAND TOTAL" Binding="{Binding GrandTotal, StringFormat='Rs. {0:N2}'}" Width="160"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </comp:DataTableShellControl.TableContent>
                </comp:DataTableShellControl>
            </Grid>
        </Grid>

        <!-- ============================================================ -->
        <!-- 2. FORM / DETAIL VIEW (ShowForm is true)                     -->
        <!-- ============================================================ -->
        <Grid IsVisible="{Binding ShowForm}" RowDefinitions="Auto,*,Auto">
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushBlue50}">
                            <materialIcons:MaterialIcon Kind="Receipt" Width="20" Height="20"
                                      Foreground="{DynamicResource BrushPrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="{Binding Mode, StringFormat='{}{0} Sale Invoice'}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}" FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Enter details and items for this sale" FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button  Command="{Binding CancelCommand}"
                            Classes="btn-secondary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="ArrowLeft" Width="18" Height="18"/>
        <TextBlock Text="Back" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                </DockPanel>
            </Border>

            <!-- Body (Full-width view for inputs & line items) -->
            <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="28,24">
                
                <!-- Top panel: Inputs & Add Product -->
                <Grid Grid.Row="0" ColumnDefinitions="*,*" Margin="0,0,0,24">
                    
                    <!-- Left: Invoice Header -->
                    <Border Grid.Column="0" Background="{DynamicResource BrushCardBackground}"
                            BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                            CornerRadius="{DynamicResource CornerRadiusCard}" Padding="24" Margin="0,0,12,0">
                        <StackPanel Spacing="16">
                            <TextBlock Text="INVOICE HEADER" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk400}" LetterSpacing="1.5"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <Separator/>
                            
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,8,12">
                                    <TextBlock Text="Invoice Number" Classes="label"/>
                                    <TextBox Text="{Binding InvoiceNumber}" IsReadOnly="True" Background="{DynamicResource BrushBackground}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6" Margin="8,0,0,12">
                                    <TextBlock Text="Date" Classes="label"/>
                                    <DatePicker SelectedDate="{Binding SaleDate}" IsEnabled="{Binding IsNewSale}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>
                            
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,8,12">
                                    <TextBlock Text="Patient (Optional)" Classes="label"/>
                                    <ComboBox ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatient}"
                                              IsEnabled="{Binding IsNewSale}" HorizontalAlignment="Stretch"
                                              PlaceholderText="Select Patient">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:Patient">
                                                <TextBlock Text="{Binding Name}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6" Margin="8,0,0,12">
                                    <TextBlock Text="Walk-in Name" Classes="label" IsVisible="{Binding IsWalkIn}"/>
                                    <TextBox Text="{Binding WalkInPatientName}"
                                             PlaceholderText="e.g. John"
                                             IsVisible="{Binding IsWalkIn}"
                                             IsEnabled="{Binding IsNewSale}"/>
                                </StackPanel>
                            </Grid>
                            
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,8,0">
                                    <TextBlock Text="Consultation Fee" Classes="label"/>
                                    <NumericUpDown Value="{Binding ConsultationFee}" Minimum="0" FormatString="N2" IsEnabled="{Binding IsNewSale}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6" Margin="8,0,0,0">
                                    <TextBlock Text="Payment Method" Classes="label"/>
                                    <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding PaymentMethod}"
                                              IsEnabled="{Binding IsNewSale}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Right: Add Product -->
                    <Border Grid.Column="1" Background="{DynamicResource BrushCardBackground}"
                            BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                            CornerRadius="{DynamicResource CornerRadiusCard}" Padding="24" Margin="12,0,0,0">
                        <StackPanel Spacing="16">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="ADD PRODUCT" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource BrushInk400}" LetterSpacing="1.5"
                                           FontFamily="{DynamicResource FontLexend}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding GrandTotal, StringFormat='Grand Total: Rs. {0:N2}'}"
                                           FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushPrimaryBlue}" 
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </DockPanel>
                            <Separator/>
                            
                            <!-- If IsNewSale, show product adding tools -->
                            <StackPanel Spacing="12" IsVisible="{Binding IsNewSale}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,12,0">
                                        <TextBlock Text="Search Product" Classes="label"/>
                                        <TextBox Text="{Binding ProductSearchTerm}"
                                                 PlaceholderText="Type name, generic..."/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Bottom">
                                        <Button  Command="{Binding AddLineItemCommand}" Classes="btn-secondary" Width="80">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Plus" Width="18" Height="18"/>
        <TextBlock Text="Add" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                                    </StackPanel>
                                </Grid>
                                
                                <Border BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                                        CornerRadius="{DynamicResource CornerRadiusInput}" Height="120">
                                    <ListBox ItemsSource="{Binding FilteredProducts}"
                                             SelectedItem="{Binding SelectedProduct}"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:Product">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Grid.Column="0" Spacing="2">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                                        <TextBlock Text="{Binding GenericName}" FontSize="11" Foreground="{DynamicResource BrushInk500}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="2">
                                                        <TextBlock Text="{Binding SellingPrice, StringFormat='Rs. {0:N2}'}"
                                                                   FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource BrushPrimaryBlue}" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding Stock, StringFormat='Stock: {0}'}"
                                                                   FontSize="11" Foreground="{DynamicResource BrushInk500}" HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                                
                                <Grid ColumnDefinitions="*,*,*">
                                    <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,6,0">
                                        <TextBlock Text="Qty" Classes="label"/>
                                        <NumericUpDown Value="{Binding Quantity}" Minimum="1" FormatString="N0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="6" Margin="6,0,6,0">
                                        <TextBlock Text="Price" Classes="label"/>
                                        <NumericUpDown Value="{Binding ProductPrice}" FormatString="N2" Minimum="0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="6" Margin="6,0,0,0">
                                        <TextBlock Text="Discount" Classes="label"/>
                                        <NumericUpDown Value="{Binding Discount}" FormatString="N2" Minimum="0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- If not IsNewSale, show grand total big -->
                            <StackPanel Spacing="12" IsVisible="{Binding !IsNewSale}" VerticalAlignment="Center" Margin="0,32,0,0">
                                <TextBlock Text="Invoice Posted" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource BrushInk400}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Cannot add products to a posted invoice." FontSize="13" Foreground="{DynamicResource BrushInk500}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Bottom panel: Invoice Line items list -->
                <Grid Grid.Row="1">
                    <comp:DataTableShellControl Title="Invoice Items" RecordCount="{Binding LineItems.Count}">
                        <comp:DataTableShellControl.TableContent>
                            <DataGrid ItemsSource="{Binding LineItems}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" Background="Transparent" BorderThickness="0"
                                      GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="PRODUCT" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="QTY" Binding="{Binding Quantity}" Width="80"/>
                                    <DataGridTextColumn Header="PRICE" Binding="{Binding ProductPrice, StringFormat='Rs. {0:N2}'}" Width="110"/>
                                    <DataGridTextColumn Header="DISCOUNT" Binding="{Binding Discount, StringFormat='Rs. {0:N2}'}" Width="110"/>
                                    <DataGridTextColumn Header="TAX" Binding="{Binding Tax, StringFormat='Rs. {0:N2}'}" Width="100"/>
                                    <DataGridTextColumn Header="LINE TOTAL" Binding="{Binding LineNetTotal, StringFormat='Rs. {0:N2}'}" Width="130"/>
                                    <DataGridTemplateColumn Width="60" IsVisible="{Binding $parent[UserControl].((vm:SaleViewModel)DataContext).IsNewSale}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding $parent[UserControl].((vm:SaleViewModel)DataContext).RemoveLineItemCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0"
                                                        Padding="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <materialIcons:MaterialIcon Kind="Close" Width="12" Height="12" Foreground="{DynamicResource BrushRose}"/>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </comp:DataTableShellControl.TableContent>
                    </comp:DataTableShellControl>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,1,0,0" Padding="28,16">
                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushRose}"
                               VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" VerticalAlignment="Center" IsVisible="{Binding SaveCancelEnabled}">
                        <Button  Command="{Binding CancelCommand}" Classes="btn-ghost">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Close" Width="18" Height="18"/>
        <TextBlock Text="Cancel" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                        <Button  Command="{Binding PostSaleCommand}" Classes="btn-primary">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Send" Width="18" Height="18"/>
        <TextBlock Text="Post Invoice" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
        
        <!-- ============================================================ -->
        <!-- 3. INVOICE PRINT VIEW                                        -->
        <!-- ============================================================ -->
        <ContentControl IsVisible="{Binding ShowInvoicePrint}" Content="{Binding InvoiceVM}"/>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource BrushPrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk600}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="{DynamicResource BrushRose}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#BE123C"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.40"/>
        </Style>
    </UserControl.Styles>
</UserControl>
