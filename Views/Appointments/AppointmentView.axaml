<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Appointments"
             x:Class="ClinicSystem.UI.Views.Appointments.AppointmentView"
             x:DataType="vm:AppointmentViewModel" x:CompileBindings="True"
             Background="#F8FAFC">

    <Grid ColumnDefinitions="360,*" Margin="24">
        <!-- Form Side -->
        <Border Grid.Column="0" Classes="card">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Book Appointment" Classes="sectionTitle" Margin="0,0,0,20"/>
                
                <StackPanel DockPanel.Dock="Bottom" Spacing="12" Margin="0,20,0,0">
                    <Grid ColumnDefinitions="*,*">
                        <Button Grid.Column="0" Content="Save" Command="{Binding SaveCommand}"
                                IsEnabled="{Binding SaveCancelEnabled}" Classes="primary" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}"
                                IsEnabled="{Binding SaveCancelEnabled}" Classes="secondary" Margin="6,0,0,0"/>
                    </Grid>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#DC2626" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>

                <ScrollViewer IsEnabled="{Binding SaveCancelEnabled}">
                    <StackPanel Spacing="16">
                        
                        <StackPanel Spacing="2">
                            <TextBlock Text="Patient" Classes="label"/>
                            <ComboBox ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatient}" 
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Spacing="2">
                            <TextBlock Text="Doctor" Classes="label"/>
                            <ComboBox ItemsSource="{Binding Doctors}" SelectedItem="{Binding SelectedDoctor}" 
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Username}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock Text="Date" Classes="label"/>
                            <DatePicker SelectedDate="{Binding AppointmentDate}" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock Text="Time" Classes="label"/>
                            <TimePicker SelectedTime="{Binding AppointmentTime}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="2">
                            <TextBlock Text="Reason for Visit" Classes="label"/>
                            <TextBox Text="{Binding Reason}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="12,10"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Grid Side -->
        <Border Grid.Column="1" Classes="card" Margin="24,0,0,0">
            <DockPanel>
                <!-- Toolbar -->
                <Border DockPanel.Dock="Top" Padding="0,0,0,16" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Margin="0,0,0,16">
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,0">
                            <Button Command="{Binding NewCommand}" IsEnabled="{Binding MutationEnabled}" Classes="primary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconPlus}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="Book" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding EditCommand}" IsEnabled="{Binding MutationEnabled}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconEdit}" Width="14" Height="14" Foreground="#1F2937" VerticalAlignment="Center"/>
                                    <TextBlock Text="Edit" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        
                        <Border Width="1" Background="#E5E7EB" Margin="0,0,16,0" Height="24" VerticalAlignment="Center"/>

                        <!-- Status actions -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding CheckInCommand}" IsEnabled="{Binding MutationEnabled}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" Foreground="#1F2937" VerticalAlignment="Center"/>
                                    <TextBlock Text="Check-In" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding CompleteCommand}" IsEnabled="{Binding MutationEnabled}" Classes="success">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconVisit}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="Complete" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding MarkCancelledCommand}" IsEnabled="{Binding MutationEnabled}" Classes="danger">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconClose}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </WrapPanel>
                </Border>
                
                <DataGrid ItemsSource="{Binding Appointments}" SelectedItem="{Binding SelectedAppointment}"
                          AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding AppointmentDate, StringFormat=\{0:MM/dd/yyyy\}}" Width="110"/>
                        <DataGridTextColumn Header="Time" Binding="{Binding AppointmentTime, StringFormat=\{0:hh\\:mm\}}" Width="90"/>
                        <DataGridTextColumn Header="Patient" Binding="{Binding PatientName}" Width="160"/>
                        <DataGridTextColumn Header="Doctor" Binding="{Binding DoctorName}" Width="130"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

