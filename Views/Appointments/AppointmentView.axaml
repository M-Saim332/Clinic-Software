<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Appointments"
             xmlns:comp="using:ClinicSystem.UI.Views.Components"
             x:Class="ClinicSystem.UI.Views.Appointments.AppointmentView"
             x:Name="Root"
             x:DataType="vm:AppointmentViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <Grid>
        <!-- CREATE PATIENT PROMPT DIALOG -->
        <Border Background="#80000000" IsVisible="{Binding ShowCreatePatientPrompt}" ZIndex="100">
            <Border Background="{DynamicResource BrushCardBackground}" CornerRadius="12" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
                <StackPanel Spacing="16">
                    <TextBlock Text="Create Patient?" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="This appointment was completed but has no linked patient record. Would you like to create one?" TextWrapping="Wrap" Foreground="{DynamicResource BrushInk600}"/>
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button  Command="{Binding DismissCreatePatientPromptCommand}" Classes="btn-secondary">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Circle" Width="18" Height="18"/>
        <TextBlock Text="No, Skip" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                        <Button  Command="{Binding CreatePatientFromAppointmentCommand}" Classes="btn-primary">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Check" Width="18" Height="18"/>
        <TextBlock Text="Yes, Create Patient" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- LIST VIEW -->
        <Grid IsVisible="{Binding !SaveCancelEnabled}" RowDefinitions="Auto,Auto,*">
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushBlue50}">
                            <materialIcons:MaterialIcon Kind="CalendarCheck" Width="20" Height="20"
                                      Foreground="{DynamicResource BrushPrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="Appointments" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Book, manage, and track patient appointments"
                                       FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button  Command="{Binding NewCommand}"
                            Classes="btn-primary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="CalendarPlus" Width="18" Height="18"/>
        <TextBlock Text="Book Appointment" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                </DockPanel>
            </Border>

            <!-- Summary Cards -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Margin="28,16,28,4">
                <comp:SummaryCardControl Grid.Column="0" Margin="0,0,12,0"
                    Title="Total Appointments"
                    Value="{Binding TotalAppointmentsCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushPrimaryBlue}"/>
                <comp:SummaryCardControl Grid.Column="1" Margin="0,0,12,0"
                    Title="Scheduled"
                    Value="{Binding ScheduledCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushAmber}"/>
                <comp:SummaryCardControl Grid.Column="2" Margin="0,0,12,0"
                    Title="Missed"
                    Value="{Binding MissedCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushTeal}"/>
                <comp:SummaryCardControl Grid.Column="3"
                    Title="Completed Today"
                    Value="{Binding CompletedCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushRose}"/>
            </Grid>

            <!-- Data Panel -->
            <Grid Grid.Row="2" Margin="28,12,28,24">
                <comp:DataTableShellControl Title="Appointment List" RecordCount="{Binding Appointments.Count}">
                    <comp:DataTableShellControl.FilterToolbar>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <!-- Removed toolbar buttons -->
                        </StackPanel>
                    </comp:DataTableShellControl.FilterToolbar>
                    <comp:DataTableShellControl.TableContent>
                        <DataGrid ItemsSource="{Binding Appointments}" SelectedItem="{Binding SelectedAppointment}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" Background="Transparent" BorderThickness="0"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="DATE" Binding="{Binding AppointmentDate, StringFormat=\{0:dd MMM yyyy\}}" Width="130"/>
                                <DataGridTextColumn Header="TIME" Binding="{Binding AppointmentTime, StringFormat=\{0:hh\:mm tt\}}" Width="100"/>
                                <DataGridTextColumn Header="PATIENT" Binding="{Binding PatientName}" Width="*"/>
                                <DataGridTextColumn Header="REASON" Binding="{Binding Reason}" Width="*"/>
                                <DataGridTemplateColumn Header="STATUS" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <comp:StatusBadgeControl Status="{Binding Status}" VerticalAlignment="Center" Margin="4,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="ACTIONS" Width="360">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button  Command="{Binding #Root.((vm:AppointmentViewModel)DataContext).ViewSpecificCommand}" CommandParameter="{Binding}" Classes="btn-secondary" Padding="8,4" Height="28" ToolTip.Tip="View">
    <materialIcons:MaterialIcon Kind="Eye" Width="18" Height="18"/>
</Button>
                                                <Button  Command="{Binding #Root.((vm:AppointmentViewModel)DataContext).EditSpecificCommand}" CommandParameter="{Binding}" Classes="btn-secondary" Padding="8,4" Height="28" ToolTip.Tip="Edit">
    <materialIcons:MaterialIcon Kind="Pencil" Width="18" Height="18"/>
</Button>
                                                <Button  Command="{Binding #Root.((vm:AppointmentViewModel)DataContext).CompleteSpecificCommand}" CommandParameter="{Binding}" Classes="btn-success" Padding="8,4" Height="28" ToolTip.Tip="Complete">
    <materialIcons:MaterialIcon Kind="Check" Width="18" Height="18"/>
</Button>
                                                <Button  Command="{Binding #Root.((vm:AppointmentViewModel)DataContext).MarkMissedSpecificCommand}" CommandParameter="{Binding}" Classes="btn-secondary" Padding="8,4" Height="28" ToolTip.Tip="Missed">
    <materialIcons:MaterialIcon Kind="CloseCircle" Width="18" Height="18"/>
</Button>
                                                <Button  Command="{Binding #Root.((vm:AppointmentViewModel)DataContext).MarkCancelledSpecificCommand}" CommandParameter="{Binding}" Classes="btn-danger" Padding="8,4" Height="28" ToolTip.Tip="Cancel">
    <materialIcons:MaterialIcon Kind="Close" Width="18" Height="18"/>
</Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </comp:DataTableShellControl.TableContent>
                </comp:DataTableShellControl>
            </Grid>
        </Grid>

        <!-- FORM VIEW -->
        <Grid IsVisible="{Binding SaveCancelEnabled}" RowDefinitions="Auto,*,Auto">
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushBlue50}">
                            <materialIcons:MaterialIcon Kind="CalendarCheck" Width="20" Height="20"
                                      Foreground="{DynamicResource BrushPrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="{Binding Mode, StringFormat='{}{0} Appointment'}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}" FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Fill out appointment details below" FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button  Command="{Binding CancelCommand}"
                            Classes="btn-secondary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="ArrowLeft" Width="18" Height="18"/>
        <TextBlock Text="Back" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                </DockPanel>
            </Border>

            <!-- Form Body -->
            <ScrollViewer Grid.Row="1" Padding="28,24">
                <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Left">
                    <StackPanel Spacing="16">
                        <TextBlock Text="APPOINTMENT DETAILS" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk400}" LetterSpacing="1.5"
                                   FontFamily="{DynamicResource FontLexend}"/>
                        <Separator/>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" HorizontalAlignment="Stretch">
                            <StackPanel Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Spacing="6" Margin="0,0,0,12">
                                <TextBlock Text="Patient (Optional)" Classes="label"/>
                                <ComboBox ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatient}"
                                          HorizontalAlignment="Stretch" PlaceholderText="Select Existing Patient or leave blank to enter manually" IsEnabled="{Binding !IsReadOnly}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="0" Grid.Row="1" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="Patient Name *" Classes="label"/>
                                <TextBox Text="{Binding PatientName}" HorizontalAlignment="Stretch" IsReadOnly="{Binding IsReadOnly}" IsEnabled="{Binding SelectedPatient, Converter={x:Static ObjectConverters.IsNull}}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Spacing="6" Margin="12,0,0,12">
                                <TextBlock Text="Phone *" Classes="label"/>
                                <TextBox Text="{Binding PatientPhone}" HorizontalAlignment="Stretch" IsReadOnly="{Binding IsReadOnly}" IsEnabled="{Binding SelectedPatient, Converter={x:Static ObjectConverters.IsNull}}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="0" Grid.Row="2" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="Gender (Optional)" Classes="label"/>
                                <ComboBox SelectedItem="{Binding Gender}" HorizontalAlignment="Stretch" IsEnabled="{Binding SelectedPatient, Converter={x:Static ObjectConverters.IsNull}}">
                                    <x:String>Male</x:String>
                                    <x:String>Female</x:String>
                                    <x:String>Other</x:String>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="2" Spacing="6" Margin="12,0,0,12">
                                <TextBlock Text="Age (Optional)" Classes="label"/>
                                <NumericUpDown Value="{Binding Age}" Minimum="0" Maximum="150" HorizontalAlignment="Stretch" IsEnabled="{Binding SelectedPatient, Converter={x:Static ObjectConverters.IsNull}}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="3" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="Date *" Classes="label"/>
                                <DatePicker SelectedDate="{Binding AppointmentDate}" HorizontalAlignment="Stretch" IsEnabled="{Binding !IsReadOnly}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="3" Spacing="6" Margin="12,0,0,12">
                                <TextBlock Text="Time *" Classes="label"/>
                                <TimePicker SelectedTime="{Binding AppointmentTime}" HorizontalAlignment="Stretch" IsEnabled="{Binding !IsReadOnly}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4" Spacing="6" Margin="0,0,0,12">
                                <TextBlock Text="Reason for Visit" Classes="label"/>
                                <TextBox Text="{Binding Reason}" PlaceholderText="Describe the reason for this appointment..."
                                         AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                                         VerticalContentAlignment="Top" Padding="12,10" IsReadOnly="{Binding IsReadOnly}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,1,0,0" Padding="28,16">
                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushRose}"
                               VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button  Command="{Binding EditSpecificCommand}" CommandParameter="{Binding SelectedAppointment}" Classes="btn-secondary" IsVisible="{Binding ShowEditButton}">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Pencil" Width="18" Height="18"/>
        <TextBlock Text="Edit Appointment" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                        <Button  Command="{Binding SaveCommand}" Classes="btn-primary" IsVisible="{Binding ShowSaveButton}">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="ContentSave" Width="18" Height="18"/>
        <TextBlock Text="Save Appointment" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource BrushPrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk600}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="{DynamicResource BrushRose}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#BE123C"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-success">
            <Setter Property="Background" Value="#16A34A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.40"/>
        </Style>
    </UserControl.Styles>
</UserControl>
