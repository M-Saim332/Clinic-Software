<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Users"
             xmlns:comp="using:ClinicSystem.UI.Views.Components"
             x:Class="ClinicSystem.UI.Views.Users.UserRegistryView"
             x:DataType="vm:UserRegistryViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <Grid>

        <!-- ╔═════════════════════════════════════════════╗ -->
        <!-- ║  VIEW 1: USER LIST                           ║ -->
        <!-- ╚═════════════════════════════════════════════╝ -->
        <Grid IsVisible="{Binding IsListView}" RowDefinitions="Auto,Auto,Auto,*">

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <Border Width="44" Height="44" CornerRadius="10" Background="#EFF6FF">
                            <PathIcon Data="{StaticResource IconUsers}" Width="22" Height="22"
                                      Foreground="{DynamicResource BrushPrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="User Management" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Manage accounts, roles, permissions and access control"
                                       FontSize="12" Foreground="{DynamicResource BrushInk500}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="＋ Add User" Command="{Binding NewCommand}"
                            Classes="btn-primary" DockPanel.Dock="Right"
                            HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- KPI Summary Cards -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*" Margin="28,16,28,4">
                <comp:SummaryCardControl Grid.Column="0" Margin="0,0,10,0"
                    Title="Total Users"   Value="{Binding TotalUsersCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushPrimaryBlue}"/>
                <comp:SummaryCardControl Grid.Column="1" Margin="0,0,10,0"
                    Title="Active"        Value="{Binding ActiveUsersCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushTeal}"/>
                <comp:SummaryCardControl Grid.Column="2" Margin="0,0,10,0"
                    Title="Admins"        Value="{Binding AdminCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushRose}"/>
                <comp:SummaryCardControl Grid.Column="3" Margin="0,0,10,0"
                    Title="Doctors"       Value="{Binding DoctorCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushAmber}"/>
                <comp:SummaryCardControl Grid.Column="4" Margin="0,0,10,0"
                    Title="Pharmacists"   Value="{Binding PharmacistCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushTeal}"/>
                <comp:SummaryCardControl Grid.Column="5"
                    Title="Receptionists" Value="{Binding ReceptionistCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushPrimaryBlue}"/>
            </Grid>

            <!-- Search + Filter Bar -->
            <Border Grid.Row="2" Margin="28,8,28,4" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                    CornerRadius="10" Padding="16,10">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <!-- Search -->
                    <Border Grid.Column="0" Background="{DynamicResource BrushBackground}"
                            BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                            CornerRadius="8" Padding="10,0" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconSearch}" Width="14" Height="14"
                                      Foreground="{DynamicResource BrushInk400}"/>
                            <TextBox Text="{Binding SearchQuery}" BorderThickness="0"
                                     Background="Transparent" Height="34"
                                     PlaceholderText="Search by name, username, email, phone or role..."
                                     FontSize="13" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Role Filter -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,12,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Role:" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushInk500}" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding FilterRoleOptions}"
                                  SelectedItem="{Binding FilterRole}"
                                  MinWidth="130" Height="34" FontSize="12"/>
                    </StackPanel>
                    <!-- Status Filter -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Text="Status:" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushInk500}" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding FilterStatusOptions}"
                                  SelectedItem="{Binding FilterStatus}"
                                  MinWidth="110" Height="34" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Data Table -->
            <Grid Grid.Row="3" Margin="28,8,28,24">
                <comp:DataTableShellControl Title="All System Users" RecordCount="{Binding Users.Count}">
                    <comp:DataTableShellControl.FilterToolbar>
                        <!-- Status message -->
                        <Panel>
                            <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    CornerRadius="6" Padding="10,6" Margin="0,0,0,0">
                                <Border.Background>
                                    <SolidColorBrush Color="#F0FDF4"/>
                                </Border.Background>
                                <Border IsVisible="{Binding !IsSuccess}" Background="#FFF1F2" CornerRadius="6" Padding="10,6">
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource BrushRose}"/>
                                </Border>
                            </Border>
                            <TextBlock Text="{Binding StatusMessage}" FontSize="12" FontWeight="Medium"
                                       Foreground="#16A34A" Margin="0,6,0,0"
                                       IsVisible="{Binding IsSuccess}"/>
                        </Panel>
                    </comp:DataTableShellControl.FilterToolbar>
                    <comp:DataTableShellControl.TableContent>
                        <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" Background="Transparent" BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="{DynamicResource BrushCardBackground}">
                            <DataGrid.Columns>

                                <!-- Avatar + Name -->
                                <DataGridTemplateColumn Header="USER" Width="*" MinWidth="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="10"
                                                        VerticalAlignment="Center" Margin="8,4">
                                                <Border Width="36" Height="36" CornerRadius="18"
                                                        Background="#EFF6FF" ClipToBounds="True">
                                                    <TextBlock FontSize="13" FontWeight="Bold"
                                                               Foreground="{DynamicResource BrushPrimaryBlue}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock.Text>
                                                            <Binding Path="FullName" FallbackValue="?"/>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center" Spacing="1">
                                                    <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{DynamicResource BrushInk900}"/>
                                                    <TextBlock Text="{Binding Username, StringFormat='@{0}'}"
                                                               FontSize="11" Foreground="{DynamicResource BrushInk500}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Role Badge -->
                                <DataGridTemplateColumn Header="ROLE" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border HorizontalAlignment="Left" Margin="8,0"
                                                    CornerRadius="12" Padding="10,3"
                                                    Background="#EFF6FF">
                                                <TextBlock Text="{Binding Role}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushPrimaryBlue}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Email -->
                                <DataGridTemplateColumn Header="EMAIL" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Email, FallbackValue='—'}"
                                                       FontSize="12" Foreground="{DynamicResource BrushInk700}"
                                                       VerticalAlignment="Center" Margin="8,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Phone -->
                                <DataGridTemplateColumn Header="PHONE" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Phone, FallbackValue='—'}"
                                                       FontSize="12" Foreground="{DynamicResource BrushInk700}"
                                                       VerticalAlignment="Center" Margin="8,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Status Badge -->
                                <DataGridTemplateColumn Header="STATUS" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Panel HorizontalAlignment="Left" Margin="8,0">
                                                <Border CornerRadius="12" Padding="10,3"
                                                        Background="#F0FDF4"
                                                        IsVisible="{Binding IsActive}">
                                                    <TextBlock Text="Active" FontSize="11"
                                                               FontWeight="SemiBold" Foreground="#16A34A"/>
                                                </Border>
                                                <Border CornerRadius="12" Padding="10,3"
                                                        Background="#FFF1F2"
                                                        IsVisible="{Binding !IsActive}">
                                                    <TextBlock Text="Inactive" FontSize="11"
                                                               FontWeight="SemiBold" Foreground="#DC2626"/>
                                                </Border>
                                            </Panel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Last Login -->
                                <DataGridTemplateColumn Header="LAST LOGIN" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LastLoginDisplay}"
                                                       FontSize="11" Foreground="{DynamicResource BrushInk500}"
                                                       VerticalAlignment="Center" Margin="8,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Actions -->
                                <DataGridTemplateColumn Header="ACTIONS" Width="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="4"
                                                        VerticalAlignment="Center" Margin="6,0">
                                                <!-- Edit -->
                                                <Button Background="#EFF6FF" Padding="6" CornerRadius="6"
                                                        Command="{Binding $parent[UserControl].((vm:UserRegistryViewModel)DataContext).EditCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Edit User">
                                                    <PathIcon Data="{StaticResource IconEdit}"
                                                              Width="14" Height="14"
                                                              Foreground="{DynamicResource BrushPrimaryBlue}"/>
                                                </Button>
                                                <!-- Reset Password -->
                                                <Button Background="#FFF7ED" Padding="6" CornerRadius="6"
                                                        Command="{Binding $parent[UserControl].((vm:UserRegistryViewModel)DataContext).ShowResetPasswordCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding IsEditable}"
                                                        ToolTip.Tip="Reset Password">
                                                    <PathIcon Data="{StaticResource IconAlert}"
                                                              Width="14" Height="14"
                                                              Foreground="{DynamicResource BrushAmber}"/>
                                                </Button>
                                                <!-- Activate / Deactivate -->
                                                <Button Padding="6" CornerRadius="6"
                                                        Command="{Binding $parent[UserControl].((vm:UserRegistryViewModel)DataContext).ToggleStatusCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding IsEditable}"
                                                        ToolTip.Tip="{Binding StatusLabel}">
                                                    <Button.Background>
                                                        <SolidColorBrush Color="#F0FDF4"/>
                                                    </Button.Background>
                                                    <Panel>
                                                        <!-- When active — show deactivate icon (lock) -->
                                                        <PathIcon IsVisible="{Binding IsActive}"
                                                                  Data="{StaticResource IconClose}"
                                                                  Width="14" Height="14"
                                                                  Foreground="#16A34A"/>
                                                        <!-- When inactive — show activate icon (check) -->
                                                        <PathIcon IsVisible="{Binding !IsActive}"
                                                                  Data="{StaticResource IconClose}"
                                                                  Width="14" Height="14"
                                                                  Foreground="#6B7280"/>
                                                    </Panel>
                                                </Button>
                                                <!-- Delete -->
                                                <Button Background="#FFF1F2" Padding="6" CornerRadius="6"
                                                        Command="{Binding $parent[UserControl].((vm:UserRegistryViewModel)DataContext).RequestDeleteCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding IsDeletable}"
                                                        ToolTip.Tip="Delete User">
                                                    <PathIcon Data="{StaticResource IconTrash}"
                                                              Width="14" Height="14"
                                                              Foreground="{DynamicResource BrushRose}"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </comp:DataTableShellControl.TableContent>
                </comp:DataTableShellControl>
            </Grid>

            <!-- Delete Confirmation Overlay -->
            <Border Grid.Row="0" Grid.RowSpan="4"
                    IsVisible="{Binding ShowDeleteConfirm}" Background="#90000000" ZIndex="100">
                <Border Background="{DynamicResource BrushCardBackground}" CornerRadius="16"
                        Padding="32,28" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="420" BoxShadow="0 20 60 0 #40000000">
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <Border Width="48" Height="48" CornerRadius="24" Background="#FEF2F2">
                                <PathIcon Data="{StaticResource IconTrash}" Width="22" Height="22"
                                          Foreground="{DynamicResource BrushRose}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="Delete User Account" FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource BrushInk900}"/>
                                <TextBlock Text="This action cannot be undone" FontSize="12"
                                           Foreground="{DynamicResource BrushRose}"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="13"
                                   Foreground="{DynamicResource BrushInk600}" LineHeight="20">
                            <Run Text="You are about to permanently delete the account "/>
                            <Run Text="{Binding PendingDeleteLabel}" FontWeight="Bold"
                                 Foreground="{DynamicResource BrushInk900}"/>
                            <Run Text=". All their login access will be removed."/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                            <Button Content="Cancel" Command="{Binding CancelDeleteCommand}" Classes="btn-ghost"/>
                            <Button Content="Yes, Delete" Command="{Binding ConfirmDeleteCommand}" Classes="btn-danger"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

        </Grid>

        <!-- ╔═════════════════════════════════════════════╗ -->
        <!-- ║  VIEW 2: ADD / EDIT FORM                     ║ -->
        <!-- ╚═════════════════════════════════════════════╝ -->
        <Grid IsVisible="{Binding IsFormView}" RowDefinitions="Auto,*,Auto">

            <!-- Form Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <Border Width="44" Height="44" CornerRadius="10" Background="#EFF6FF">
                            <PathIcon Data="{StaticResource IconUsers}" Width="22" Height="22"
                                      Foreground="{DynamicResource BrushPrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{Binding Mode, StringFormat='{}{0} User Account'}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Fill in all required fields marked with *"
                                       FontSize="12" Foreground="{DynamicResource BrushInk500}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="← Back to List" Command="{Binding CancelCommand}"
                            Classes="btn-secondary" DockPanel.Dock="Right"
                            HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Form Body -->
            <ScrollViewer Grid.Row="1" Padding="28,20,28,0">
                <Grid ColumnDefinitions="*,320" Margin="0,0,0,24">

                    <!-- LEFT: Form Sections -->
                    <StackPanel Grid.Column="0" Spacing="16" Margin="0,0,16,0">

                        <!-- PERSONAL INFORMATION -->
                        <Border Classes="card-section">
                            <StackPanel Spacing="16">
                                <TextBlock Text="PERSONAL INFORMATION" Classes="section-header"/>
                                <Separator/>
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">

                                    <StackPanel Grid.Column="0" Grid.Row="0" Classes="field-cell-left">
                                        <TextBlock Text="Full Name *" Classes="lbl"/>
                                        <TextBox Text="{Binding FullName}" PlaceholderText="Dr. John Smith"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="0" Classes="field-cell-right">
                                        <TextBlock Text="CNIC / NIC" Classes="lbl"/>
                                        <TextBox Text="{Binding Cnic}" PlaceholderText="00000-0000000-0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="1" Classes="field-cell-left">
                                        <TextBlock Text="Phone Number *" Classes="lbl"/>
                                        <TextBox Text="{Binding Phone}" PlaceholderText="+92 300 0000000"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="1" Classes="field-cell-right">
                                        <TextBlock Text="Email Address *" Classes="lbl"/>
                                        <TextBox Text="{Binding Email}" PlaceholderText="doctor@clinic.com"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="2" Classes="field-cell-left">
                                        <TextBlock Text="Gender" Classes="lbl"/>
                                        <ComboBox ItemsSource="{Binding GenderOptions}"
                                                  SelectedItem="{Binding Gender}"
                                                  PlaceholderText="Select gender"
                                                  HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="2" Classes="field-cell-right">
                                        <TextBlock Text="Date of Birth" Classes="lbl"/>
                                        <DatePicker SelectedDate="{Binding DateOfBirth}"
                                                    HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Address" Classes="lbl"/>
                                    <TextBox Text="{Binding Address}"
                                             AcceptsReturn="True" Height="72"
                                             TextWrapping="Wrap" VerticalContentAlignment="Top"
                                             Padding="12,10"
                                             PlaceholderText="Street, City, Country"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- PROFESSIONAL INFORMATION -->
                        <Border Classes="card-section">
                            <StackPanel Spacing="16">
                                <TextBlock Text="PROFESSIONAL INFORMATION" Classes="section-header"/>
                                <Separator/>
                                <Grid ColumnDefinitions="*,*,*">
                                    <StackPanel Grid.Column="0" Classes="field-cell-left">
                                        <TextBlock Text="Designation" Classes="lbl"/>
                                        <TextBox Text="{Binding Designation}" PlaceholderText="e.g. General Physician"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Classes="field-cell-right">
                                        <TextBlock Text="Qualification" Classes="lbl"/>
                                        <TextBox Text="{Binding Qualification}" PlaceholderText="e.g. MBBS, FCPS"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                        <TextBlock Text="License / PMDC No." Classes="lbl"/>
                                        <TextBox Text="{Binding LicenseNumber}" PlaceholderText="PMDC-12345"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ACCOUNT CREDENTIALS -->
                        <Border Classes="card-section">
                            <StackPanel Spacing="16">
                                <TextBlock Text="ACCOUNT CREDENTIALS" Classes="section-header"/>
                                <Separator/>
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                                    <StackPanel Grid.Column="0" Grid.Row="0" Classes="field-cell-left">
                                        <TextBlock Text="Username *" Classes="lbl"/>
                                        <TextBox Text="{Binding Username}" PlaceholderText="e.g. dr_john"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="0" Classes="field-cell-right">
                                        <TextBlock Text="System Role *" Classes="lbl"/>
                                        <ComboBox ItemsSource="{Binding RoleOptions}"
                                                  SelectedItem="{Binding Role}"
                                                  HorizontalAlignment="Stretch"
                                                  PlaceholderText="Select role"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="1" Classes="field-cell-left">
                                        <TextBlock Text="Password *" Classes="lbl"/>
                                        <TextBox Text="{Binding Password}" PasswordChar="●"
                                                 PlaceholderText="{Binding PasswordWatermark}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="1" Classes="field-cell-right">
                                        <TextBlock Text="Confirm Password *" Classes="lbl"/>
                                        <TextBox Text="{Binding ConfirmPassword}" PasswordChar="●"
                                                 PlaceholderText="Re-enter password"/>
                                    </StackPanel>
                                </Grid>
                                <!-- Active toggle -->
                                <CheckBox Content="Account is Active"
                                          IsChecked="{Binding IsActive}"
                                          Foreground="{DynamicResource BrushInk800}"
                                          FontSize="13" FontWeight="Medium"/>
                            </StackPanel>
                        </Border>

                        <!-- MODULE ACCESS -->
                        <Border Classes="card-section" IsVisible="{Binding ShowModuleAccess}">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="MODULE ACCESS PERMISSIONS" Classes="section-header"/>
                                    <TextBlock Text="Choose which modules this user can access. Unchecked modules will be hidden from the sidebar."
                                               FontSize="12" Foreground="{DynamicResource BrushInk500}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Separator/>
                                <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                    <!-- Row 0 -->
                                    <Border Grid.Column="0" Grid.Row="0" Classes="perm-box" Margin="0,0,8,8">
                                        <CheckBox Content="Dashboard" IsChecked="{Binding AccDashboard}" Classes="perm-chk"/>
                                    </Border>
                                    <Border Grid.Column="1" Grid.Row="0" Classes="perm-box" Margin="0,0,8,8">
                                        <CheckBox Content="Patients" IsChecked="{Binding AccPatients}" Classes="perm-chk"/>
                                    </Border>
                                    <Border Grid.Column="2" Grid.Row="0" Classes="perm-box" Margin="0,0,0,8">
                                        <CheckBox Content="Appointments" IsChecked="{Binding AccAppointments}" Classes="perm-chk"/>
                                    </Border>
                                    <!-- Row 1 -->
                                    <Border Grid.Column="0" Grid.Row="1" Classes="perm-box" Margin="0,0,8,8">
                                        <CheckBox Content="Products" IsChecked="{Binding AccProducts}" Classes="perm-chk"/>
                                    </Border>
                                    <Border Grid.Column="1" Grid.Row="1" Classes="perm-box" Margin="0,0,8,8">
                                        <CheckBox Content="Companies" IsChecked="{Binding AccCompanies}" Classes="perm-chk"/>
                                    </Border>
                                    <Border Grid.Column="2" Grid.Row="1" Classes="perm-box" Margin="0,0,0,8">
                                        <CheckBox Content="Suppliers" IsChecked="{Binding AccSuppliers}" Classes="perm-chk"/>
                                    </Border>
                                    <!-- Row 2 -->
                                    <Border Grid.Column="0" Grid.Row="2" Classes="perm-box" Margin="0,0,8,8">
                                        <CheckBox Content="Purchases" IsChecked="{Binding AccPurchases}" Classes="perm-chk"/>
                                    </Border>
                                    <Border Grid.Column="1" Grid.Row="2" Classes="perm-box" Margin="0,0,8,8">
                                        <CheckBox Content="Sales &amp; Billing" IsChecked="{Binding AccSales}" Classes="perm-chk"/>
                                    </Border>
                                    <Border Grid.Column="2" Grid.Row="2" Classes="perm-box" Margin="0,0,0,8">
                                        <CheckBox Content="Returns" IsChecked="{Binding AccReturns}" Classes="perm-chk"/>
                                    </Border>
                                    <!-- Row 3 -->
                                    <Border Grid.Column="0" Grid.Row="3" Classes="perm-box" Margin="0,0,8,8">
                                        <CheckBox Content="Inventory" IsChecked="{Binding AccInventory}" Classes="perm-chk"/>
                                    </Border>
                                    <Border Grid.Column="1" Grid.Row="3" Classes="perm-box" Margin="0,0,8,8">
                                        <CheckBox Content="Reports" IsChecked="{Binding AccReports}" Classes="perm-chk"/>
                                    </Border>
                                    <Border Grid.Column="2" Grid.Row="3" Classes="perm-box" Margin="0,0,0,8">
                                        <CheckBox Content="Settings" IsChecked="{Binding AccSettings}" Classes="perm-chk"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Admin / Doctor note -->
                        <Border IsVisible="{Binding !ShowModuleAccess}"
                                Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                                CornerRadius="10" Padding="16,12">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Data="{StaticResource IconAlert}" Width="16" Height="16"
                                          Foreground="{DynamicResource BrushPrimaryBlue}"
                                          VerticalAlignment="Center"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#1D4ED8">
                                    This role has full system access. Module permissions do not apply.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- RIGHT: Profile Picture + Role Info -->
                    <StackPanel Grid.Column="1" Spacing="16">

                        <!-- Profile Picture Card -->
                        <Border Background="{DynamicResource BrushCardBackground}"
                                BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                                CornerRadius="14" Padding="20">
                            <StackPanel Spacing="14">
                                <TextBlock Text="PROFILE PICTURE" Classes="section-header"/>
                                <Separator/>

                                <!-- Avatar Preview -->
                                <Border Width="100" Height="100" CornerRadius="50"
                                        Background="#EFF6FF" HorizontalAlignment="Center"
                                        BorderBrush="{DynamicResource BrushPrimaryBlue}" BorderThickness="2">
                                    <Panel>
                                        <!-- Initials (no picture) -->
                                        <TextBlock IsVisible="{Binding !HasProfilePicture}"
                                                   FontSize="36" FontWeight="Bold"
                                                   Foreground="{DynamicResource BrushPrimaryBlue}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <Binding Path="FullName" FallbackValue="?"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <PathIcon IsVisible="{Binding !HasProfilePicture}"
                                                  Data="{StaticResource IconUsers}"
                                                  Width="40" Height="40"
                                                  Foreground="{DynamicResource BrushPrimaryBlue}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Panel>
                                </Border>

                                <TextBlock Text="JPG, PNG or WEBP. Max 5MB."
                                           FontSize="11" Foreground="{DynamicResource BrushInk400}"
                                           HorizontalAlignment="Center" TextAlignment="Center"/>

                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <Button Content="Upload Photo"
                                            Command="{Binding UploadPictureCommand}"
                                            Classes="btn-secondary" Height="32" FontSize="12"/>
                                    <Button Content="Remove"
                                            Command="{Binding RemovePictureCommand}"
                                            Classes="btn-ghost" Height="32" FontSize="12"
                                            IsVisible="{Binding HasProfilePicture}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Role Guide Card -->
                        <Border Background="{DynamicResource BrushCardBackground}"
                                BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                                CornerRadius="14" Padding="20">
                            <StackPanel Spacing="14">
                                <TextBlock Text="ROLE GUIDE" Classes="section-header"/>
                                <Separator/>

                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="3">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource BrushRose}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Administrator" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushInk900}"/>
                                        </StackPanel>
                                        <TextBlock Text="Full access to all modules including User Management."
                                                   FontSize="11" Foreground="{DynamicResource BrushInk500}"
                                                   TextWrapping="Wrap" Margin="16,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Spacing="3">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource BrushAmber}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Doctor" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushInk900}"/>
                                        </StackPanel>
                                        <TextBlock Text="Full clinical access: patients, appointments, prescriptions."
                                                   FontSize="11" Foreground="{DynamicResource BrushInk500}"
                                                   TextWrapping="Wrap" Margin="16,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Spacing="3">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource BrushTeal}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Pharmacist" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushInk900}"/>
                                        </StackPanel>
                                        <TextBlock Text="Products, sales, purchases, inventory and returns."
                                                   FontSize="11" Foreground="{DynamicResource BrushInk500}"
                                                   TextWrapping="Wrap" Margin="16,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Spacing="3">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource BrushPrimaryBlue}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Receptionist" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushInk900}"/>
                                        </StackPanel>
                                        <TextBlock Text="Patients, appointments, and billing only."
                                                   FontSize="11" Foreground="{DynamicResource BrushInk500}"
                                                   TextWrapping="Wrap" Margin="16,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Spacing="3">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Width="8" Height="8" CornerRadius="4" Background="#9CA3AF" VerticalAlignment="Center"/>
                                            <TextBlock Text="Assistant" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushInk900}"/>
                                        </StackPanel>
                                        <TextBlock Text="Limited access based on assigned permissions."
                                                   FontSize="11" Foreground="{DynamicResource BrushInk500}"
                                                   TextWrapping="Wrap" Margin="16,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Form Footer -->
            <Border Grid.Row="2" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,1,0,0" Padding="28,16">
                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                               FontSize="13" FontWeight="Medium">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="#DC2626"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Spacing="12"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="btn-ghost"/>
                        <Button Content="💾  Save User" Command="{Binding SaveCommand}" Classes="btn-primary"/>
                    </StackPanel>
                </DockPanel>
            </Border>

        </Grid>

        <!-- ╔═════════════════════════════════════════════╗ -->
        <!-- ║  VIEW 3: RESET PASSWORD                      ║ -->
        <!-- ╚═════════════════════════════════════════════╝ -->
        <Grid IsVisible="{Binding IsResetPasswordView}" RowDefinitions="Auto,*,Auto">

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <Border Width="44" Height="44" CornerRadius="10" Background="#FFF7ED">
                            <PathIcon Data="{StaticResource IconAlert}" Width="22" Height="22"
                                      Foreground="{DynamicResource BrushAmber}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Reset User Password" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="{Binding ResetTargetLabel, StringFormat='Setting new password for: {0}'}"
                                       FontSize="12" Foreground="{DynamicResource BrushInk500}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="← Back to List" Command="{Binding CancelResetPasswordCommand}"
                            Classes="btn-secondary" DockPanel.Dock="Right"
                            HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1">
                <StackPanel HorizontalAlignment="Center" MaxWidth="520" Margin="24,32,24,32" Spacing="20">

                    <!-- Target User Info Banner -->
                    <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                            CornerRadius="10" Padding="16,14">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="44" Height="44" CornerRadius="22" Background="#DBEAFE">
                                <PathIcon Data="{StaticResource IconUsers}" Width="20" Height="20"
                                          Foreground="{DynamicResource BrushPrimaryBlue}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding ResetTarget.FullName, FallbackValue='—'}"
                                           FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushInk900}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding ResetTarget.Username, StringFormat='@{0}'}"
                                               FontSize="12" Foreground="{DynamicResource BrushInk500}"/>
                                    <Border CornerRadius="10" Padding="8,2" Background="#EFF6FF">
                                        <TextBlock Text="{Binding ResetTarget.Role}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrushPrimaryBlue}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Password Fields -->
                    <Border Background="{DynamicResource BrushCardBackground}"
                            BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                            CornerRadius="14" Padding="24">
                        <StackPanel Spacing="18">
                            <TextBlock Text="NEW PASSWORD" Classes="section-header"/>
                            <Separator/>

                            <StackPanel Spacing="5">
                                <TextBlock Text="New Password *" Classes="lbl"/>
                                <TextBox Text="{Binding NewPassword}" PasswordChar="●"
                                         PlaceholderText="Minimum 8 characters"/>
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="Confirm New Password *" Classes="lbl"/>
                                <TextBox Text="{Binding ConfirmNewPassword}" PasswordChar="●"
                                         PlaceholderText="Re-enter new password"/>
                            </StackPanel>

                            <Border Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1"
                                    CornerRadius="8" Padding="12,10">
                                <CheckBox Content="Force user to change password on next login"
                                          IsChecked="{Binding ForceChangeOnNextLogin}"
                                          FontSize="13" Foreground="#92400E"/>
                            </Border>

                            <!-- Validation Message -->
                            <Border IsVisible="{Binding ResetStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Background="#FFF1F2" BorderBrush="#FECDD3" BorderThickness="1"
                                    CornerRadius="8" Padding="12,8">
                                <TextBlock Text="{Binding ResetStatusMessage}"
                                           FontSize="13" FontWeight="Medium" Foreground="#DC2626"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Security Tips -->
                    <Border Background="{DynamicResource BrushBackground}"
                            BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                            CornerRadius="10" Padding="16,12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="🔒 Password Requirements" FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk700}"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource BrushInk500}"
                                       TextWrapping="Wrap" LineHeight="18">
                                • Minimum 8 characters&#xA;• The user will be notified to use their new password&#xA;• Enabling "force change" ensures the user sets their own password on next login
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Actions -->
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CancelResetPasswordCommand}" Classes="btn-ghost"/>
                        <Button Content="🔒  Reset Password" Command="{Binding SaveResetPasswordCommand}" Classes="btn-primary"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

        </Grid>

    </Grid>

    <!-- ════════════════════════════════════════════════════════════ -->
    <!-- LOCAL STYLES                                                   -->
    <!-- ════════════════════════════════════════════════════════════ -->
    <UserControl.Styles>
        <Style Selector="TextBlock.lbl">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk500}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk400}"/>
            <Setter Property="LetterSpacing" Value="1.5"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontLexend}"/>
        </Style>
        <Style Selector="Border.card-section">
            <Setter Property="Background" Value="{DynamicResource BrushCardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="24"/>
        </Style>
        <Style Selector="StackPanel.field-cell-left">
            <Setter Property="Margin" Value="0,0,12,14"/>
            <Setter Property="Spacing" Value="5"/>
        </Style>
        <Style Selector="StackPanel.field-cell-right">
            <Setter Property="Margin" Value="12,0,0,14"/>
            <Setter Property="Spacing" Value="5"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource BrushPrimaryBlue}"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="DatePicker">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Border.perm-box">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style Selector="CheckBox.perm-chk">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk800}"/>
        </Style>
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource BrushPrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk600}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="{DynamicResource BrushRose}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#BE123C"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.40"/>
        </Style>
    </UserControl.Styles>

</UserControl>
