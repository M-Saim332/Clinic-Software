<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Users"
             x:Class="ClinicSystem.UI.Views.Users.UserRegistryView"
             x:DataType="vm:UserRegistryViewModel"
             Background="#0F1117">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Background="#1A1D27" Padding="20,14" BorderBrush="#2A2D3A" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="👤 Users Registry" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}" Foreground="#0097A7" VerticalAlignment="Center" FontSize="13"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="320,*">
            <!-- Left: Form -->
            <Border Grid.Column="0" Background="#141720" Padding="20" BorderBrush="#2A2D3A" BorderThickness="0,0,1,0">
                <StackPanel Spacing="12">
                    <TextBlock Text="Actions" Foreground="#666" FontSize="11" FontWeight="SemiBold"/>
                    <WrapPanel Margin="0,0,0,6">
                        <Button Content="New"    Command="{Binding NewCommand}"    IsEnabled="{Binding MutationEnabled}" Classes="action"/>
                        <Button Content="Edit"   Command="{Binding EditCommand}"   IsEnabled="{Binding MutationEnabled}" Classes="action"/>
                        <Button Content="Delete" Command="{Binding DeleteCommand}" IsEnabled="{Binding MutationEnabled}" Classes="action danger"/>
                        <Button Content="Save"   Command="{Binding SaveCommand}"   IsEnabled="{Binding SaveCancelEnabled}" Classes="action primary"/>
                        <Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding SaveCancelEnabled}" Classes="action"/>
                    </WrapPanel>
                    <Separator Background="#2A2D3A" Height="1" Margin="0,4"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Username *" Classes="label"/>
                        <TextBox Text="{Binding Username}" IsEnabled="{Binding SaveCancelEnabled}" Classes="field" PlaceholderText="Login username"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Full Name" Classes="label"/>
                        <TextBox Text="{Binding FullName}" IsEnabled="{Binding SaveCancelEnabled}" Classes="field" PlaceholderText="Display name"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Role" Classes="label"/>
                        <ComboBox ItemsSource="{Binding RoleOptions}"
                                  SelectedItem="{Binding Role}"
                                  IsEnabled="{Binding SaveCancelEnabled}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Password" Classes="label"/>
                        <TextBox Text="{Binding Password}" IsEnabled="{Binding SaveCancelEnabled}"
                                 PasswordChar="●" Classes="field"
                                 PlaceholderText="{Binding PasswordWatermark}"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Confirm Password" Classes="label"/>
                        <TextBox Text="{Binding ConfirmPassword}" IsEnabled="{Binding SaveCancelEnabled}"
                                 PasswordChar="●" Classes="field" PlaceholderText="Re-enter password"/>
                    </StackPanel>
                    <CheckBox Content="Active" IsChecked="{Binding IsActive}" IsEnabled="{Binding SaveCancelEnabled}" Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Right: Users List -->
            <Border Grid.Column="1" Padding="20">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="All Users" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="#141720" RowBackground="#141720"
                              Foreground="White" GridLinesVisibility="Horizontal"
                              BorderBrush="#2A2D3A" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Username"  Binding="{Binding Username}"    Width="*"/>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}"    Width="*"/>
                            <DataGridTextColumn Header="Role"      Binding="{Binding Role}"        Width="120"/>
                            <DataGridTextColumn Header="Active"    Binding="{Binding IsActive}"    Width="60"/>
                            <DataGridTextColumn Header="Created"   Binding="{Binding CreatedAt, StringFormat=\{0:yyyy-MM-dd\}}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#141720" Padding="16,8" BorderBrush="#2A2D3A" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#888" FontSize="12"/>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="TextBlock.label"><Setter Property="Foreground" Value="#AAA"/><Setter Property="FontSize" Value="12"/></Style>
        <Style Selector="TextBox.field">
            <Setter Property="Background" Value="#252837"/><Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Foreground" Value="White"/><Setter Property="CornerRadius" Value="6"/><Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="Button.action"><Setter Property="Background" Value="#252837"/><Setter Property="Foreground" Value="#DDD"/><Setter Property="CornerRadius" Value="6"/><Setter Property="Padding" Value="12,7"/></Style>
        <Style Selector="Button.action.primary"><Setter Property="Background" Value="#0097A7"/><Setter Property="Foreground" Value="White"/></Style>
        <Style Selector="Button.action.danger"><Setter Property="Background" Value="#B71C1C"/><Setter Property="Foreground" Value="White"/></Style>
        <Style Selector="Button:disabled /template/ ContentPresenter"><Setter Property="Opacity" Value="0.35"/></Style>
    </UserControl.Styles>
</UserControl>
