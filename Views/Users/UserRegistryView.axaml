<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Users"
             x:Class="ClinicSystem.UI.Views.Users.UserRegistryView"
             x:DataType="vm:UserRegistryViewModel" x:CompileBindings="True"
             Background="#F8FAFC">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="24,16" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource IconUsers}" Width="20" Height="20" Foreground="#2563EB"/>
                    <TextBlock Text="Users Registry" FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
                </StackPanel>
                
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="340,*">
            <!-- Left: Form -->
            <Border Grid.Column="0" Background="#FFFFFF" Padding="24" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
                <ScrollViewer>
                  <StackPanel Spacing="16">
                    <TextBlock Text="Actions" Classes="label" Foreground="#6B7280" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,*">
                        <Button Grid.Row="0" Grid.Column="0" Content="New"    Command="{Binding NewCommand}"    IsEnabled="{Binding MutationEnabled}" Classes="action" Margin="0,0,8,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="Edit"   Command="{Binding EditCommand}"   IsEnabled="{Binding MutationEnabled}" Classes="action" Margin="0,0,8,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="Delete" Command="{Binding DeleteCommand}" IsEnabled="{Binding MutationEnabled}" Classes="action danger" Margin="0,0,0,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Focusable="False"/>
                        <Button Grid.Row="1" Grid.Column="0" Content="Save"   Command="{Binding SaveCommand}"   IsEnabled="{Binding SaveCancelEnabled}" Classes="action primary" Margin="0,0,8,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding SaveCancelEnabled}" Classes="action" Margin="0,0,8,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#DC2626" FontSize="13" TextWrapping="Wrap"
                               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <Separator Background="#E5E7EB" Height="1" Margin="0,8"/>

                    <StackPanel Spacing="14" IsEnabled="{Binding SaveCancelEnabled}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Username *" Classes="label"/>
                            <TextBox Text="{Binding Username}" PlaceholderText="Login username"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Full Name" Classes="label"/>
                            <TextBox Text="{Binding FullName}" PlaceholderText="Display name"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Role" Classes="label"/>
                            <ComboBox ItemsSource="{Binding RoleOptions}"
                                      SelectedItem="{Binding Role}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Password" Classes="label"/>
                            <TextBox Text="{Binding Password}"
                                     PasswordChar="●" PlaceholderText="{Binding PasswordWatermark}"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Confirm Password" Classes="label"/>
                            <TextBox Text="{Binding ConfirmPassword}"
                                     PasswordChar="●" PlaceholderText="Re-enter password"/>
                        </StackPanel>
                        <CheckBox Content="Active" IsChecked="{Binding IsActive}" Foreground="#1F2937" FontSize="14" FontWeight="Medium"/>
                    </StackPanel>
                  </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right: Users List -->
            <Border Grid.Column="1" Padding="24">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="All Users" Foreground="#1F2937" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>
                    <DataGrid ItemsSource="{Binding Users}"
                               SelectedItem="{Binding SelectedUser}"
                               AutoGenerateColumns="False" IsReadOnly="True"
                               SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Username"  Binding="{Binding Username}"    Width="*"/>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}"    Width="*"/>
                            <DataGridTextColumn Header="Role"      Binding="{Binding Role}"        Width="140"/>
                            <DataGridTextColumn Header="Active"    Binding="{Binding IsActive}"    Width="80"/>
                            <DataGridTextColumn Header="Created"   Binding="{Binding CreatedAt, StringFormat=\{0:yyyy-MM-dd\}}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" Padding="24,8" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#6B7280" FontSize="12"/>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.action">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.action.primary">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.action.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.action.danger">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.action.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#B91C1C"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
    </UserControl.Styles>
</UserControl>

