<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Users"
             xmlns:comp="using:ClinicSystem.UI.Views.Components"
             x:Class="ClinicSystem.UI.Views.Users.UserRegistryView"
             x:DataType="vm:UserRegistryViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <Grid>
        <!-- ============================================================ -->
        <!-- 1. LIST/GRID VIEW (SaveCancelEnabled is false)                -->
        <!-- ============================================================ -->
        <Grid IsVisible="{Binding !SaveCancelEnabled}" RowDefinitions="Auto,Auto,*">
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushPrimaryBlue50}">
                            <PathIcon Data="{StaticResource IconUsers}" Width="20" Height="20"
                                      Foreground="{DynamicResource BrushPrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="User Registry" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Manage user accounts, roles, access levels, and credentials"
                                       FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="+ Add User" Command="{Binding NewCommand}"
                            Classes="btn-primary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Summary Cards Row -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Margin="28,16,28,4">
                <comp:SummaryCardControl Grid.Column="0" Margin="0,0,12,0"
                    Title="Total Users"
                    Value="{Binding TotalUsersCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushPrimaryBlue}"/>
                <comp:SummaryCardControl Grid.Column="1" Margin="0,0,12,0"
                    Title="Active Accounts"
                    Value="{Binding ActiveUsersCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushTeal}"/>
                <comp:SummaryCardControl Grid.Column="2" Margin="0,0,12,0"
                    Title="Doctors"
                    Value="{Binding DoctorCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushAmber}"/>
                <comp:SummaryCardControl Grid.Column="3"
                    Title="Administrators"
                    Value="{Binding AdminCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushRose}"/>
            </Grid>

            <!-- Data Panel -->
            <Grid Grid.Row="2" Margin="28,12,28,24">
                <comp:DataTableShellControl Title="Registered Users" RecordCount="{Binding Users.Count}">
                    <comp:DataTableShellControl.FilterToolbar>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Content="Edit User" Command="{Binding EditCommand}"
                                    IsEnabled="{Binding SelectedUser, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Classes="btn-secondary"/>
                            <Button Content="Delete Account" Command="{Binding DeleteCommand}"
                                    IsEnabled="{Binding SelectedUser, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Classes="btn-danger"/>
                        </StackPanel>
                    </comp:DataTableShellControl.FilterToolbar>
                    <comp:DataTableShellControl.TableContent>
                        <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" Background="Transparent" BorderThickness="0"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="USERNAME" Binding="{Binding Username}" Width="*"/>
                                <DataGridTextColumn Header="FULL NAME" Binding="{Binding FullName}" Width="*"/>
                                <DataGridTextColumn Header="ROLE" Binding="{Binding Role}" Width="160"/>
                                <DataGridCheckBoxColumn Header="ACTIVE" Binding="{Binding IsActive}" Width="100"/>
                                <DataGridTextColumn Header="CREATED DATE" Binding="{Binding CreatedAt, StringFormat=\{0:dd MMM yyyy\}}" Width="160"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </comp:DataTableShellControl.TableContent>
                </comp:DataTableShellControl>
            </Grid>
        </Grid>

        <!-- ============================================================ -->
        <!-- 2. FORM VIEW (SaveCancelEnabled is true)                       -->
        <!-- ============================================================ -->
        <Grid IsVisible="{Binding SaveCancelEnabled}" RowDefinitions="Auto,*,Auto">
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushPrimaryBlue50}">
                            <PathIcon Data="{StaticResource IconUsers}" Width="20" Height="20"
                                      Foreground="{DynamicResource BrushPrimaryBlue}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="{Binding Mode, StringFormat='{}{0} User Account'}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}" FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Enter login credentials and choose system role" FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="← Back to Users" Command="{Binding CancelCommand}"
                            Classes="btn-secondary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Scrollable Form Body -->
            <ScrollViewer Grid.Row="1" Padding="28,24">
                <StackPanel Spacing="24" MaxWidth="700" HorizontalAlignment="Left">
                    <StackPanel Spacing="16">
                        <TextBlock Text="USER DETAILS" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk400}" LetterSpacing="1.5"
                                   FontFamily="{DynamicResource FontLexend}"/>
                        <Separator/>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                            <StackPanel Grid.Column="0" Grid.Row="0" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="Username *" Classes="label"/>
                                <TextBox Text="{Binding Username}" PlaceholderText="Enter login username"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="0" Spacing="6" Margin="12,0,0,12">
                                <TextBlock Text="Display Name" Classes="label"/>
                                <TextBox Text="{Binding FullName}" PlaceholderText="Enter user display name"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="1" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="System Role *" Classes="label"/>
                                <ComboBox ItemsSource="{Binding RoleOptions}" SelectedItem="{Binding Role}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Spacing="6" Margin="12,0,0,12" VerticalAlignment="Center">
                                <CheckBox Content="Account Active" IsChecked="{Binding IsActive}" Foreground="{DynamicResource BrushInk800}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="16">
                        <TextBlock Text="SECURITY CREDENTIALS" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk400}" LetterSpacing="1.5"
                                   FontFamily="{DynamicResource FontLexend}"/>
                        <Separator/>
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,12,0">
                                <TextBlock Text="Password" Classes="label"/>
                                <TextBox Text="{Binding Password}" PasswordChar="●" PlaceholderText="{Binding PasswordWatermark}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6" Margin="12,0,0,0">
                                <TextBlock Text="Confirm Password" Classes="label"/>
                                <TextBox Text="{Binding ConfirmPassword}" PasswordChar="●" PlaceholderText="Re-enter password to confirm"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,1,0,0" Padding="28,16">
                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushRose}"
                               VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="btn-ghost"/>
                        <Button Content="Save User" Command="{Binding SaveCommand}" Classes="btn-primary"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource BrushPrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk600}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="{DynamicResource BrushRose}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#BE123C"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.40"/>
        </Style>
    </UserControl.Styles>
</UserControl>
