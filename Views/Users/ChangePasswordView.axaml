<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Users"
             x:Class="ClinicSystem.UI.Views.Users.ChangePasswordView"
             x:DataType="vm:ChangePasswordViewModel"
             Background="Transparent">

    <!-- Modal overlay backdrop -->
    <Border Background="rgba(17,24,39,0.55)">
        <Border Background="#FFFFFF" CornerRadius="16"
                Width="440"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                BoxShadow="0 20 60 -10 rgba(0,0,0,0.35)"
                Padding="0">

            <!-- Card content -->
            <StackPanel Spacing="0">

                <!-- Header -->
                <Border Background="#1E3A5F" CornerRadius="16,16,0,0" Padding="28,22">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Border Width="36" Height="36" CornerRadius="18" Background="rgba(255,255,255,0.15)">
                                <materialIcons:MaterialIcon Kind="AccountCog" Width="16" Height="16"
                                          Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Change Password" FontSize="17" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Keep your account secure" FontSize="12" Foreground="rgba(255,255,255,0.6)"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CancelCommand}"
                                Background="rgba(255,255,255,0.1)" BorderThickness="0"
                                Width="32" Height="32" CornerRadius="16" Padding="0">
                            <materialIcons:MaterialIcon Kind="Close" Width="12" Height="12" Foreground="White"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Form Body -->
                <StackPanel Spacing="20" Margin="28,24,28,0">

                    <StackPanel Spacing="6">
                        <TextBlock Text="Current Password" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                        <TextBox Text="{Binding CurrentPassword}"
                                 PasswordChar="●"
                                 PlaceholderText="Enter current password"
                                 IsEnabled="{Binding !IsBusy}"/>
                    </StackPanel>

                    <Border Height="1" Background="#F3F4F6"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="New Password" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                        <TextBox Text="{Binding NewPassword}"
                                 PasswordChar="●"
                                 PlaceholderText="At least 8 characters"
                                 IsEnabled="{Binding !IsBusy}"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Confirm New Password" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                        <TextBox Text="{Binding ConfirmPassword}"
                                 PasswordChar="●"
                                 PlaceholderText="Re-enter new password"
                                 IsEnabled="{Binding !IsBusy}"/>
                    </StackPanel>

                    <!-- Status Message -->
                    <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            CornerRadius="8" Padding="14,10"
                            Classes.success="{Binding IsSuccess}">
                        <Border.Styles>
                            <Style Selector="Border">
                                <Setter Property="Background" Value="#FEF2F2"/>
                            </Style>
                            <Style Selector="Border.success">
                                <Setter Property="Background" Value="#F0FDF4"/>
                            </Style>
                            <Style Selector="TextBlock">
                                <Setter Property="Foreground" Value="#991B1B"/>
                            </Style>
                            <Style Selector="TextBlock.success">
                                <Setter Property="Foreground" Value="#166534"/>
                            </Style>
                            <Style Selector="PathIcon">
                                <Setter Property="Foreground" Value="#DC2626"/>
                            </Style>
                            <Style Selector="PathIcon.success">
                                <Setter Property="Foreground" Value="#16A34A"/>
                            </Style>
                        </Border.Styles>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <materialIcons:MaterialIcon Kind="Alert" Width="14" Height="14"
                                      Classes.success="{Binding IsSuccess}"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Classes.success="{Binding IsSuccess}"
                                       FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*,*" Margin="28,20,28,28">
                    <Button Grid.Column="0"  Command="{Binding CancelCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Margin="0,0,8,0" IsEnabled="{Binding !IsBusy}">
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <materialIcons:MaterialIcon Kind="Close" Width="18" Height="18"/>
        <TextBlock Text="Cancel" VerticalAlignment="Center"/>
    </StackPanel>
</Button>
                    <Button Grid.Column="1" Command="{Binding ChangePasswordCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Margin="8,0,0,0" IsEnabled="{Binding !IsBusy}"
                            Classes="primary">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconBackup}" Width="13" Height="13"
                                      Foreground="White" VerticalAlignment="Center"
                                      IsVisible="{Binding !IsBusy}"/>
                            <ProgressBar IsIndeterminate="True" Width="13" Height="13"
                                         IsVisible="{Binding IsBusy}" VerticalAlignment="Center"/>
                            <TextBlock Text="Update Password" IsVisible="{Binding !IsBusy}" VerticalAlignment="Center"/>
                            <TextBlock Text="Saving..." IsVisible="{Binding IsBusy}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </StackPanel>
        </Border>
    </Border>

</UserControl>
