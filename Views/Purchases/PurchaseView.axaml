<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Purchases"
             x:Class="ClinicSystem.UI.Views.Purchases.PurchaseView"
             x:DataType="vm:PurchaseViewModel"
             Background="#F8FAFC">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="24,16"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource IconPurchases}" Width="20" Height="20" Foreground="#2563EB"/>
                    <TextBlock Text="Purchase Invoices" FontSize="20" FontWeight="Bold"
                               Foreground="#1F2937" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}"
                           Foreground="#2563EB" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" ColumnDefinitions="380,*" Margin="24">

            <!-- Form Side (Header & Line Items input) -->
            <Border Grid.Column="0" Classes="card">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Purchase Invoice" Classes="sectionTitle" Margin="0,0,0,16"/>

                    <StackPanel DockPanel.Dock="Bottom" Spacing="12" Margin="0,16,0,0">
                        <!-- Grand Total Display -->
                        <Border Background="#F8FAFC" Padding="16" CornerRadius="8"
                                BorderBrush="#E5E7EB" BorderThickness="1">
                            <DockPanel>
                                <TextBlock Text="Grand Total:" FontSize="15" FontWeight="SemiBold"
                                           Foreground="#4B5563" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding GrandTotal, StringFormat=C2}" FontSize="24"
                                           FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Right"/>
                            </DockPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,*">
                            <Button Grid.Column="0" Content="Save Invoice" Command="{Binding SaveCommand}"
                                    IsEnabled="{Binding SaveCancelEnabled}"
                                    Classes="success" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" Margin="0,0,6,0" Padding="10"/>
                            <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}"
                                    IsEnabled="{Binding SaveCancelEnabled}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" Margin="6,0,0,0" Padding="10"/>
                        </Grid>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#DC2626" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer IsEnabled="{Binding SaveCancelEnabled}">
                        <StackPanel Spacing="16">

                            <!-- Header Section -->
                            <TextBlock Text="INVOICE HEADER" Classes="label" Foreground="#9CA3AF"
                                       FontSize="10" FontWeight="Bold" LetterSpacing="1.5"/>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                                    <TextBlock Text="Invoice Number" Classes="label"/>
                                    <TextBox Text="{Binding InvoiceNumber}" PlaceholderText="INV-001"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Date" Classes="label"/>
                                    <DatePicker SelectedDate="{Binding PurchaseDate}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Supplier" Classes="label"/>
                                <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <Border Height="1" Background="#E5E7EB" Margin="0,4"/>

                            <!-- Add Item Section -->
                            <TextBlock Text="ADD LINE ITEM" Classes="label" Foreground="#9CA3AF"
                                       FontSize="10" FontWeight="Bold" LetterSpacing="1.5"/>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Product" Classes="label"/>
                                <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                                    <TextBlock Text="Batch Number" Classes="label"/>
                                    <TextBox Text="{Binding BatchNumber}" PlaceholderText="Batch No."/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Expiry Date" Classes="label"/>
                                    <DatePicker SelectedDate="{Binding ExpiryDate}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*,*">
                                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                                    <TextBlock Text="Quantity" Classes="label"/>
                                    <NumericUpDown Value="{Binding Quantity}" Minimum="1" FormatString="N0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2" Margin="0,0,8,0">
                                    <TextBlock Text="Price" Classes="label"/>
                                    <NumericUpDown Value="{Binding PurchasePrice}" FormatString="N2"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Text="Discount" Classes="label"/>
                                    <NumericUpDown Value="{Binding Discount}" FormatString="N2"/>
                                </StackPanel>
                            </Grid>

                            <Button Command="{Binding AddLineItemCommand}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconPlus}" Width="14" Height="14" Foreground="#1F2937" VerticalAlignment="Center"/>
                                    <TextBlock Text="Add Item" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Grid Side -->
            <Border Grid.Column="1" Classes="card" Margin="24,0,0,0">
                <DockPanel>
                    <!-- Toolbar -->
                    <Border DockPanel.Dock="Top" Padding="0,0,0,16"
                            BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding NewCommand}"
                                    IsEnabled="{Binding MutationEnabled}" Classes="primary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconPlus}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="New Purchase" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ViewDetailsCommand}"
                                    IsEnabled="{Binding MutationEnabled}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconEye}" Width="14" Height="14" Foreground="#1F2937" VerticalAlignment="Center"/>
                                    <TextBlock Text="View Details" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Display Area based on mode -->
                    <Panel>
                        <!-- List of Purchases (View Mode) -->
                        <DataGrid ItemsSource="{Binding Purchases}" SelectedItem="{Binding SelectedPurchase}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  IsVisible="{Binding MutationEnabled}"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Invoice No"    Binding="{Binding InvoiceNumber}"                                  Width="130"/>
                                <DataGridTextColumn Header="Date"          Binding="{Binding PurchaseDate, StringFormat=\{0:MM/dd/yyyy\}}"      Width="110"/>
                                <DataGridTextColumn Header="Supplier"      Binding="{Binding SupplierName}"                                    Width="*"/>
                                <DataGridTextColumn Header="Total Amount"  Binding="{Binding TotalAmount, StringFormat=C2}"                    Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Line Items (Add/Edit/Detail Mode) -->
                        <DockPanel IsVisible="{Binding SaveCancelEnabled}">
                            <TextBlock DockPanel.Dock="Top" Text="INVOICE LINE ITEMS" Classes="label"
                                       Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"
                                       LetterSpacing="1.5" Margin="0,0,0,12"/>
                            <DataGrid ItemsSource="{Binding LineItems}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="Transparent" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Product" Binding="{Binding ProductName}"                              Width="*"/>
                                    <DataGridTextColumn Header="Batch"   Binding="{Binding BatchNumber}"                              Width="100"/>
                                    <DataGridTextColumn Header="Exp"     Binding="{Binding ExpiryDate, StringFormat=\{0:MM/yy\}}"     Width="80"/>
                                    <DataGridTextColumn Header="Qty"     Binding="{Binding Quantity}"                                 Width="60"/>
                                    <DataGridTextColumn Header="Price"   Binding="{Binding PurchasePrice, StringFormat=N2}"           Width="90"/>
                                    <DataGridTextColumn Header="Total"   Binding="{Binding LineNetTotal, StringFormat=C2}"            Width="100"/>

                                    <DataGridTemplateColumn Width="50">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding $parent[UserControl].((vm:PurchaseViewModel)DataContext).RemoveLineItemCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0"
                                                        Padding="5" Cursor="Hand"
                                                        Height="32" Width="32" HorizontalAlignment="Center">
                                                    <PathIcon Data="{StaticResource IconClose}" Width="12" Height="12" Foreground="#DC2626"/>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Panel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#FFFFFF" Padding="24,8"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#6B7280" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
