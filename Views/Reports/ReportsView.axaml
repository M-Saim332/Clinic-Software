<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Reports"
             x:Class="ClinicSystem.UI.Views.Reports.ReportsView"
             x:DataType="vm:ReportsViewModel" x:CompileBindings="True"
             Background="#F8FAFC">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="24,16" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource IconReports}" Width="20" Height="20" Foreground="#2563EB"/>
                    <TextBlock Text="Reports" FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
                </StackPanel>
                
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    Background="#F8FAFC"
                    Margin="12">

            <!-- Tab 1: Patient List -->
            <TabItem Header="Patient List">
                <DockPanel Margin="12">
                    <Button DockPanel.Dock="Top" Command="{Binding LoadPatientListCommand}" Classes="primary" HorizontalAlignment="Left" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <DataGrid ItemsSource="{Binding PatientList}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"      Binding="{Binding PatientID}" Width="60"/>
                            <DataGridTextColumn Header="Name"    Binding="{Binding Name}"      Width="*"/>
                            <DataGridTextColumn Header="Age"     Binding="{Binding Age}"       Width="80"/>
                            <DataGridTextColumn Header="Gender"  Binding="{Binding Gender}"    Width="100"/>
                            <DataGridTextColumn Header="Contact" Binding="{Binding Contact}"   Width="140"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}"   Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Tab 2: Medicine Stock -->
            <TabItem Header="Medicine Stock">
                <DockPanel Margin="12">
                    <Button DockPanel.Dock="Top" Command="{Binding LoadMedicineStockCommand}" Classes="primary" HorizontalAlignment="Left" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <DataGrid ItemsSource="{Binding MedicineStockList}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"         Binding="{Binding Name}"         Width="*"/>
                            <DataGridTextColumn Header="Stock"        Binding="{Binding Stock}"        Width="90"/>
                            <DataGridTextColumn Header="Min Stock"    Binding="{Binding MinStock}"     Width="100"/>
                            <DataGridTextColumn Header="Status"       Binding="{Binding StockStatus}"  Width="100"/>
                            <DataGridTextColumn Header="Expiry"       Binding="{Binding ExpiryDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="120"/>
                            <DataGridTextColumn Header="Price"        Binding="{Binding Price, StringFormat=\{0:F2\}}" Width="100"/>
                            <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Tab 3: Expired/Low Stock -->
            <TabItem Header="Alerts">
                <DockPanel Margin="12">
                    <Button DockPanel.Dock="Top" Command="{Binding LoadExpiredLowStockCommand}" Classes="primary" HorizontalAlignment="Left" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,*" RowDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Expired Medicines" Foreground="#DC2626" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <TextBlock Grid.Column="1" Grid.Row="0" Text="Low Stock Medicines" Foreground="#F59E0B" FontWeight="Bold" FontSize="14" Margin="20,0,0,10"/>
                        <DataGrid Grid.Column="0" Grid.Row="1"
                                  ItemsSource="{Binding ExpiredMedicines}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Margin="0,0,12,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"   Binding="{Binding Name}"       Width="*"/>
                                <DataGridTextColumn Header="Stock"  Binding="{Binding Stock}"      Width="80"/>
                                <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <DataGrid Grid.Column="1" Grid.Row="1"
                                  ItemsSource="{Binding LowStockMedicines}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Margin="12,0,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"      Binding="{Binding Name}"     Width="*"/>
                                <DataGridTextColumn Header="Stock"     Binding="{Binding Stock}"    Width="80"/>
                                <DataGridTextColumn Header="Min Stock" Binding="{Binding MinStock}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- Tab 4: All Visits -->
            <TabItem Header="Visit History">
                <DockPanel Margin="12">
                    <Button DockPanel.Dock="Top" Command="{Binding LoadAllVisitsCommand}" Classes="primary" HorizontalAlignment="Left" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <DataGrid ItemsSource="{Binding AllVisits}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date"      Binding="{Binding VisitDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="120"/>
                            <DataGridTextColumn Header="Patient"   Binding="{Binding PatientName}" Width="*"/>
                            <DataGridTextColumn Header="Doctor"    Binding="{Binding DoctorName}"  Width="160"/>
                            <DataGridTextColumn Header="Diagnosis" Binding="{Binding Diagnosis}"   Width="*"/>
                            <DataGridTextColumn Header="Notes"     Binding="{Binding Notes}"       Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Tab 5: Financials -->
            <TabItem Header="Financials">
                <DockPanel Margin="12">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                        <Button Command="{Binding LoadFinancialsCommand}" Classes="primary">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DownloadWeeklyReportCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconReports}" Width="14" Height="14" Foreground="#1F2937" VerticalAlignment="Center"/>
                                <TextBlock Text="Download Weekly" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DownloadMonthlyReportCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconReports}" Width="14" Height="14" Foreground="#1F2937" VerticalAlignment="Center"/>
                                <TextBlock Text="Download Monthly" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Spacing="20" HorizontalAlignment="Left">
                        <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Width="300" Padding="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Total Revenue" Foreground="#6B7280" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="{Binding TotalRevenue, StringFormat=C2}" Foreground="#16A34A" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Width="300" Padding="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Total Expenses (Purchases)" Foreground="#6B7280" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="{Binding TotalExpenses, StringFormat=C2}" Foreground="#DC2626" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Width="300" Padding="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Net Profit" Foreground="#6B7280" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="{Binding NetProfit, StringFormat=C2}" Foreground="#2563EB" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#FFFFFF" Padding="24,8" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#6B7280" FontSize="12" VerticalAlignment="Center"/>
                <ProgressBar IsVisible="{Binding IsBusy}" IsIndeterminate="True" Width="100" Height="4" Foreground="#2563EB" Background="#E5E7EB" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

