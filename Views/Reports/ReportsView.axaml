<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Reports"
             xmlns:comp="using:ClinicSystem.UI.Views.Components"
             x:Class="ClinicSystem.UI.Views.Reports.ReportsView"
             x:DataType="vm:ReportsViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Padding="28,18">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushPrimaryBlue50}">
                        <PathIcon Data="{StaticResource IconReports}" Width="20" Height="20"
                                  Foreground="{DynamicResource BrushPrimaryBlue}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="Reports &amp; Analytics" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk900}"
                                   FontFamily="{DynamicResource FontLexend}"/>
                        <TextBlock Text="Generate PDF summaries, check stocks, alerts, visit history, and financials"
                                   FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" Margin="28,20">
            <!-- Tab 1: Patient List -->
            <TabItem Header="Patient List">
                <comp:DataTableShellControl Title="Patients Database Summary" RecordCount="{Binding PatientList.Count}">
                    <comp:DataTableShellControl.FilterToolbar>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding LoadPatientListCommand}" Classes="btn-secondary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" Foreground="{DynamicResource BrushInk600}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Refresh Data" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ExportPatientListToPdfCommand}" Classes="btn-secondary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconReports}" Width="14" Height="14" Foreground="{DynamicResource BrushInk600}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Export PDF" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ExportPatientListToExcelCommand}" Classes="btn-secondary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconReports}" Width="14" Height="14" Foreground="{DynamicResource BrushInk600}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Export Excel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </comp:DataTableShellControl.FilterToolbar>
                    <comp:DataTableShellControl.TableContent>
                        <DataGrid ItemsSource="{Binding PatientList}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding PatientID}" Width="70"/>
                                <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="AGE" Binding="{Binding Age}" Width="90"/>
                                <DataGridTextColumn Header="GENDER" Binding="{Binding Gender}" Width="110"/>
                                <DataGridTextColumn Header="CONTACT" Binding="{Binding Contact}" Width="150"/>
                                <DataGridTextColumn Header="ADDRESS" Binding="{Binding Address}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </comp:DataTableShellControl.TableContent>
                </comp:DataTableShellControl>
            </TabItem>

            <!-- Tab 2: Product Stock -->
            <TabItem Header="Product Stock">
                <comp:DataTableShellControl Title="Stock Level Listing" RecordCount="{Binding ProductStockList.Count}">
                    <comp:DataTableShellControl.FilterToolbar>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding LoadProductStockCommand}" Classes="btn-secondary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" Foreground="{DynamicResource BrushInk600}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Refresh Data" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ExportProductStockToPdfCommand}" Classes="btn-secondary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconReports}" Width="14" Height="14" Foreground="{DynamicResource BrushInk600}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Export PDF" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ExportProductStockToExcelCommand}" Classes="btn-secondary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconReports}" Width="14" Height="14" Foreground="{DynamicResource BrushInk600}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Export Excel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </comp:DataTableShellControl.FilterToolbar>
                    <comp:DataTableShellControl.TableContent>
                        <DataGrid ItemsSource="{Binding ProductStockList}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PRODUCT NAME" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="CURRENT STOCK" Binding="{Binding Stock}" Width="140"/>
                                <DataGridTextColumn Header="MINIMUM LEVEL" Binding="{Binding MinStock}" Width="140"/>
                                <DataGridTextColumn Header="STATUS" Binding="{Binding StockStatus}" Width="130"/>
                                <DataGridTextColumn Header="EXPIRY" Binding="{Binding ExpiryDate, StringFormat=\{0:dd MMM yyyy\}}" Width="130"/>
                                <DataGridTextColumn Header="PRICE" Binding="{Binding Price, StringFormat='Rs. {0:N2}'}" Width="110"/>
                                <DataGridTextColumn Header="MANUFACTURER" Binding="{Binding Manufacturer}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </comp:DataTableShellControl.TableContent>
                </comp:DataTableShellControl>
            </TabItem>

            <!-- Tab 3: Alerts -->
            <TabItem Header="Alerts">
                <Grid ColumnDefinitions="*,*" Margin="0,12,0,0">
                    <!-- Expired products panel -->
                    <Border Grid.Column="0" Background="{DynamicResource BrushCardBackground}"
                            BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                            CornerRadius="{DynamicResource CornerRadiusCard}" Margin="0,0,12,0" Padding="16">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="EXPIRED PRODUCTS (DO NOT SELL)" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushRose}" LetterSpacing="1.5"
                                       FontFamily="{DynamicResource FontLexend}" Margin="0,0,0,12"/>
                            <DataGrid ItemsSource="{Binding ExpiredProducts}" AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="STOCK" Binding="{Binding Stock}" Width="90"/>
                                    <DataGridTextColumn Header="EXPIRY DATE" Binding="{Binding ExpiryDate, StringFormat=\{0:dd MMM yyyy\}}" Width="145"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- Low Stock products panel -->
                    <Border Grid.Column="1" Background="{DynamicResource BrushCardBackground}"
                            BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                            CornerRadius="{DynamicResource CornerRadiusCard}" Margin="12,0,0,0" Padding="16">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="LOW STOCK ALERTS (REORDER SOON)" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushAmber}" LetterSpacing="1.5"
                                       FontFamily="{DynamicResource FontLexend}" Margin="0,0,0,12"/>
                            <DataGrid ItemsSource="{Binding LowStockProducts}" AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="STOCK" Binding="{Binding Stock}" Width="90"/>
                                    <DataGridTextColumn Header="MINIMUM REQUIRED" Binding="{Binding MinStock}" Width="160"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 4: Visit History -->
            <TabItem Header="Visit History">
                <comp:DataTableShellControl Title="Patient Consultations &amp; Visits" RecordCount="{Binding AllVisits.Count}">
                    <comp:DataTableShellControl.FilterToolbar>
                        <Button Command="{Binding LoadAllVisitsCommand}" Classes="btn-secondary" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" Foreground="{DynamicResource BrushInk600}" VerticalAlignment="Center"/>
                                <TextBlock Text="Refresh Data" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </comp:DataTableShellControl.FilterToolbar>
                    <comp:DataTableShellControl.TableContent>
                        <DataGrid ItemsSource="{Binding AllVisits}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="DATE" Binding="{Binding VisitDate, StringFormat=\{0:dd MMM yyyy\}}" Width="130"/>
                                <DataGridTextColumn Header="PATIENT" Binding="{Binding PatientName}" Width="*"/>
                                <DataGridTextColumn Header="DOCTOR" Binding="{Binding DoctorName}" Width="160"/>
                                <DataGridTextColumn Header="DIAGNOSIS" Binding="{Binding Diagnosis}" Width="*"/>
                                <DataGridTextColumn Header="NOTES" Binding="{Binding Notes}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </comp:DataTableShellControl.TableContent>
                </comp:DataTableShellControl>
            </TabItem>

            <!-- Tab 5: Financials -->
            <TabItem Header="Financials">
                <DockPanel Margin="0,12,0,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="12" Margin="0,0,0,24">
                        <Button Command="{Binding LoadFinancialsCommand}" Classes="btn-secondary">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconClock}" Width="14" Height="14" Foreground="{DynamicResource BrushInk600}" VerticalAlignment="Center"/>
                                <TextBlock Text="Refresh Data" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DownloadWeeklyReportCommand}" Classes="btn-secondary">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconReports}" Width="14" Height="14" Foreground="{DynamicResource BrushInk600}" VerticalAlignment="Center"/>
                                <TextBlock Text="Download Weekly PDF" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DownloadMonthlyReportCommand}" Classes="btn-secondary">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconReports}" Width="14" Height="14" Foreground="{DynamicResource BrushInk600}" VerticalAlignment="Center"/>
                                <TextBlock Text="Download Monthly PDF" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportFinancialsToExcelCommand}" Classes="btn-secondary">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconReports}" Width="14" Height="14" Foreground="{DynamicResource BrushInk600}" VerticalAlignment="Center"/>
                                <TextBlock Text="Export to Excel" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Financial Summary cards in full-page swap layout style -->
                    <StackPanel Spacing="20" HorizontalAlignment="Left">
                        <comp:SummaryCardControl Title="Total Revenue" Value="{Binding TotalRevenue, StringFormat='Rs. {0:N2}'}" BorderColor="{DynamicResource BrushTeal}" Width="380"/>
                        <comp:SummaryCardControl Title="Total Expenses (Purchases)" Value="{Binding TotalExpenses, StringFormat='Rs. {0:N2}'}" BorderColor="{DynamicResource BrushRose}" Width="380"/>
                        <comp:SummaryCardControl Title="Net Profit" Value="{Binding NetProfit, StringFormat='Rs. {0:N2}'}" BorderColor="{DynamicResource BrushPrimaryBlue}" Width="380"/>
                    </StackPanel>
                </DockPanel>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource BrushCardBackground}"
                BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,1,0,0" Padding="28,16">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushInk600}"
                           VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
                <ProgressBar IsVisible="{Binding IsBusy}" IsIndeterminate="True" Width="100" Height="4"
                             Foreground="{DynamicResource BrushPrimaryBlue}" Background="{DynamicResource BrushLine}"
                             DockPanel.Dock="Right" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </UserControl.Styles>
</UserControl>
