<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Reports"
             x:Class="ClinicSystem.UI.Views.Reports.ReportsView"
             x:DataType="vm:ReportsViewModel"
             Background="#0F1117">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Background="#1A1D27" Padding="20,14" BorderBrush="#2A2D3A" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="📊 Reports" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}" Foreground="#0097A7" VerticalAlignment="Center" FontSize="13"/>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    Background="#0F1117">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Foreground" Value="#888"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="16,10"/>
                </Style>
                <Style Selector="TabItem:selected">
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </TabControl.Styles>

            <!-- Tab 1: Patient List -->
            <TabItem Header="👥 Patient List">
                <DockPanel Margin="20">
                    <Button DockPanel.Dock="Top" Content="🔄 Refresh" Command="{Binding LoadPatientListCommand}"
                            Background="#0097A7" Foreground="White" CornerRadius="6" Padding="12,7"
                            HorizontalAlignment="Left" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding PatientList}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="#141720" RowBackground="#141720"
                              Foreground="White" GridLinesVisibility="Horizontal"
                              BorderBrush="#2A2D3A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"      Binding="{Binding PatientID}" Width="50"/>
                            <DataGridTextColumn Header="Name"    Binding="{Binding Name}"      Width="*"/>
                            <DataGridTextColumn Header="Age"     Binding="{Binding Age}"       Width="60"/>
                            <DataGridTextColumn Header="Gender"  Binding="{Binding Gender}"    Width="80"/>
                            <DataGridTextColumn Header="Contact" Binding="{Binding Contact}"   Width="130"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}"   Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Tab 2: Medicine Stock -->
            <TabItem Header="💊 Medicine Stock">
                <DockPanel Margin="20">
                    <Button DockPanel.Dock="Top" Content="🔄 Refresh" Command="{Binding LoadMedicineStockCommand}"
                            Background="#0097A7" Foreground="White" CornerRadius="6" Padding="12,7"
                            HorizontalAlignment="Left" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding MedicineStockList}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="#141720" RowBackground="#141720"
                              Foreground="White" GridLinesVisibility="Horizontal"
                              BorderBrush="#2A2D3A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"         Binding="{Binding Name}"         Width="*"/>
                            <DataGridTextColumn Header="Stock"        Binding="{Binding Stock}"        Width="70"/>
                            <DataGridTextColumn Header="Min Stock"    Binding="{Binding MinStock}"     Width="80"/>
                            <DataGridTextColumn Header="Status"       Binding="{Binding StockStatus}"  Width="80"/>
                            <DataGridTextColumn Header="Expiry"       Binding="{Binding ExpiryDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="110"/>
                            <DataGridTextColumn Header="Price"        Binding="{Binding Price, StringFormat=\{0:F2\}}" Width="80"/>
                            <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Tab 3: Expired/Low Stock -->
            <TabItem Header="⚠️ Alerts">
                <DockPanel Margin="20">
                    <Button DockPanel.Dock="Top" Content="🔄 Refresh" Command="{Binding LoadExpiredLowStockCommand}"
                            Background="#0097A7" Foreground="White" CornerRadius="6" Padding="12,7"
                            HorizontalAlignment="Left" Margin="0,0,0,16"/>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,*" RowDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Grid.Row="0" Text="🔴 Expired Medicines" Foreground="#FF5252" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock Grid.Column="1" Grid.Row="0" Text="🟡 Low Stock Medicines" Foreground="#FFD600" FontWeight="Bold" FontSize="14" Margin="20,0,0,8"/>
                        <DataGrid Grid.Column="0" Grid.Row="1"
                                  ItemsSource="{Binding ExpiredMedicines}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="#141720" RowBackground="#141720"
                                  Foreground="White" GridLinesVisibility="Horizontal"
                                  BorderBrush="#2A2D3A" Margin="0,0,10,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"   Binding="{Binding Name}"       Width="*"/>
                                <DataGridTextColumn Header="Stock"  Binding="{Binding Stock}"      Width="60"/>
                                <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <DataGrid Grid.Column="1" Grid.Row="1"
                                  ItemsSource="{Binding LowStockMedicines}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="#141720" RowBackground="#141720"
                                  Foreground="White" GridLinesVisibility="Horizontal"
                                  BorderBrush="#2A2D3A" Margin="10,0,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"      Binding="{Binding Name}"     Width="*"/>
                                <DataGridTextColumn Header="Stock"     Binding="{Binding Stock}"    Width="60"/>
                                <DataGridTextColumn Header="Min Stock" Binding="{Binding MinStock}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- Tab 4: All Visits -->
            <TabItem Header="📅 Visit History">
                <DockPanel Margin="20">
                    <Button DockPanel.Dock="Top" Content="🔄 Refresh" Command="{Binding LoadAllVisitsCommand}"
                            Background="#0097A7" Foreground="White" CornerRadius="6" Padding="12,7"
                            HorizontalAlignment="Left" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding AllVisits}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="#141720" RowBackground="#141720"
                              Foreground="White" GridLinesVisibility="Horizontal"
                              BorderBrush="#2A2D3A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date"      Binding="{Binding VisitDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="110"/>
                            <DataGridTextColumn Header="Patient"   Binding="{Binding PatientName}" Width="*"/>
                            <DataGridTextColumn Header="Doctor"    Binding="{Binding DoctorName}"  Width="150"/>
                            <DataGridTextColumn Header="Diagnosis" Binding="{Binding Diagnosis}"   Width="*"/>
                            <DataGridTextColumn Header="Notes"     Binding="{Binding Notes}"       Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#141720" Padding="16,8" BorderBrush="#2A2D3A" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                <ProgressBar IsVisible="{Binding IsBusy}" IsIndeterminate="True" Width="100" Height="6"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
