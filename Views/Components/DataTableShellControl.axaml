<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="ClinicSystem.UI.Views.Components.DataTableShellControl"
             x:Name="Root"
             x:CompileBindings="False">

    <Border Background="{DynamicResource BrushCardBackground}"
            BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
            CornerRadius="{DynamicResource CornerRadiusCard}" Padding="20"
            BoxShadow="0 1 3 0 #0D000000">
        <DockPanel>
            <!-- Top header of the panel: Title + Record Count Chip -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title, ElementName=Root}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushInk900}"/>
                    <Border Background="{DynamicResource BrushBlue50}" CornerRadius="{DynamicResource CornerRadiusPill}" Padding="8,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding RecordCount, ElementName=Root}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushPrimaryBlue}" FontFamily="{DynamicResource FontMono}"/>
                    </Border>
                </StackPanel>
                
                <!-- Slot for top-right toolbar actions -->
                <ContentControl Content="{Binding HeaderActions, ElementName=Root}" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Filter/Toolbar row -->
            <Border DockPanel.Dock="Top" Padding="0,0,0,16" BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1" Margin="0,0,0,16">
                <ContentControl Content="{Binding FilterToolbar, ElementName=Root}" VerticalAlignment="Center"/>
            </Border>

            <!-- Main table content (the DataGrid) -->
            <Panel>
                <ContentControl Content="{Binding TableContent, ElementName=Root}" IsVisible="{Binding !ShowEmptyState, ElementName=Root}"/>
                
                <!-- Empty State Overlay -->
                <StackPanel IsVisible="{Binding ShowEmptyState, ElementName=Root}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="0,40,0,40" Spacing="16">
                    <Border Width="64" Height="64" CornerRadius="32" Background="{DynamicResource BrushBackground}">
                        <materialIcons:MaterialIcon Kind="Magnify" Width="28" Height="28" Foreground="{DynamicResource BrushInk400}"/>
                    </Border>
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="No records found" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrushInk900}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Try adjusting your filters or adding new data." FontSize="13" Foreground="{DynamicResource BrushInk500}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Panel>
        </DockPanel>
    </Border>
</UserControl>
