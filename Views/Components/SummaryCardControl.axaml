<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="100"
             x:Class="ClinicSystem.UI.Views.Components.SummaryCardControl"
             x:Name="Root"
             x:CompileBindings="False">
  <Border Background="{DynamicResource BrushCardBackground}"
          BorderBrush="{DynamicResource BrushLine}"
          BorderThickness="1"
          CornerRadius="{DynamicResource CornerRadiusCard}"
          Padding="16,12"
          BoxShadow="0 1 3 0 #0D000000">
    <Grid RowDefinitions="Auto,Auto,*">
      <Border Grid.Row="0" Height="3" Background="{Binding BorderColor, ElementName=Root}"
              CornerRadius="1.5" Margin="0,0,0,10" VerticalAlignment="Top"/>
      <TextBlock Grid.Row="1" Text="{Binding Title, ElementName=Root}"
                 FontSize="13" FontWeight="Medium" Foreground="{DynamicResource BrushInk600}"
                 TextTrimming="CharacterEllipsis"/>
      <TextBlock Grid.Row="2" Text="{Binding Value, ElementName=Root}"
                 FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushInk900}"
                 FontFamily="{DynamicResource FontMono}" Margin="0,4,0,0"
                 TextTrimming="CharacterEllipsis"/>
    </Grid>
  </Border>
</UserControl>
