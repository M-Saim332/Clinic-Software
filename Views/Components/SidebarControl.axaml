<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ClinicSystem.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="224" d:DesignHeight="780"
             x:Class="ClinicSystem.UI.Views.Components.SidebarControl"
             x:DataType="vm:MainWindowViewModel"
             Width="224"
             Background="{DynamicResource BrushCardBackground}">
    <Border BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,1,0">
        <DockPanel>
            <!-- Logo / Brand -->
            <Border DockPanel.Dock="Top" Padding="20,24" BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource BrushBlue50}">
                        <PathIcon Data="{StaticResource IconClinic}" Width="18" Height="18"
                                  Foreground="{DynamicResource BrushPrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="Clinic" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushInk900}" FontFamily="{DynamicResource FontLexend}"/>
                        <TextBlock Text="Management" FontSize="11" Foreground="{DynamicResource BrushInk600}" FontFamily="{DynamicResource FontInter}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Logout at bottom -->
            <Border DockPanel.Dock="Bottom" Padding="16">
                <Button Command="{Binding LogoutCommand}" HorizontalAlignment="Stretch" Classes="navbtn">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <PathIcon Data="{StaticResource IconLogout}" Width="16" Height="16" Foreground="{DynamicResource BrushRose}" VerticalAlignment="Center"/>
                        <TextBlock Text="Logout" Foreground="{DynamicResource BrushRose}" VerticalAlignment="Center" FontWeight="Medium"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Logged-in user chip -->
            <Border DockPanel.Dock="Bottom" Padding="20,16" BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,1,0,0">
                <StackPanel Spacing="3">
                    <TextBlock Text="{Binding CurrentUserName}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrushInk900}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding CurrentUserRole}" FontSize="11" Foreground="{DynamicResource BrushInk600}"/>
                </StackPanel>
            </Border>

            <!-- Navigation -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="4" Margin="12,16">

                    <!-- MANAGEMENT SECTION -->
                    <TextBlock Text="MANAGEMENT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrushInk400}" Margin="8,4,0,8" LetterSpacing="1.5" FontFamily="{DynamicResource FontLexend}"/>

                    <Button Command="{Binding ShowPatientsCommand}" Classes="navbtn" Classes.active="{Binding IsPatientsActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconPatients}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Patients" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowAppointmentsCommand}" Classes="navbtn" Classes.active="{Binding IsAppointmentsActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconAppointments}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Appointments" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowMedicinesCommand}" Classes="navbtn" Classes.active="{Binding IsMedicinesActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconMedicines}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Medicines" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowProductsCommand}" Classes="navbtn" Classes.active="{Binding IsProductsActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconProducts}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Products" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowCompaniesCommand}" Classes="navbtn" Classes.active="{Binding IsCompaniesActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconCompanies}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Companies" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowSuppliersCommand}" Classes="navbtn" Classes.active="{Binding IsSuppliersActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconSuppliers}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Suppliers" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- TRANSACTIONS SECTION -->
                    <Border Height="1" Background="{DynamicResource BrushLine}" Margin="8,12"/>
                    <TextBlock Text="TRANSACTIONS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrushInk400}" Margin="8,0,0,8" LetterSpacing="1.5" FontFamily="{DynamicResource FontLexend}"/>

                    <Button Command="{Binding ShowPurchasesCommand}" Classes="navbtn" Classes.active="{Binding IsPurchasesActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconPurchases}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Purchases" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowSalesCommand}" Classes="navbtn" Classes.active="{Binding IsSalesActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconSales}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Sales &amp; Billing" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowReturnsCommand}" Classes="navbtn" Classes.active="{Binding IsReturnsActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconCart}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Returns" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowPrescriptionsCommand}" Classes="navbtn" Classes.active="{Binding IsPrescriptionsActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconVisit}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="New Visit" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowVisitHistoryCommand}" Classes="navbtn" Classes.active="{Binding IsVisitHistoryActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconClock}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Visit History" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- ANALYSIS SECTION -->
                    <Border Height="1" Background="{DynamicResource BrushLine}" Margin="8,12"/>
                    <TextBlock Text="ANALYSIS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrushInk400}" Margin="8,0,0,8" LetterSpacing="1.5" FontFamily="{DynamicResource FontLexend}"/>

                    <Button Command="{Binding ShowDashboardCommand}" Classes="navbtn" Classes.active="{Binding IsDashboardActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowInventoryCommand}" Classes="navbtn" Classes.active="{Binding IsInventoryActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconInventory}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Inventory" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowReportsCommand}" Classes="navbtn" Classes.active="{Binding IsReportsActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconReports}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Reports" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowSearchCommand}" Classes="navbtn" Classes.active="{Binding IsSearchActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconSearch}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Search" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- SUPPORT SECTION -->
                    <Border Height="1" Background="{DynamicResource BrushLine}" Margin="8,12"/>
                    <TextBlock Text="SUPPORT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrushInk400}" Margin="8,0,0,8" LetterSpacing="1.5" FontFamily="{DynamicResource FontLexend}"/>

                    <Button Command="{Binding ShowUsersCommand}" Classes="navbtn" Classes.active="{Binding IsUsersActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconUsers}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Users" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowSettingsCommand}" Classes="navbtn" Classes.active="{Binding IsSettingsActive}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource IconUsers}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
