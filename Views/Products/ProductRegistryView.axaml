<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Products"
             x:Class="ClinicSystem.UI.Views.Products.ProductRegistryView"
             x:DataType="vm:ProductRegistryViewModel"
             Background="#F5F7FA">

    <Grid ColumnDefinitions="300,*" Margin="20">
        <!-- Form Side -->
        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20"
                BorderBrush="#E5E7EB" BorderThickness="1"
                BoxShadow="0 1 3 0 #1A000000">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Product Details" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,20"/>
                
                <StackPanel DockPanel.Dock="Bottom" Spacing="10" Margin="0,20,0,0">
                    <Grid ColumnDefinitions="*,*">
                        <Button Grid.Column="0" Content="Save" Command="{Binding SaveCommand}"
                                IsEnabled="{Binding SaveCancelEnabled}"
                                Background="#0EA5E9" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,5,0" CornerRadius="6"/>
                        <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}"
                                IsEnabled="{Binding SaveCancelEnabled}"
                                Background="#F3F4F6" Foreground="#4B5563" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5,0,0,0" CornerRadius="6"/>
                    </Grid>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>

                <ScrollViewer IsEnabled="{Binding SaveCancelEnabled}">
                    <StackPanel Spacing="15">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Name" Foreground="#374151" FontSize="12" FontWeight="Medium"/>
                            <TextBox Text="{Binding Name}" CornerRadius="6" BorderBrush="#D1D5DB"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="5">
                            <TextBlock Text="Company" Foreground="#374151" FontSize="12" FontWeight="Medium"/>
                            <ComboBox ItemsSource="{Binding Companies}" SelectedItem="{Binding SelectedCompany}" 
                                      HorizontalAlignment="Stretch" CornerRadius="6" BorderBrush="#D1D5DB">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Purchase Rate" Foreground="#374151" FontSize="12" FontWeight="Medium"/>
                            <NumericUpDown Value="{Binding PurchaseRate}" FormatString="C2" CornerRadius="6" BorderBrush="#D1D5DB"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Selling Price" Foreground="#374151" FontSize="12" FontWeight="Medium"/>
                            <NumericUpDown Value="{Binding SellingPrice}" FormatString="C2" CornerRadius="6" BorderBrush="#D1D5DB"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Tax (%)" Foreground="#374151" FontSize="12" FontWeight="Medium"/>
                            <NumericUpDown Value="{Binding Tax}" FormatString="N2" CornerRadius="6" BorderBrush="#D1D5DB"/>
                        </StackPanel>
                        
                        <!-- Stock is typically updated via purchases, so this might be readonly or just display -->
                        <StackPanel Spacing="5">
                            <TextBlock Text="Stock Quantity (Manual Adj.)" Foreground="#374151" FontSize="12" FontWeight="Medium"/>
                            <NumericUpDown Value="{Binding StockQuantity}" FormatString="N0" CornerRadius="6" BorderBrush="#D1D5DB"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Grid Side -->
        <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="20,0,0,0"
                BorderBrush="#E5E7EB" BorderThickness="1"
                BoxShadow="0 1 3 0 #1A000000">
            <DockPanel>
                <!-- Toolbar -->
                <Border DockPanel.Dock="Top" Padding="15" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="➕ New" Command="{Binding NewCommand}"
                                IsEnabled="{Binding MutationEnabled}"
                                Background="#10B981" Foreground="White" CornerRadius="6" Padding="15,6"/>
                        <Button Content="✏️ Edit" Command="{Binding EditCommand}"
                                IsEnabled="{Binding MutationEnabled}"
                                Background="#F59E0B" Foreground="White" CornerRadius="6" Padding="15,6"/>
                        <Button Content="🗑️ Delete" Command="{Binding DeleteCommand}"
                                IsEnabled="{Binding MutationEnabled}"
                                Background="#EF4444" Foreground="White" CornerRadius="6" Padding="15,6"/>
                    </StackPanel>
                </Border>
                
                <DataGrid ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0"
                          RowBackground="Transparent"
                          Foreground="#374151">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ProductID}" Width="60"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" Width="150"/>
                        <DataGridTextColumn Header="Purchase Rate" Binding="{Binding PurchaseRate, StringFormat=C2}" Width="120"/>
                        <DataGridTextColumn Header="Selling Price" Binding="{Binding SellingPrice, StringFormat=C2}" Width="120"/>
                        <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
