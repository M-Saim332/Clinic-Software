<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Products"
             x:Class="ClinicSystem.UI.Views.Products.ProductRegistryView"
             x:DataType="vm:ProductRegistryViewModel"
             Background="#F8FAFC">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="24,16"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource IconProducts}" Width="20" Height="20" Foreground="#2563EB"/>
                    <TextBlock Text="Product Registry" FontSize="20" FontWeight="Bold"
                               Foreground="#1F2937" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}"
                           Foreground="#2563EB" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" ColumnDefinitions="340,*">

            <!-- Left: Form -->
            <Border Grid.Column="0" Background="#FFFFFF" Padding="24"
                    BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Save/Cancel at bottom -->
                    <StackPanel DockPanel.Dock="Bottom" Spacing="12" Margin="0,20,0,0">
                        <Grid ColumnDefinitions="*,*">
                            <Button Grid.Column="0" Content="Save" Command="{Binding SaveCommand}"
                                    IsEnabled="{Binding SaveCancelEnabled}"
                                    Classes="primary" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" Margin="0,0,6,0"/>
                            <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}"
                                    IsEnabled="{Binding SaveCancelEnabled}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#DC2626" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer IsEnabled="{Binding SaveCancelEnabled}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Name *" Classes="label"/>
                                <TextBox Text="{Binding Name}" PlaceholderText="Product name"/>
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Company" Classes="label"/>
                                <ComboBox ItemsSource="{Binding Companies}" SelectedItem="{Binding SelectedCompany}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                                    <TextBlock Text="Purchase Rate" Classes="label"/>
                                    <NumericUpDown Value="{Binding PurchaseRate}" FormatString="C2"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Selling Price" Classes="label"/>
                                    <NumericUpDown Value="{Binding SellingPrice}" FormatString="C2"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Tax (%)" Classes="label"/>
                                <NumericUpDown Value="{Binding Tax}" FormatString="N2"/>
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Stock Quantity (Manual Adj.)" Classes="label"/>
                                <NumericUpDown Value="{Binding StockQuantity}" FormatString="N0"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Right: Grid with toolbar -->
            <Border Grid.Column="1" Padding="24">
                <DockPanel>
                    <!-- Toolbar -->
                    <Border DockPanel.Dock="Top" Padding="0,0,0,16"
                            BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding NewCommand}"
                                    IsEnabled="{Binding MutationEnabled}" Classes="primary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconPlus}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="New" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding EditCommand}"
                                    IsEnabled="{Binding MutationEnabled}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconEdit}" Width="14" Height="14" Foreground="#1F2937" VerticalAlignment="Center"/>
                                    <TextBlock Text="Edit" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DeleteCommand}"
                                    IsEnabled="{Binding MutationEnabled}" Classes="danger">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource IconClose}" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="Delete" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <DataGrid ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"            Binding="{Binding ProductID}"                                   Width="60"/>
                            <DataGridTextColumn Header="Name"          Binding="{Binding Name}"                                        Width="*"/>
                            <DataGridTextColumn Header="Company"       Binding="{Binding CompanyName}"                                 Width="150"/>
                            <DataGridTextColumn Header="Purchase Rate" Binding="{Binding PurchaseRate, StringFormat=C2}"               Width="120"/>
                            <DataGridTextColumn Header="Selling Price" Binding="{Binding SellingPrice, StringFormat=C2}"               Width="120"/>
                            <DataGridTextColumn Header="Stock"         Binding="{Binding StockQuantity}"                               Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#FFFFFF" Padding="24,8"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#6B7280" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
