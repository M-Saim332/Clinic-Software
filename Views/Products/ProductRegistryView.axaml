<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Products"
             xmlns:models="using:ClinicSystem.Core.Models"
             xmlns:comp="using:ClinicSystem.UI.Views.Components"
             x:Class="ClinicSystem.UI.Views.Products.ProductRegistryView"
             x:DataType="vm:ProductRegistryViewModel" x:CompileBindings="True"
             Background="{DynamicResource BrushBackground}">

    <Grid>
        <!-- ============================================================ -->
        <!-- 1. LIST/GRID VIEW (SaveCancelEnabled is false)                -->
        <!-- ============================================================ -->
        <Grid IsVisible="{Binding !SaveCancelEnabled}" RowDefinitions="Auto,Auto,*">
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1"
                    Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushTeal50}">
                            <PathIcon Data="{StaticResource IconProducts}" Width="20" Height="20"
                                      Foreground="{DynamicResource BrushTeal}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="Product Registry" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Track products, stocks, expiry dates, and pricing"
                                       FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Primary action: + Add Product -->
                    <Button Content="+ Add Product" Command="{Binding NewCommand}"
                            Classes="btn-primary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Summary Cards Row -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Margin="28,16,28,4">
                <comp:SummaryCardControl Grid.Column="0" Margin="0,0,12,0"
                    Title="Total Products"
                    Value="{Binding Products.Count, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushTeal}"/>
                <comp:SummaryCardControl Grid.Column="1" Margin="0,0,12,0"
                    Title="Low Stock"
                    Value="{Binding LowStockCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushAmber}"/>
                <comp:SummaryCardControl Grid.Column="2" Margin="0,0,12,0"
                    Title="Expired"
                    Value="{Binding ExpiredCount, StringFormat={}{0}}"
                    BorderColor="{DynamicResource BrushRose}"/>
                <comp:SummaryCardControl Grid.Column="3"
                    Title="Inventory Value"
                    Value="{Binding TotalInventoryValue}"
                    BorderColor="{DynamicResource BrushPrimaryBlue}"/>
            </Grid>

            <!-- Data Panel with Tabs -->
            <TabControl Grid.Row="2" Margin="28,12,28,24" SelectedIndex="{Binding SelectedTab}">

                <!-- TAB 0: ALL PRODUCTS -->
                <TabItem Header="All Products" FontSize="14" FontWeight="Medium">
                    <comp:DataTableShellControl Title="Product Inventory" RecordCount="{Binding FilteredProducts.Count}" Margin="0,12,0,0">
                        <!-- Search -->
                        <comp:DataTableShellControl.FilterToolbar>
                            <Border Background="{DynamicResource BrushCardBackground}"
                                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                                    CornerRadius="{DynamicResource CornerRadiusInput}" Padding="12,0"
                                    Height="40" Width="380" Margin="0,0,0,8">
                                <Grid ColumnDefinitions="Auto,*">
                                    <PathIcon Grid.Column="0" Data="{StaticResource IconSearch}" Width="14" Height="14"
                                              Foreground="{DynamicResource BrushInk400}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding SearchTerm}"
                                             PlaceholderText="Search by name, generic, batch or company..."
                                             Classes="search-input" VerticalAlignment="Center" Height="38" Padding="0"/>
                                </Grid>
                            </Border>
                        </comp:DataTableShellControl.FilterToolbar>
                        <!-- Table -->
                        <comp:DataTableShellControl.TableContent>
                            <DataGrid x:Name="ProductGrid"
                                      ItemsSource="{Binding FilteredProducts}"
                                      SelectedItem="{Binding SelectedProduct}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" Background="Transparent"
                                      BorderThickness="0" GridLinesVisibility="Horizontal"
                                      HorizontalScrollBarVisibility="Auto"
                                      RowBackground="{DynamicResource BrushCardBackground}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="PRODUCT NAME" Binding="{Binding Name}" Width="*" MinWidth="160"/>
                                    <DataGridTextColumn Header="COMPANY" Binding="{Binding CompanyName}" Width="130"/>
                                    <DataGridTextColumn Header="EXPIRY" Binding="{Binding ExpiryDate, StringFormat=\{0:dd MMM yyyy\}}" Width="110"/>
                                    <DataGridTextColumn Header="STOCK" Binding="{Binding Stock}" Width="70"/>
                                    <DataGridTextColumn Header="SELLING" Binding="{Binding SellingPrice, StringFormat='Rs. {0:N2}'}" Width="100"/>
                                    <DataGridTemplateColumn Header="ACTIONS" Width="290">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <!-- Patient Return: medicine comes back, revenue decreases -->
                                                    <Button Command="{Binding #ProductGrid.((vm:ProductRegistryViewModel)DataContext).OpenPatientReturnCommand}"
                                                            CommandParameter="{Binding}" ToolTip.Tip="Patient Return (stock ↑, revenue ↓)"
                                                            Classes="btn-amber" Padding="8,4" Height="28" FontSize="11">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <PathIcon Data="{StaticResource IconReturns}" Width="12" Height="12"/>
                                                            <TextBlock Text="Patient Return" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Content="Edit"
                                                            Command="{Binding #ProductGrid.((vm:ProductRegistryViewModel)DataContext).EditSpecificCommand}"
                                                            CommandParameter="{Binding}"
                                                            Classes="btn-secondary" Padding="8,4" Height="28" FontSize="11"/>
                                                    <Button Content="Delete"
                                                            Command="{Binding #ProductGrid.((vm:ProductRegistryViewModel)DataContext).RequestDeleteSpecificCommand}"
                                                            CommandParameter="{Binding}"
                                                            Classes="btn-danger" Padding="8,4" Height="28" FontSize="11"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </comp:DataTableShellControl.TableContent>
                    </comp:DataTableShellControl>
                </TabItem>

                <!-- TAB 1: EXPIRED PRODUCTS -->
                <TabItem Header="Expired" FontSize="14" FontWeight="Medium">
                    <comp:DataTableShellControl Title="Expired Products" RecordCount="{Binding FilteredProducts.Count}" Margin="0,12,0,0">
                        <comp:DataTableShellControl.FilterToolbar>
                            <Border Background="{DynamicResource BrushCardBackground}"
                                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                                    CornerRadius="{DynamicResource CornerRadiusInput}" Padding="12,0"
                                    Height="40" Width="380" Margin="0,0,0,8">
                                <Grid ColumnDefinitions="Auto,*">
                                    <PathIcon Grid.Column="0" Data="{StaticResource IconSearch}" Width="14" Height="14"
                                              Foreground="{DynamicResource BrushInk400}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding SearchTerm}"
                                             PlaceholderText="Search expired products..."
                                             Classes="search-input" VerticalAlignment="Center" Height="38" Padding="0"/>
                                </Grid>
                            </Border>
                        </comp:DataTableShellControl.FilterToolbar>
                        <comp:DataTableShellControl.TableContent>
                            <DataGrid x:Name="ExpiredGrid"
                                      ItemsSource="{Binding FilteredProducts}"
                                      SelectedItem="{Binding SelectedProduct}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" Background="Transparent"
                                      BorderThickness="0" GridLinesVisibility="Horizontal"
                                      HorizontalScrollBarVisibility="Auto"
                                      RowBackground="{DynamicResource BrushCardBackground}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="PRODUCT NAME" Binding="{Binding Name}" Width="*" MinWidth="160"/>
                                    <DataGridTextColumn Header="COMPANY" Binding="{Binding CompanyName}" Width="130"/>
                                    <DataGridTextColumn Header="EXPIRY DATE" Binding="{Binding ExpiryDate, StringFormat=\{0:dd MMM yyyy\}}" Width="120"/>
                                    <DataGridTextColumn Header="STOCK" Binding="{Binding Stock}" Width="70"/>
                                    <DataGridTextColumn Header="PURCHASE" Binding="{Binding PurchasePrice, StringFormat='Rs. {0:N2}'}" Width="100"/>
                                    <DataGridTemplateColumn Header="ACTIONS" Width="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <!-- Return to seller: stock goes to seller, clinic gets money back -->
                                                    <Button Command="{Binding #ExpiredGrid.((vm:ProductRegistryViewModel)DataContext).OpenSupplierReturnCommand}"
                                                            CommandParameter="{Binding}" ToolTip.Tip="Return to Seller (stock ↓, revenue ↑)"
                                                            Classes="btn-danger" Padding="8,4" Height="28" FontSize="11">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <PathIcon Data="{StaticResource IconReturns}" Width="12" Height="12"/>
                                                            <TextBlock Text="Return to Seller" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </comp:DataTableShellControl.TableContent>
                    </comp:DataTableShellControl>
                </TabItem>

                <!-- TAB 2: UNSOLD PRODUCTS -->
                <TabItem Header="Unsold Products" FontSize="14" FontWeight="Medium">
                    <comp:DataTableShellControl Title="Unsold Products" RecordCount="{Binding FilteredProducts.Count}" Margin="0,12,0,0">
                        <comp:DataTableShellControl.FilterToolbar>
                            <StackPanel Orientation="Vertical" Spacing="4" Margin="0,0,0,8">
                                <TextBlock Text="These products still have stock and are not expired. You can return them to the seller."
                                           FontSize="11" Foreground="{DynamicResource BrushInk600}"/>
                                <Border Background="{DynamicResource BrushCardBackground}"
                                        BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                                        CornerRadius="{DynamicResource CornerRadiusInput}" Padding="12,0"
                                        Height="40" Width="380">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <PathIcon Grid.Column="0" Data="{StaticResource IconSearch}" Width="14" Height="14"
                                                  Foreground="{DynamicResource BrushInk400}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding SearchTerm}"
                                                 PlaceholderText="Search unsold products..."
                                                 Classes="search-input" VerticalAlignment="Center" Height="38" Padding="0"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </comp:DataTableShellControl.FilterToolbar>
                        <comp:DataTableShellControl.TableContent>
                            <DataGrid x:Name="UnsoldGrid"
                                      ItemsSource="{Binding FilteredProducts}"
                                      SelectedItem="{Binding SelectedProduct}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" Background="Transparent"
                                      BorderThickness="0" GridLinesVisibility="Horizontal"
                                      HorizontalScrollBarVisibility="Auto"
                                      RowBackground="{DynamicResource BrushCardBackground}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="PRODUCT NAME" Binding="{Binding Name}" Width="*" MinWidth="160"/>
                                    <DataGridTextColumn Header="COMPANY" Binding="{Binding CompanyName}" Width="130"/>
                                    <DataGridTextColumn Header="EXPIRY" Binding="{Binding ExpiryDate, StringFormat=\{0:dd MMM yyyy\}}" Width="110"/>
                                    <DataGridTextColumn Header="STOCK (Unsold)" Binding="{Binding Stock}" Width="100"/>
                                    <DataGridTextColumn Header="PURCHASE" Binding="{Binding PurchasePrice, StringFormat='Rs. {0:N2}'}" Width="100"/>
                                    <DataGridTemplateColumn Header="ACTIONS" Width="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Button Command="{Binding #UnsoldGrid.((vm:ProductRegistryViewModel)DataContext).OpenSupplierReturnCommand}"
                                                            CommandParameter="{Binding}" ToolTip.Tip="Return unsold stock to seller"
                                                            Classes="btn-danger" Padding="8,4" Height="28" FontSize="11">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <PathIcon Data="{StaticResource IconReturns}" Width="12" Height="12"/>
                                                            <TextBlock Text="Return to Seller" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </comp:DataTableShellControl.TableContent>
                    </comp:DataTableShellControl>
                </TabItem>

            </TabControl>

            <!-- Delete Confirmation Overlay -->
            <Border Grid.Row="0" Grid.RowSpan="3"
                    IsVisible="{Binding ShowDeleteConfirm}"
                    Background="#80000000" ZIndex="100">
                <Border Background="{DynamicResource BrushCardBackground}"
                        CornerRadius="12" Padding="32,28"
                        MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center"
                        BoxShadow="0 8 32 0 #30000000">
                    <StackPanel Spacing="20">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Delete Product?" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="{Binding PendingDeleteLabel}"
                                       FontSize="14" Foreground="{DynamicResource BrushInk600}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="This action cannot be undone. The product will be permanently removed."
                                       FontSize="12" Foreground="{DynamicResource BrushInk400}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                            <Button Content="Cancel" Command="{Binding CancelDeleteCommand}" Classes="btn-ghost"/>
                            <Button Content="Yes, Delete" Command="{Binding ConfirmDeleteCommand}" Classes="btn-danger"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

            <!-- RETURN MODAL OVERLAY -->
            <Border Grid.Row="0" Grid.RowSpan="3"
                    IsVisible="{Binding IsReturnModalOpen}"
                    Background="#80000000" ZIndex="200">
                <Border Background="{DynamicResource BrushCardBackground}"
                        CornerRadius="16" Padding="28,24"
                        MaxWidth="460" HorizontalAlignment="Center" VerticalAlignment="Center"
                        BoxShadow="0 12 40 0 #40000000">
                    <StackPanel Spacing="16">
                        <!-- Header -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding ReturnModalTitle}" FontSize="18" FontWeight="Bold"
                                       FontFamily="{DynamicResource FontLexend}"
                                       Foreground="{DynamicResource BrushInk900}"/>
                            <TextBlock Text="{Binding ReturnModalSubtitle}" FontSize="12"
                                       Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>

                        <!-- Info row: Quantity + Reason -->
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,8,0">
                                <TextBlock Text="Return Quantity" FontSize="12" FontWeight="Medium"
                                           Foreground="{DynamicResource BrushInk700}"/>
                                <NumericUpDown Minimum="1" Value="{Binding ReturnQuantity}"
                                              HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6" Margin="8,0,0,0">
                                <TextBlock Text="Reason" FontSize="12" FontWeight="Medium"
                                           Foreground="{DynamicResource BrushInk700}"/>
                                <ComboBox ItemsSource="{Binding ReturnReasons}"
                                          SelectedItem="{Binding ReturnReason}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>

                        <!-- Error / status -->
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushRose}"
                                   TextWrapping="Wrap" MinHeight="16" FontSize="12"/>

                        <!-- Actions -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,4,0,0">
                            <Button Content="Cancel" Command="{Binding CloseReturnModalCommand}" Classes="btn-secondary"/>
                            <Button Content="Submit Return" Command="{Binding SubmitReturnCommand}" Classes="btn-primary"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <!-- ============================================================ -->
        <!-- 2. FORM VIEW (SaveCancelEnabled is true)                       -->
        <!-- ============================================================ -->
        <Grid IsVisible="{Binding SaveCancelEnabled}" RowDefinitions="Auto,*,Auto">
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,0,0,1"
                    Padding="28,18">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource BrushTeal50}">
                            <PathIcon Data="{StaticResource IconProducts}" Width="20" Height="20"
                                      Foreground="{DynamicResource BrushTeal}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="{Binding Mode, StringFormat='{}{0} Product'}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushInk900}"
                                       FontFamily="{DynamicResource FontLexend}"/>
                            <TextBlock Text="Fill out the product details below"
                                       FontSize="12" Foreground="{DynamicResource BrushInk600}"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Back Button -->
                    <Button Content="Back" Command="{Binding CancelCommand}"
                            Classes="btn-secondary" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Scrollable Form Body -->
            <ScrollViewer Grid.Row="1" Padding="28,24,28,60">
                <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Left">
                    <!-- SECTION 1: Quick Entry -->
                    <StackPanel Spacing="16">
                        <TextBlock Text="QUICK ENTRY" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushInk400}" LetterSpacing="1.5"
                                   FontFamily="{DynamicResource FontLexend}"/>
                        <Separator/>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                            <!-- Name -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="Product Name *" Classes="label"/>
                                <TextBox Text="{Binding Name}" PlaceholderText="e.g. Amoxicillin 500mg"/>
                            </StackPanel>
                            <!-- Type -->
                            <StackPanel Grid.Column="1" Grid.Row="0" Spacing="6" Margin="12,0,0,12">
                                <TextBlock Text="Type" Classes="label"/>
                                <TextBox Text="{Binding Type}" PlaceholderText="e.g. Tablet, Syrup, Injection"/>
                            </StackPanel>
                            
                            <!-- Category -->
                            <StackPanel Grid.Column="0" Grid.Row="1" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="Category" Classes="label"/>
                                <TextBox Text="{Binding Category}" PlaceholderText="e.g. Antibiotics"/>
                            </StackPanel>
                            <!-- Batch Number -->
                            <StackPanel Grid.Column="1" Grid.Row="1" Spacing="6" Margin="12,0,0,12">
                                <TextBlock Text="Batch Number" Classes="label"/>
                                <TextBox Text="{Binding BatchNumber}" PlaceholderText="e.g. B-9988"/>
                            </StackPanel>
                            
                            <!-- Purchase Price -->
                            <StackPanel Grid.Column="0" Grid.Row="2" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="Purchase Price (Rs.)" Classes="label"/>
                                <TextBox Text="{Binding PurchasePrice}" PlaceholderText="0.00"/>
                            </StackPanel>
                            <!-- Selling Price -->
                            <StackPanel Grid.Column="1" Grid.Row="2" Spacing="6" Margin="12,0,0,12">
                                <TextBlock Text="Selling Price (Rs.)" Classes="label"/>
                                <TextBox Text="{Binding SellingPrice}" PlaceholderText="0.00"/>
                            </StackPanel>
                            
                            <!-- Current Stock -->
                            <StackPanel Grid.Column="0" Grid.Row="3" Spacing="6" Margin="0,0,12,12">
                                <TextBlock Text="Current Stock" Classes="label"/>
                                <TextBox Text="{Binding Stock}" PlaceholderText="0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- SECTION 2: Advanced Fields (Accordion) -->
                    <Expander Header="Advanced Details" HorizontalAlignment="Stretch" 
                              Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource BrushLine}" 
                              CornerRadius="{DynamicResource CornerRadiusCard}" Padding="16,8">
                        <StackPanel Spacing="16" Margin="0,12,0,0">
                             <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                                <!-- Generic Name -->
                                <StackPanel Grid.Column="0" Grid.Row="0" Spacing="6" Margin="0,0,12,12">
                                    <TextBlock Text="Generic Name" Classes="label"/>
                                    <TextBox Text="{Binding GenericName}" PlaceholderText="e.g. Amoxicillin Trihydrate"/>
                                </StackPanel>
                                <!-- Company -->
                                <StackPanel Grid.Column="1" Grid.Row="0" Spacing="6" Margin="12,0,0,12">
                                    <TextBlock Text="Company" Classes="label"/>
                                    <ComboBox ItemsSource="{Binding Companies}" SelectedItem="{Binding SelectedCompany}" HorizontalAlignment="Stretch" PlaceholderText="Select Company (Optional)">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:Company">
                                                <TextBlock Text="{Binding Name}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBox Text="{Binding CompanyName}" PlaceholderText="Or type Company Name here..." Margin="0,4,0,0"
                                             IsVisible="{Binding SelectedCompany, Converter={x:Static ObjectConverters.IsNull}}"/>
                                </StackPanel>
                                
                                <!-- Rack -->
                                <StackPanel Grid.Column="0" Grid.Row="1" Spacing="6" Margin="0,0,12,12">
                                    <TextBlock Text="Rack" Classes="label"/>
                                    <TextBox Text="{Binding Rack}" PlaceholderText="e.g. A1, Shelf 3"/>
                                </StackPanel>
                                <!-- Expiry Date -->
                                <StackPanel Grid.Column="1" Grid.Row="1" Spacing="6" Margin="12,0,0,12">
                                    <TextBlock Text="Expiry Date" Classes="label"/>
                                    <DatePicker SelectedDate="{Binding ExpiryDate}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                
                                <!-- Minimum Stock Level -->
                                <StackPanel Grid.Column="0" Grid.Row="2" Spacing="6" Margin="0,0,12,12">
                                    <TextBlock Text="Reorder Level (Min Stock)" Classes="label"/>
                                    <TextBox Text="{Binding MinimumStockLevel}" PlaceholderText="10"/>
                                </StackPanel>
                             </Grid>
                        </StackPanel>
                    </Expander>

                        <!-- Snapshot Card -->
                        <Border Background="{DynamicResource BrushBlue50}"
                                BorderBrush="{DynamicResource BrushLine}" BorderThickness="1"
                                CornerRadius="{DynamicResource CornerRadiusInput}"
                                Padding="20,16" Margin="0,8,0,0" MaxWidth="500" HorizontalAlignment="Left">
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*">
                                <TextBlock Grid.ColumnSpan="2" Text="Financial Snapshot"
                                           Foreground="{DynamicResource BrushInk900}"
                                           FontWeight="Bold" Margin="0,0,0,10" FontSize="13"
                                           FontFamily="{DynamicResource FontLexend}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{Binding ProfitPerUnitText}"
                                           Foreground="{DynamicResource BrushPrimaryBlue}"
                                           FontSize="16" FontWeight="SemiBold"
                                           FontFamily="{DynamicResource FontMono}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding InventoryValueText}"
                                           Foreground="{DynamicResource BrushPrimaryBlue}"
                                           FontSize="16" FontWeight="SemiBold"
                                           FontFamily="{DynamicResource FontMono}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="Profit / unit"
                                           Foreground="{DynamicResource BrushInk600}" FontSize="11"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="Inventory Value"
                                           Foreground="{DynamicResource BrushInk600}" FontSize="11"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource BrushCardBackground}"
                    BorderBrush="{DynamicResource BrushLine}" BorderThickness="0,1,0,0"
                    Padding="28,16">
                <DockPanel>
                    <!-- Error or info messages go here -->
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushRose}"
                               VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Save Product" Command="{Binding SaveCommand}" Classes="btn-primary"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="{DynamicResource BrushPrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk900}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushInk600}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushLine}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="{DynamicResource BrushRose}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#BE123C"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.40"/>
        </Style>
        <Style Selector="Button.btn-amber">
            <Setter Property="Background" Value="#D97706"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.btn-amber:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#B45309"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>
</UserControl>
