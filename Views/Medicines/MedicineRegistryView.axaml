<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClinicSystem.UI.ViewModels.Medicines"
             xmlns:models="using:ClinicSystem.Core.Models"
             x:Class="ClinicSystem.UI.Views.Medicines.MedicineRegistryView"
             x:DataType="vm:MedicineRegistryViewModel"
             Background="#F8FAFC">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="24,16" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource IconMedicines}" Width="20" Height="20" Foreground="#2563EB"/>
                    <TextBlock Text="Medicine Registry" FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}" Foreground="#2563EB" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="380,*">

            <!-- Left: Form -->
            <Border Grid.Column="0" Background="#FFFFFF" Padding="24" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
                <ScrollViewer>
                    <StackPanel Spacing="16">
                        <TextBlock Text="Actions" Classes="label" Foreground="#6B7280" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="New"    Command="{Binding NewCommand}"    IsEnabled="{Binding MutationEnabled}" Classes="action" Margin="0,0,6,6"/>
                            <Button Content="Edit"   Command="{Binding EditCommand}"   IsEnabled="{Binding MutationEnabled}" Classes="action" Margin="0,0,6,6"/>
                            <Button Content="Delete" Command="{Binding DeleteCommand}" IsEnabled="{Binding MutationEnabled}" Classes="action danger" Margin="0,0,6,6"/>
                            <Button Content="Save"   Command="{Binding SaveCommand}"   IsEnabled="{Binding SaveCancelEnabled}" Classes="action primary" Margin="0,0,6,6"/>
                            <Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding SaveCancelEnabled}" Classes="action" Margin="0,0,6,6"/>
                        </WrapPanel>
                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="Find" Command="{Binding FindCommand}" IsEnabled="{Binding MutationEnabled}" Classes="action" Margin="0,0,6,6"/>
                            <Button Content="List" Command="{Binding ListCommand}" IsEnabled="{Binding MutationEnabled}" Classes="action" Margin="0,0,6,6"/>
                        </WrapPanel>
                        <Separator Background="#E5E7EB" Height="1" Margin="0,8"/>

                        <!-- Form Fields -->
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Name *" Classes="label"/>
                                <TextBox Text="{Binding Name}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="Medicine name"/>
                            </StackPanel>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                                    <TextBlock Text="Generic Name" Classes="label"/>
                                    <TextBox Text="{Binding GenericName}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="e.g. Paracetamol"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Company" Classes="label"/>
                                    <ComboBox ItemsSource="{Binding Companies}"
                                              SelectedItem="{Binding SelectedCompany}"
                                              IsEnabled="{Binding SaveCancelEnabled}"
                                              HorizontalAlignment="Stretch">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:Company">
                                                <TextBlock Text="{Binding Name}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                                    <TextBlock Text="Batch Number" Classes="label"/>
                                    <TextBox Text="{Binding BatchNumber}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="Batch No."/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Expiry Date" Classes="label"/>
                                    <DatePicker SelectedDate="{Binding ExpiryDate}" IsEnabled="{Binding SaveCancelEnabled}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                                    <TextBlock Text="Purchase Price" Classes="label"/>
                                    <TextBox Text="{Binding PurchasePrice}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="0.00"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Selling Price" Classes="label"/>
                                    <TextBox Text="{Binding SellingPrice}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="0.00"/>
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                                    <TextBlock Text="Stock" Classes="label"/>
                                    <TextBox Text="{Binding Stock}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Min Stock Level" Classes="label"/>
                                    <TextBox Text="{Binding MinimumStockLevel}" IsEnabled="{Binding SaveCancelEnabled}" PlaceholderText="10"/>
                                </StackPanel>
                            </Grid>

                            <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8,0,0">
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*">
                                    <TextBlock Grid.ColumnSpan="2" Text="Financial Snapshot" Foreground="#1F2937" FontWeight="Bold" Margin="0,0,0,10" FontSize="13"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ProfitPerUnitText}" Classes="metricValue" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding InventoryValueText}" Classes="metricValue" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Profit / unit" Classes="metricLabel"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Inventory Value" Classes="metricLabel"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right: List / Welcome -->
            <Border Grid.Column="1" Padding="24">
                <Grid>
                    <Border IsVisible="{Binding ShowList}" Background="#FFFFFF" Classes="card">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                                <TextBlock Text="Find Medicine" FontSize="16" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Command="{Binding CloseListCommand}" Classes="action"
                                        Width="32" Height="32" Padding="0"
                                        Background="Transparent" BorderThickness="0">
                                    <PathIcon Data="{StaticResource IconClose}" Width="12" Height="12" Foreground="#6B7280"/>
                                </Button>
                            </DockPanel>
                            <TextBox DockPanel.Dock="Top" Text="{Binding SearchTerm}"
                                     PlaceholderText="Search by name, generic name, company or batch..." Margin="0,0,0,16"/>
                            <DataGrid ItemsSource="{Binding FilteredMedicines}"
                                      SelectedItem="{Binding SelectedMedicine}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name"         Binding="{Binding Name}"         Width="*"/>
                                    <DataGridTextColumn Header="Generic Name" Binding="{Binding GenericName}"  Width="130"/>
                                    <DataGridTextColumn Header="Company"      Binding="{Binding CompanyName}"  Width="120"/>
                                    <DataGridTextColumn Header="Stock"        Binding="{Binding Stock}"        Width="70"/>
                                    <DataGridTextColumn Header="Status"       Binding="{Binding StockStatus}"  Width="80"/>
                                    <DataGridTextColumn Header="Purchase"     Binding="{Binding PurchasePrice, StringFormat=\{0:F2\}}" Width="90"/>
                                    <DataGridTextColumn Header="Selling"      Binding="{Binding SellingPrice, StringFormat=\{0:F2\}}" Width="90"/>
                                    <DataGridTextColumn Header="Expiry"       Binding="{Binding ExpiryDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="110"/>
                                    <DataGridTextColumn Header="Batch"        Binding="{Binding BatchNumber}"  Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button DockPanel.Dock="Bottom" Content="Select Medicine" Margin="0,16,0,0"
                                    Command="{Binding SelectFromListCommand}"
                                    CommandParameter="{Binding SelectedMedicine}"
                                    Classes="action primary" HorizontalAlignment="Left"/>
                        </DockPanel>
                    </Border>

                    <StackPanel IsVisible="{Binding !ShowList}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                        <Border Width="64" Height="64" CornerRadius="32" Background="#EFF6FF">
                            <PathIcon Data="{StaticResource IconMedicines}" Width="24" Height="24" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Medicine Registry" FontSize="20" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center"/>
                        <TextBlock Text="Track medicines, stocks, prices, expiries and batch numbers." Foreground="#6B7280" HorizontalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" Padding="24,8" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#6B7280" FontSize="12"/>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="TextBlock.metricValue">
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TextBlock.metricLabel">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.action.primary">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.action.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.action.danger">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.action.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#B91C1C"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
    </UserControl.Styles>
</UserControl>
